[{"data":1,"prerenderedAt":130},["ShallowReactive",2],{"tag-content-entertainment":3},[4,22,35,46,57,69,83,95,107,118],{"slug":5,"title":6,"description":7,"date":11,"tags":12},"guess-the-word","猜词游戏",[8,9,10],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。","2026\u002F5\u002F20",[13,16,19],[14,15],"lang","web",[17,18],"inspiration","original",[20,21],"content","entertainment",{"slug":23,"title":24,"description":25,"date":29,"tags":30},"village-of-chaos","Village of Chaos",[26,27,28],"简短文字放置游戏，原生JS编写，轻松挂机发展村庄。","支持多语言切换，覆盖中文简繁体。","完全免费在线游玩，无需下载即开即玩。","2026\u002F3\u002F6",[31,32,34],[14,15],[17,33],"localization",[20,21],{"slug":36,"title":37,"description":38,"date":41,"tags":42},"loop-jam","2^1024 Loops",[39,40],"2^1024 Loops 是由 MrRedShark77 在 GMTK Game Jam 2025 上制作的游戏。游戏的目标是通过编程，达到 2^1024（约 1.8x10^308）。","本文章提供游戏相关教程和攻略。","2025\u002F8\u002F14",[43,44,45],[14,15],[17,33],[20,21],{"slug":47,"title":48,"description":49,"date":52,"tags":53},"word-solitaire","单词接龙",[50,51],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[54,55,56],[14,15],[17,18],[20,21],{"slug":58,"title":59,"description":60,"date":63,"tags":64},"file-matchmaking","文件消消乐",[61,62],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[65,67,68],[14,66],"python3",[17,18],[20,21],{"slug":70,"title":71,"description":72,"date":76,"tags":77},"oh-my-dear-js","Oh my dear JavaScript",[73,74,75],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[78,80,82],[14,79],"scratch3",[17,81],"adaptation",[20,21],{"slug":84,"title":85,"description":86,"date":90,"tags":91},"numbers-eating-game","大数吃小数游戏",[87,88,89],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[92,93,94],[14,79],[17,81],[20,21],{"slug":96,"title":97,"description":98,"date":102,"tags":103},"chicken-parkour","小鸡跑酷",[99,100,101],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[104,105,106],[14,79],[17,18],[20,21],{"slug":108,"title":109,"description":110,"date":113,"tags":114},"cut-fruit","切水果",[111,112],"Scratch休闲游戏，键盘操作简单易上手，切水果感受舒适爽感，多种升级可用。","在升级的加持下，切碎上千水果，通关游戏！","2025\u002F1\u002F24",[115,116,117],[14,79],[17,81],[20,21],{"slug":119,"title":120,"description":121,"date":125,"tags":126},"click-ta","点击Ta!",[122,123,124],"点击Ta！升级，然后再次点击Ta！","这是一个点击游戏，点击角色赚取金币。在商店中购买升级道具。","从零开始，获取99999999金币，通关游戏！","2024\u002F8\u002F23",[127,128,129],[14,79],[17,81],[20,21],1779597318457]
[{"data":1,"prerenderedAt":107},["ShallowReactive",2],{"tag-content-entertainment":3},[4,22,33,45,57,71,83,95],{"slug":5,"title":6,"description":7,"date":11,"tags":12},"village-of-chaos","Village of Chaos",[8,9,10],"简短文字放置游戏，原生JS编写，轻松挂机发展村庄。","支持多语言切换，覆盖中文简繁体。","完全免费在线游玩，无需下载即开即玩。","2026\u002F3\u002F6",[13,16,19],[14,15],"lang","web",[17,18],"inspiration","localization",[20,21],"content","entertainment",{"slug":23,"title":24,"description":25,"date":28,"tags":29},"loop-jam","2^1024 Loops",[26,27],"2^1024 Loops 是由 MrRedShark77 在 GMTK Game Jam 2025 上制作的游戏。游戏的目标是通过编程，达到 2^1024（约 1.8x10^308）。","本文章提供游戏相关教程和攻略。","2025\u002F8\u002F14",[30,31,32],[14,15],[17,18],[20,21],{"slug":34,"title":35,"description":36,"date":39,"tags":40},"word-solitaire","单词接龙",[37,38],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[41,42,44],[14,15],[17,43],"original",[20,21],{"slug":46,"title":47,"description":48,"date":51,"tags":52},"file-matchmaking","文件消消乐",[49,50],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[53,55,56],[14,54],"python3",[17,43],[20,21],{"slug":58,"title":59,"description":60,"date":64,"tags":65},"oh-my-dear-js","Oh my dear JavaScript",[61,62,63],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[66,68,70],[14,67],"scratch3",[17,69],"adaptation",[20,21],{"slug":72,"title":73,"description":74,"date":78,"tags":79},"numbers-eating-game","大数吃小数游戏",[75,76,77],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[80,81,82],[14,67],[17,69],[20,21],{"slug":84,"title":85,"description":86,"date":90,"tags":91},"chicken-parkour","小鸡跑酷",[87,88,89],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[92,93,94],[14,67],[17,43],[20,21],{"slug":96,"title":97,"description":98,"date":102,"tags":103},"click-ta","点击Ta!",[99,100,101],"点击Ta！升
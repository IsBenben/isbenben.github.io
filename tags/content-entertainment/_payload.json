[{"data":1,"prerenderedAt":130},["ShallowReactive",2],{"tag-content-entertainment":3},[4,22,35,46,57,69,83,95,107,118],{"title":5,"description":6,"date":10,"tags":11,"path":21},"猜词游戏",[7,8,9],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。","2026\u002F5\u002F20",[12,15,18],[13,14],"lang","web",[16,17],"inspiration","original",[19,20],"content","entertainment","\u002Fpages\u002Fguess-the-word",{"title":23,"description":24,"date":28,"tags":29,"path":34},"Village of Chaos",[25,26,27],"简短文字放置游戏，原生JS编写，轻松挂机发展村庄。","支持多语言切换，覆盖中文简繁体。","完全免费在线游玩，无需下载即开即玩。","2026\u002F3\u002F6",[30,31,33],[13,14],[16,32],"localization",[19,20],"\u002Fpages\u002Fvillage-of-chaos",{"title":36,"description":37,"date":40,"tags":41,"path":45},"2^1024 Loops",[38,39],"2^1024 Loops 是由 MrRedShark77 在 GMTK Game Jam 2025 上制作的游戏。游戏的目标是通过编程，达到 2^1024（约 1.8x10^308）。","本文章提供游戏相关教程和攻略。","2025\u002F8\u002F14",[42,43,44],[13,14],[16,32],[19,20],"\u002Fpages\u002Floop-jam",{"title":47,"description":48,"date":51,"tags":52,"path":56},"单词接龙",[49,50],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[53,54,55],[13,14],[16,17],[19,20],"\u002Fpages\u002Fword-solitaire",{"title":58,"description":59,"date":62,"tags":63,"path":68},"文件消消乐",[60,61],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[64,66,67],[13,65],"python3",[16,17],[19,20],"\u002Fpages\u002Ffile-matchmaking",{"title":70,"description":71,"date":75,"tags":76,"path":82},"Oh my dear JavaScript",[72,73,74],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[77,79,81],[13,78],"scratch3",[16,80],"adaptation",[19,20],"\u002Fpages\u002Foh-my-dear-js",{"title":84,"description":85,"date":89,"tags":90,"path":94},"大数吃小数游戏",[86,87,88],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[91,92,93],[13,78],[16,80],[19,20],"\u002Fpages\u002Fnumbers-eating-game",{"title":96,"description":97,"date":101,"tags":102,"path":106},"小鸡跑酷",[98,99,100],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[103,104,105],[13,78],[16,17],[19,20],"\u002Fpages\u002Fchicken-parkour",{"title":108,"description":109,"date":112,"tags":113,"path":117},"切水果",[110,111],"Scratch休闲游戏，键盘操作简单易上手，切水果感受舒适爽感，多种升级可用。","在升级的加持下，切碎上千水果，通关游戏！","2025\u002F1\u002F24",[114,115,116],[13,78],[16,80],[19,20],"\u002Fpages\u002Fcut-fruit",{"title":119,"description":120,"date":124,"tags":125,"path":129},"点击Ta!",[121,122,123],"点击Ta！升级，然后再次点击Ta！","这是一个点击游戏，点击角色赚取金币。在商店中购买升级道具。","从零开始，获取99999999金币，通关游戏！","2024\u002F8\u002F23",[126,127,128],[13,78],[16,80],[19,20],"\u002Fpages\u002Fclick-ta",1781181638327]
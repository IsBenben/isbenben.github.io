[{"data":1,"prerenderedAt":131},["ShallowReactive",2],{"tag-inspiration-original":3},[4,22,35,46,58,72,84,95,107,119],{"title":5,"description":6,"date":10,"tags":11,"path":21},"猜词游戏",[7,8,9],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。","2026\u002F05\u002F20",[12,15,18],[13,14],"lang","web",[16,17],"inspiration","original",[19,20],"content","entertainment","\u002Fpages\u002Fguess-the-word",{"title":23,"description":24,"date":27,"tags":28,"path":34},"禁用矿石烧炼",[25,26],"该数据包会禁用部分会浪费的矿石烧炼配方。","支持1.13+的主流版本，在Modrinth上发布。","2025\u002F08\u002F25",[29,31,32],[13,30],"minecraft",[16,17],[19,33],"tool","\u002Fpages\u002Fdisable-ore-smelting",{"title":36,"description":37,"date":40,"tags":41,"path":45},"单词接龙",[38,39],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F03\u002F07",[42,43,44],[13,14],[16,17],[19,20],"\u002Fpages\u002Fword-solitaire",{"title":47,"description":48,"date":51,"tags":52,"path":57},"文件消消乐",[49,50],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F03\u002F01",[53,55,56],[13,54],"python3",[16,17],[19,20],"\u002Fpages\u002Ffile-matchmaking",{"title":59,"description":60,"date":64,"tags":65,"path":71},"Scratch支持UTF-16",[61,62,63],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。","2025\u002F02\u002F17",[66,68,69],[13,67],"scratch3",[16,17],[19,70],"learning","\u002Fpages\u002Futf-16-supporting",{"title":73,"description":74,"date":78,"tags":79,"path":83},"小鸡跑酷",[75,76,77],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F02\u002F10",[80,81,82],[13,67],[16,17],[19,20],"\u002Fpages\u002Fchicken-parkour",{"title":85,"description":86,"date":89,"tags":90,"path":94},"“找规律”",[87,88],"Python程序，可以通过多项式拟合几乎任意的数列，即\"找规律\"。","原理是一种类似于拉格朗日插值的算法。","2025\u002F02\u002F03",[91,92,93],[13,54],[16,17],[19,33],"\u002Fpages\u002Ffind-patterns",{"title":96,"description":97,"date"
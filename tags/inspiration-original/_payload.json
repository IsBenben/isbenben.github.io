[{"data":1,"prerenderedAt":131},["ShallowReactive",2],{"tag-inspiration-original":3},[4,22,35,46,58,69,83,95,107,119],{"title":5,"description":6,"date":10,"tags":11,"path":21},"猜词游戏",[7,8,9],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。","2026\u002F5\u002F20",[12,15,18],[13,14],"lang","web",[16,17],"inspiration","original",[19,20],"content","entertainment","\u002Fpages\u002Fguess-the-word",{"title":23,"description":24,"date":27,"tags":28,"path":34},"禁用矿石烧炼",[25,26],"该数据包会禁用部分会浪费的矿石烧炼配方。","支持1.13+的主流版本，在Modrinth上发布。","2025\u002F8\u002F25",[29,31,32],[13,30],"minecraft",[16,17],[19,33],"tool","\u002Fpages\u002Fdisable-ore-smelting",{"title":36,"description":37,"date":40,"tags":41,"path":45},"单词接龙",[38,39],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[42,43,44],[13,14],[16,17],[19,20],"\u002Fpages\u002Fword-solitaire",{"title":47,"description":48,"date":51,"tags":52,"path":57},"文件消消乐",[49,50],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[53,55,56],[13,54],"python3",[16,17],[19,20],"\u002Fpages\u002Ffile-matchmaking",{"title":59,"description":60,"date":63,"tags":64,"path":68},"“找规律”",[61,62],"Python程序，可以通过多项式拟合几乎任意的数列，即\"找规律\"。","原理是一种类似于拉格朗日插值的算法。","2025\u002F2\u002F3",[65,66,67],[13,54],[16,17],[19,33],"\u002Fpages\u002Ffind-patterns",{"title":70,"description":71,"date":75,"tags":76,"path":82},"Scratch支持UTF-16",[72,73,74],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。","2025\u002F2\u002F17",[77,79,80],[13,78],"scratch3",[16,17],[19,81],"learning","\u002Fpages\u002Futf-16-supporting",{"title":84,"description":85,"date":89,"tags":90,"path":94},"小鸡跑酷",[86,87,88],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[91,92,93],[13,78],[16,17],[19,20],"\u002Fpages\u002Fchicken-parkour",{"title":96,"description":97,"date":101,"tags":102,"path":106},"Scratch-Language",[98,99,100],"用Python为Scratch做的编程语言。","编译成品为Scratch可直接识别的project.json。","已经支持基本的编程语法。","2024\u002F8\u002F25",[103,104,105],[13,54],[16,17],[19,33],"\u002Fpages\u002Fscratch-language",{"title":108,"description":109,"date":113,"tags":114,"path":118},"快速添加到收藏夹",[110,111,112],"这是一个 Chrome 浏览器插件，需要开启开发者模式导入该插件，在 B 站视频中就可以快速添加到收藏夹。","快速添加到收藏夹：根据B站视频的标签自动创建并匹配收藏夹。","原理：通过 JS 脚本操作 DOM 元素，模拟点击按钮和输入，实现快速添加到收藏夹。","2024\u002F12\u002F5",[115,116,117],[13,14],[16,17],[19,33],"\u002Fpages\u002Ffast-collection",{"title":120,"description":121,"date":124,"tags":125,"path":130},"字符画",[122,123],"Python制作的字符画程序，可以把图片用字符显示出来。","使用方法：安装pillow库，在相同目录放置字体font.ttf","2024\u002F11\u002F9",[126,127,128],[13,54],[16,17],[19,129],"art","\u002Fpages\u002Fcharacters-drawing",1782302454445]
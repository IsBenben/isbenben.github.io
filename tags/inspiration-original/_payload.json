[{"data":1,"prerenderedAt":131},["ShallowReactive",2],{"tag-inspiration-original":3},[4,22,35,46,58,69,83,95,107,119],{"slug":5,"title":6,"description":7,"date":11,"tags":12},"guess-the-word","猜词游戏",[8,9,10],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。","2026\u002F5\u002F20",[13,16,19],[14,15],"lang","web",[17,18],"inspiration","original",[20,21],"content","entertainment",{"slug":23,"title":24,"description":25,"date":28,"tags":29},"disable-ore-smelting","禁用矿石烧炼",[26,27],"该数据包会禁用部分会浪费的矿石烧炼配方。","支持1.13+的主流版本，在Modrinth上发布。","2025\u002F8\u002F25",[30,32,33],[14,31],"minecraft",[17,18],[20,34],"tool",{"slug":36,"title":37,"description":38,"date":41,"tags":42},"word-solitaire","单词接龙",[39,40],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[43,44,45],[14,15],[17,18],[20,21],{"slug":47,"title":48,"description":49,"date":52,"tags":53},"file-matchmaking","文件消消乐",[50,51],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[54,56,57],[14,55],"python3",[17,18],[20,21],{"slug":59,"title":60,"description":61,"date":64,"tags":65},"find-patterns","“找规律”",[62,63],"Python程序，可以通过多项式拟合几乎任意的数列，即\"找规律\"。","原理是一种类似于拉格朗日插值的算法。","2025\u002F2\u002F3",[66,67,68],[14,55],[17,18],[20,34],{"slug":70,"title":71,"description":72,"date":76,"tags":77},"utf-16-supporting","Scratch支持UTF-16",[73,74,75],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。","2025\u002F2\u002F17",[78,80,81],[14,79],"scratch3",[17,18],[20,82],"learning",{"slug":84,"title":85,"description":86,"date":90,"tags":91},"chicken-parkour","小鸡跑酷",[87,88,89],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[92,93,94],[14,79],[17,18],[20,21],{"slug":96,"title":97,"description":98,"date":102,"tags":103},"scratch-language","Scratch-Language",[99,100,101],"用Python为Scratch做的编程语言。","编译成品为Scratch可直接识别的project.json。","已经支持基本的编程语法。","2024\u002F8\u002F25",[104,105,106],[14,55],[17,18],[20,34],{"slug":108,"title":109,"description":110,"date":114,"tags":115},"fast-collection","快速添加到收藏夹",[111,112,113],"这是一个 Chrome 浏览器插件，需要开启开发者模式导入该插件，在 B 站视频中就可以快速添加到收藏夹。","快速添加到收藏夹：根据B站视频的标签自动创建并匹配收藏夹。","原理：通过 JS 脚本操作 DOM 元素，模拟点击按钮和输入，实现快速添加到收藏夹。","2024\u002F12\u002F5",[116,117,118],[14,15],[17,18],[20,34],{"slug":120,"title":121,"description":122,"date":125,"tags":126},"characters-drawing","字符画",[123,124],"Python制作的字符画程序，可以把图片用字符显示出来。","使用方法：安装pillow库，在相同目录放置字体font.ttf","2024\u002F11\u002F9",[127,128,129],[14,55],[17,18],[20,130],"art",1779597318457]
[{"data":1,"prerenderedAt":84},["ShallowReactive",2],{"tag-lang-scratch3":3},[4,22,35,47,60,72],{"slug":5,"title":6,"description":7,"date":11,"tags":12},"life-game","Scratch 生命游戏",[8,9,10],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。","2025\u002F7\u002F20",[13,16,19],[14,15],"lang","scratch3",[17,18],"inspiration","adaptation",[20,21],"content","art",{"slug":23,"title":24,"description":25,"date":29,"tags":30},"oh-my-dear-js","Oh my dear JavaScript",[26,27,28],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[31,32,33],[14,15],[17,18],[20,34],"entertainment",{"slug":36,"title":37,"description":38,"date":42,"tags":43},"numbers-eating-game","大数吃小数游戏",[39,40,41],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[44,45,46],[14,15],[17,18],[20,34],{"slug":48,"title":49,"description":50,"date":42,"tags":54},"utf-16-supporting","Scratch支持UTF-16",[51,52,53],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。",[55,56,58],[14,15],[17,57],"original",[20,59],"learning",{"slug":61,"title":62,"description":63,"date":67,"tags":68},"chicken-parkour","小鸡跑酷",[64,65,66],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[69,70,71],[14,15],[17,57],[20,34],{"slug":73,"title":74,"description":75,"date":79,"tags":80},"click-ta","点击Ta!",[76,77,78],"点击Ta！升级，然后再次点击Ta！","这是一个点击游戏，点击角色赚取金币。在商店中购买升级道具。","从零开始，获取99999999金币，通关游戏！","2024\u002F8\u002F23",[81,82,83],[14,15],[17,18],[20,34],1778904103867]
[{"data":1,"prerenderedAt":107},["ShallowReactive",2],{"tag-lang-scratch3":3},[4,22,34,47,59,72,84,95],{"title":5,"description":6,"date":10,"tags":11,"path":21},"Scratch生命游戏",[7,8,9],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。","2025\u002F7\u002F20",[12,15,18],[13,14],"lang","scratch3",[16,17],"inspiration","adaptation",[19,20],"content","art","\u002Fpages\u002Flife-game",{"title":23,"description":24,"date":27,"tags":28,"path":33},"动画计算器",[25,26],"支持多种运算格式，负数，小数。用户操作有非线性的流畅动效。支持识别常见语法错误，计算错误。","纯Scratch实现，利用到栈，递归等技巧，实时显示运算结果。","2025\u002F4\u002F29",[29,30,31],[13,14],[16,17],[19,32],"tool","\u002Fpages\u002Fanimated-calculator",{"title":35,"description":36,"date":40,"tags":41,"path":46},"Oh my dear JavaScript",[37,38,39],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[42,43,44],[13,14],[16,17],[19,45],"entertainment","\u002Fpages\u002Foh-my-dear-js",{"title":48,"description":49,"date":53,"tags":54,"path":58},"大数吃小数游戏",[50,51,52],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[55,56,57],[13,14],[16,17],[19,45],"\u002Fpages\u002Fnumbers-eating-game",{"title":60,"description":61,"date":53,"tags":65,"path":71},"Scratch支持UTF-16",[62,63,64],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。",[66,67,69],[13,14],[16,68],"original",[19,70],"learning","\u002Fpages\u002Futf-16-supporting",{"title":73,"description":74,"date":78,"tags":79,"path":83},"小鸡跑酷",[75,76,77],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[80,81,82],[13,14],[16,68],[19,45],"\u002Fpages\u002Fchicken-parkour",{"title":85,"description":86,"date":89,"tags":90,"path":94},"切水果",[87,88],"Scratch休闲游戏，键盘操作简单易上手，切水果感受舒适爽感，多种升级可用。","在升级的加持下，切碎上千水果，通关游戏！","2025\u002F1\u002F24",[91,92,93],[13,14],[16,17],[19,45],"\u002Fpages\u002Fcut-fruit",{"title":96,"description":97,"date":101,"tags":102,"path":106},"点击Ta!",[98,99,100],"点击Ta！升级，然后再次点击Ta！","这是一个点击游戏，点击角色赚取金币。在商店中购买升级道具。","从零开始，获取99999999金币，通关游戏！","2024\u002F8\u002F23",[103,104,105],[13,14],[16,17],[19,45],"\u002Fpages\u002Fclick-ta",1782302454622]
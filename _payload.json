[{"data":1,"prerenderedAt":247},["ShallowReactive",2],{"pages-all":3},[4,22,35,50,62,73,86,97,108,120,132,143,153,165,177,189,200,212,224,236],{"title":5,"description":6,"date":10,"tags":11,"path":21},"猜词游戏",[7,8,9],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。","2026\u002F5\u002F20",[12,15,18],[13,14],"lang","web",[16,17],"inspiration","original",[19,20],"content","entertainment","\u002Fpages\u002Fguess-the-word",{"title":23,"description":24,"date":28,"tags":29,"path":34},"Village of Chaos",[25,26,27],"简短文字放置游戏，原生JS编写，轻松挂机发展村庄。","支持多语言切换，覆盖中文简繁体。","完全免费在线游玩，无需下载即开即玩。","2026\u002F3\u002F6",[30,31,33],[13,14],[16,32],"localization",[19,20],"\u002Fpages\u002Fvillage-of-chaos",{"title":36,"description":37,"date":41,"tags":42,"path":49},"谷歌翻译十遍（语言包）",[38,39,40],"该资源包添加一种语言，名叫“中文（谷歌翻译十遍）”。","其文本使用谷歌翻译，从英文开始，在随机语言间翻译，最后出现一些滑稽的翻译结果。","支持Minecraft 1.21.9。","2026\u002F2\u002F13",[43,45,47],[13,44],"minecraft",[16,46],"adaptation",[19,48],"art","\u002Fpages\u002Fgoogle-10",{"title":51,"description":52,"date":55,"tags":56,"path":61},"禁用矿石烧炼",[53,54],"该数据包会禁用部分会浪费的矿石烧炼配方。","支持1.13+的主流版本，在Modrinth上发布。","2025\u002F8\u002F25",[57,58,59],[13,44],[16,17],[19,60],"tool","\u002Fpages\u002Fdisable-ore-smelting",{"title":63,"description":64,"date":67,"tags":68,"path":72},"2^1024 Loops",[65,66],"2^1024 Loops 是由 MrRedShark77 在 GMTK Game Jam 2025 上制作的游戏。游戏的目标是通过编程，达到 2^1024（约 1.8x10^308）。","本文章提供游戏相关教程和攻略。","2025\u002F8\u002F14",[69,70,71],[13,14],[16,32],[19,20],"\u002Fpages\u002Floop-jam",{"title":74,"description":75,"date":79,"tags":80,"path":85},"Scratch生命游戏",[76,77,78],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。","2025\u002F7\u002F20",[81,83,84],[13,82],"scratch3",[16,46],[19,48],"\u002Fpages\u002Flife-game",{"title":87,"description":88,"date":91,"tags":92,"path":96},"动画计算器",[89,90],"支持多种运算格式，负数，小数。用户操作有非线性的流畅动效。支持识别常见语法错误，计算错误。","纯Scratch实现，利用到栈，递归等技巧，实时显示运算结果。","2025\u002F4\u002F29",[93,94,95],[13,82],[16,46],[19,60],"\u002Fpages\u002Fanimated-calculator",{"title":98,"description":99,"date":102,"tags":103,"path":107},"单词接龙",[100,101],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[104,105,106],[13,14],[16,17],[19,20],"\u002Fpages\u002Fword-solitaire",{"title":109,"description":110,"date":113,"tags":114,"path":119},"文件消消乐",[111,112],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[115,117,118],[13,116],"python3",[16,17],[19,20],"\u002Fpages\u002Ffile-matchmaking",{"title":121,"description":122,"date":126,"tags":127,"path":131},"Oh my dear JavaScript",[123,124,125],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[128,129,130],[13,82],[16,46],[19,20],"\u002Fpages\u002Foh-my-dear-js",{"title":133,"description":134,"date":137,"tags":138,"path":142},"XXXX 论证器",[135,136],"这个小程序复制了以 MIT License 开源的 https:\u002F\u002Fgithub.com\u002Fitorr\u002Fhomo 代码。","可论证任何数字为 5277 和 7725。","2025\u002F2\u002F3",[139,140,141],[13,14],[16,46],[19,60],"\u002Fpages\u002Fdemonstrator",{"title":144,"description":145,"date":137,"tags":148,"path":152},"“找规律”",[146,147],"Python程序，可以通过多项式拟合几乎任意的数列，即\"找规律\"。","原理是一种类似于拉格朗日插值的算法。",[149,150,151],[13,116],[16,17],[19,60],"\u002Fpages\u002Ffind-patterns",{"title":154,"description":155,"date":159,"tags":160,"path":164},"大数吃小数游戏",[156,157,158],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[161,162,163],[13,82],[16,46],[19,20],"\u002Fpages\u002Fnumbers-eating-game",{"title":166,"description":167,"date":159,"tags":171,"path":176},"Scratch支持UTF-16",[168,169,170],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。",[172,173,174],[13,82],[16,17],[19,175],"learning","\u002Fpages\u002Futf-16-supporting",{"title":178,"description":179,"date":183,"tags":184,"path":188},"小鸡跑酷",[180,181,182],"基于Scratch风格的横版跑酷游戏，控
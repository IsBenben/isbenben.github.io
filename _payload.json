[{"data":1,"prerenderedAt":247},["ShallowReactive",2],{"home":3},[4,22,35,50,62,73,86,97,108,120,132,143,153,165,177,189,200,212,224,236],{"slug":5,"title":6,"description":7,"date":11,"tags":12},"guess-the-word","猜词游戏",[8,9,10],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。","2026\u002F5\u002F20",[13,16,19],[14,15],"lang","web",[17,18],"inspiration","original",[20,21],"content","entertainment",{"slug":23,"title":24,"description":25,"date":29,"tags":30},"village-of-chaos","Village of Chaos",[26,27,28],"简短文字放置游戏，原生JS编写，轻松挂机发展村庄。","支持多语言切换，覆盖中文简繁体。","完全免费在线游玩，无需下载即开即玩。","2026\u002F3\u002F6",[31,32,34],[14,15],[17,33],"localization",[20,21],{"slug":36,"title":37,"description":38,"date":42,"tags":43},"google-10","谷歌翻译十遍（语言包）",[39,40,41],"该资源包添加一种语言，名叫“中文（谷歌翻译十遍）”。","其文本使用谷歌翻译，从英文开始，在随机语言间翻译，最后出现一些滑稽的翻译结果。","支持Minecraft 1.21.9。","2026\u002F2\u002F13",[44,46,48],[14,45],"minecraft",[17,47],"adaptation",[20,49],"art",{"slug":51,"title":52,"description":53,"date":56,"tags":57},"disable-ore-smelting","禁用矿石烧炼",[54,55],"该数据包会禁用部分会浪费的矿石烧炼配方。","支持1.13+的主流版本，在Modrinth上发布。","2025\u002F8\u002F25",[58,59,60],[14,45],[17,18],[20,61],"tool",{"slug":63,"title":64,"description":65,"date":68,"tags":69},"loop-jam","2^1024 Loops",[66,67],"2^1024 Loops 是由 MrRedShark77 在 GMTK Game Jam 2025 上制作的游戏。游戏的目标是通过编程，达到 2^1024（约 1.8x10^308）。","本文章提供游戏相关教程和攻略。","2025\u002F8\u002F14",[70,71,72],[14,15],[17,33],[20,21],{"slug":74,"title":75,"description":76,"date":80,"tags":81},"life-game","Scratch 生命游戏",[77,78,79],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。","2025\u002F7\u002F20",[82,84,85],[14,83],"scratch3",[17,47],[20,49],{"slug":87,"title":88,"description":89,"date":92,"tags":93},"animated-calculator","动画计算器",[90,91],"支持多种运算格式，负数，小数。用户操作有非线性的流畅动效。支持识别常见语法错误，计算错误。","纯Scratch实现，利用到栈，递归等技巧，实时显示运算结果。","2025\u002F4\u002F29",[94,95,96],[14,83],[17,47],[20,61],{"slug":98,"title":99,"description":100,"date":103,"tags":104},"word-solitaire","单词接龙",[101,102],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[105,106,107],[14,15],[17,18],[20,21],{"slug":109,"title":110,"description":111,"date":114,"tags":115},"file-matchmaking","文件消消乐",[112,113],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[116,118,119],[14,117],"python3",[17,18],[20,21],{"slug":121,"title":122,"description":123,"date":127,"tags":128},"oh-my-dear-js","Oh my dear JavaScript",[124,125,126],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[129,130,131],[14,83],[17,47],[20,21],{"slug":133,"title":134,"description":135,"date":138,"tags":139},"demonstrator","XXXX 论证器",[136,137],"这个小程序复制了以 MIT License 开源的 https:\u002F\u002Fgithub.com\u002Fitorr\u002Fhomo 代码。","可论证任何数字为 5277 和 7725。","2025\u002F2\u002F3",[140,141,142],[14,15],[17,47],[20,61],{"slug":144,"title":145,"description":146,"date":138,"tags":149},"find-patterns","“找规律”",[147,148],"Python程序，可以通过多项式拟合几乎任意的数列，即\"找规律\"。","原理是一种类似于拉格朗日插值的算法。",[150,151,152],[14,117],[17,18],[20,61],{"slug":154,"title":155,"description":156,"date":160,"tags":161},"numbers-eating-game","大数吃小数游戏",[157,158,159],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[162,163,164],[14,83],[17,47],[20,21],{"slug":166,"title":167,"description":168,"date":160,"tags":172},"utf-16-supporting","Scratch支持UTF-16",[169,170,171],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。",[173,174,175],[14,83],[17,18],[20,176],"learning",{"slug":178,"title":179,"description":180,"date":184,"tags":185},"chicken-parkour","小鸡跑酷",[181,182,183],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[186,187,188],[14,83],[17,18],[20,21],{"slug":190,"title":191,"description":192,"date":195,"tags":196},"cut-fruit",
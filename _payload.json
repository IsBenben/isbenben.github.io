[{"data":1,"prerenderedAt":213},["ShallowReactive",2],{"home":3},[4,22,37,50,61,74,85,97,109,120,130,142,154,166,178,190,202],{"slug":5,"title":6,"description":7,"date":11,"tags":12},"village-of-chaos","Village of Chaos",[8,9,10],"简短文字放置游戏，原生JS编写，轻松挂机发展村庄。","支持多语言切换，覆盖中文简繁体。","完全免费在线游玩，无需下载即开即玩。","2026\u002F3\u002F6",[13,16,19],[14,15],"lang","web",[17,18],"inspiration","localization",[20,21],"content","entertainment",{"slug":23,"title":24,"description":25,"date":29,"tags":30},"google-10","谷歌翻译十遍（语言包）",[26,27,28],"该资源包添加一种语言，名叫“中文（谷歌翻译十遍）”。","其文本使用谷歌翻译，从英文开始，在随机语言间翻译，最后出现一些滑稽的翻译结果。","支持Minecraft 1.21.9。","2026\u002F2\u002F13",[31,33,35],[14,32],"minecraft",[17,34],"adaptation",[20,36],"art",{"slug":38,"title":39,"description":40,"date":43,"tags":44},"disable-ore-smelting","禁用矿石烧炼",[41,42],"该数据包会禁用部分会浪费的矿石烧炼配方。","支持1.13+的主流版本，在Modrinth上发布。","2025\u002F8\u002F25",[45,46,48],[14,32],[17,47],"original",[20,49],"tool",{"slug":51,"title":52,"description":53,"date":56,"tags":57},"loop-jam","2^1024 Loops",[54,55],"2^1024 Loops 是由 MrRedShark77 在 GMTK Game Jam 2025 上制作的游戏。游戏的目标是通过编程，达到 2^1024（约 1.8x10^308）。","本文章提供游戏相关教程和攻略。","2025\u002F8\u002F14",[58,59,60],[14,15],[17,18],[20,21],{"slug":62,"title":63,"description":64,"date":68,"tags":69},"life-game","Scratch 生命游戏",[65,66,67],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。","2025\u002F7\u002F20",[70,72,73],[14,71],"scratch3",[17,34],[20,36],{"slug":75,"title":76,"description":77,"date":80,"tags":81},"word-solitaire","单词接龙",[78,79],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。","2025\u002F3\u002F7",[82,83,84],[14,15],[17,47],[20,21],{"slug":86,"title":87,"description":88,"date":91,"tags":92},"file-matchmaking","文件消消乐",[89,90],"这个程序会帮你创建很多文件，删除的文件会被重新创建。","删除的越多得分越多。","2025\u002F3\u002F1",[93,95,96],[14,94],"python3",[17,47],[20,21],{"slug":98,"title":99,"description":100,"date":104,"tags":105},"oh-my-dear-js","Oh my dear JavaScript",[101,102,103],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。","2025\u002F2\u002F9",[106,107,108],[14,71],[17,34],[20,21],{"slug":110,"title":111,"description":112,"date":115,"tags":116},"demonstrator","XXXX 论证器",[113,114],"这个小程序复制了以 MIT License 开源的 https:\u002F\u002Fgithub.com\u002Fitorr\u002Fhomo 代码。","可论证任何数字为 5277 和 7725。","2025\u002F2\u002F3",[117,118,119],[14,15],[17,34],[20,49],{"slug":121,"title":122,"description":123,"date":115,"tags":126},"find-patterns","“找规律”",[124,125],"Python程序，可以通过多项式拟合几乎任意的数列，即\"找规律\"。","原理是一种类似于拉格朗日插值的算法。",[127,128,129],[14,94],[17,47],[20,49],{"slug":131,"title":132,"description":133,"date":137,"tags":138},"numbers-eating-game","大数吃小数游戏",[134,135,136],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！","2025\u002F2\u002F17",[139,140,141],[14,71],[17,34],[20,21],{"slug":143,"title":144,"description":145,"date":137,"tags":149},"utf-16-supporting","Scratch支持UTF-16",[146,147,148],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。",[150,151,152],[14,71],[17,47],[20,153],"learning",{"slug":155,"title":156,"description":157,"date":161,"tags":162},"chicken-parkour","小鸡跑酷",[158,159,160],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。","2025\u002F2\u002F10",[163,164,165],[14,71],[17,47],[20,21],{"slug":167,"title":168,"description":169,"date":173,"tags":174},"scratch-language","Scratch-Language",[170,171,172],"用Python为Scratch做的编程语言。","编译成品为Scratch可直接识别的project.json。","已经支持基本的编程语法。","2024\u002F8\u002F25",[175,176,177],[14,94],[17,47],[20,49],{"slug":179,"title":180,"description":181,"date":185,"tags":186},"click-ta","点击Ta!",[182,183,184],"点击Ta！升级，然后再次点击Ta！","这是一个点击游戏，点击角色赚取金币。在商店中购买升级道具。","从零开始，获取99999999金币，通关游戏！","2024\u002F8\u002F23",[187,188,189],[14,71],[17,34],[20,21],{"slug":191,"title":192,"description":193,"date":197,"tags":198},"fast-collection","快速添加到收藏夹",[194,195,196],"这是一个 Chrome 浏览器插件，需要开启开发者模式导入该插件，在 B 站视频中就可以快速添加到收藏夹。","快速添加到收藏夹：根据B站视频的标签自动创建并匹配收藏夹。","原理：通过 JS 脚本操作 DOM 元素，模拟点击按钮和输入，实现快速添加到收藏夹。","2024\u002F12\u002F5",[199,200,201],[14,15],[17,47],[20,49],{"slug":203,"title":204,"description":205,"date":208,"tags":209},"characters-drawing","字符画",[206,207],"Python制作的字符画程序，可以把图片用字符显示出来。","使用方法：安装pillow库，在相同目录放置字体font.ttf","2024\u002F11\u002F9",[210,211,212],[14,94],[17,47],[20,36],1778904103719]
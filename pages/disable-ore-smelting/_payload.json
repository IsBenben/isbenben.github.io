2,123],"content","tool","YHY8rDkJzvdJjiAbh8VZZdjbYQO-r7fLxKiq6lBApss",{"id":126,"title":127,"body":128,"date":357,"description":358,"downloads":361,"extension":102,"hide":103,"links":362,"meta":380,"navigation":109,"path":381,"seo":382,"stem":384,"tags":385,"__hash__":392},"pages\u002Fpages\u002Floop-jam.md","2^1024 Loops",{"type":8,"value":129,"toc":347},[130,136,147,173,176,182,189,196,211,214,217,228,231,267,270,281,287,293,299,311,314],[11,131,127,133],{"id":132,"class":13},"_21024-loops",[15,134],{"class":17,"href":135},"#21024-loops",[20,137,138,139],{"id":138,"class":13},"游戏介绍",[15,140,142,145],{"class":17,"href":141},"#游戏介绍",[27,143,31],{"className":144},[30],[27,146,36],{"ariaHidden":34,"tabIndex":35},[38,148,149,151,152,158,159,164,165,168,169,172],{},[54,150,127],{}," 是由",[15,153,157],{"href":154,"rel":155},"https:\u002F\u002Fgithub.com\u002FMrRedShark77",[156],"nofollow","MrRedShark77","在",[15,160,163],{"href":161,"rel":162},"https:\u002F\u002Fgamemakerstoolkit.com\u002F",[156],"GMTK Game Jam 2025","上制作的游戏。游戏的目标是通过编程，达到 ",[54,166,167],{},"2^1024","（约 ",[54,170,171],{},"1.8x10^308","）。",[38,174,175],{},"通过鼠标操作，移动各种代码，拼接复杂的程序。说明见下图：",[38,177,178],{},[84,179],{"alt":180,"src":181},"2^1024 Loops编程增量游戏代码操作说明示意图","https:\u002F\u002Fisbenben.github.io\u002Floop-jam-cn\u002Ftextures\u002Fhelp.png",[38,183,184,185,188],{},"单击\"运行（Run）\"按钮可以运行代码，一次运行成为一个\"",[54,186,187],{},"loop","\"。会实时展现当前运行状态，再按一次可以加速（Fast）运行一整轮代码。",[38,190,191,192,195],{},"游戏有一个个目标（goal）：让",[54,193,194],{},"P","变量达到一个值。达到的值随游戏进程而增大。",[38,197,198,199,202,203,206,207,210],{},"在完成目标后，可以从",[54,200,201],{},"6","项奖励（Reward）中选择最多",[54,204,205],{},"3","项奖励。奖励有",[54,208,209],{},"5","个等级，获得概率递减。若找不到自己想要的奖励，可以使用 3 次\"重掷（Reroll）\"机会，生成新的 6 项奖励。选择奖励代码后，可以在后续的 loop 中使用。",[38,212,213],{},"在达到 2^1024 后，还可以选择开启无尽模式（Endless Mode）。无尽模式顾名思义，没有真正的结束，但是你可以无限挑战自己的 P，冲向属于你的极限。",[38,215,216],{},"游戏还有一些成就（Achievement）等着你去挑战！",[20,218,219,220],{"id":219,"class":13},"插件介绍",[15,221,223,226],{"class":17,"href":222},"#插件介绍",[27,224,31],{"className":225},[30],[27,227,36],{"ariaHidden":34,"tabIndex":35},[38,229,230],{},"插件由我制作，提供五个可自由开关的功能：",[45,232,233,243,249,255,261],{},[48,234,235,238,239,242],{},[51,236,237],{},"使用弃用的奖励算法：","打开原作者注释掉的奖励算法。代码片段：",[54,240,241],{},"j === 2 ? 1 \u002F Math.max(200, 1000 \u002F player.nextP.add(9).log10().cbrt()) :","。",[48,244,245,248],{},[51,246,247],{},"现代化样式：","启用现代化样式，包括弹框动画，图标修复，滚动条样式，圆角槽位等杂项修改。",[48,250,251,254],{},[51,252,253],{},"无限重掷：","有无限次\"重掷（Reroll）\"机会。",[48,256,257,260],{},[51,258,259],{},"获得无限块：","用于测试，启用后无限获得奖励块。",[48,262,263,266],{},[51,264,265],{},"排序物品栏：","自动排序物品栏。数字，运算符，变量等均可自动排序。",[38,268,269],{},"插件的设置会保存在玩家数据中，默认启用现代化样式和排序物品栏。",[20,271,272,273],{"id":272,"class":13},"截图",[15,274,276,279],{"class":17,"href":275},"#截图",[27,277,31],{"className":278},[30],[27,280,36],{"ariaHidden":34,"tabIndex":35},[38,282,283],{},[84,284],{"alt":285,"src":286},"2^1024 Loops编程增量游戏主菜单截图","\u002Fraw\u002Floop-jam-main-menu.png",[38,288,289],{},[84,290],{"alt":291,"src":292},"2^1024 Loops编程增量游戏选择奖励界面截图","\u002Fraw\u002Floop-jam-choosing-rewards.png",[38,294,295],{},[84,296],{"alt":297,"src":298},"2^1024 Loops编程增量游戏成就界面截图","\u002Fraw\u002Floop-jam-achivements.png",[20,300,302,303],{"id":301,"class":13},"license","License",[15,304,306,309],{"class":17,"href":305},"#license",[27,307,31],{"className":308},[30],[27,310,36],{"ariaHidden":34,"tabIndex":35},[38,312,313],{},"源代码改编以 MIT License 许可。",[38,315,316,317,321,322,326,327,331,332,336,337,341,342,346],{},"外部库引用：Lodash.js (",[15,318,302],{"href":319,"rel":320},"https:\u002F\u002Fgithub.com\u002Flodash\u002Flodash\u002Fblob\u002Fmain\u002FLICENSE",[156],") | Vue.js (",[15,323,302],{"href":324,"rel":325},"https:\u002F\u002Fgithub.com\u002Fvuejs\u002Fvue\u002Fblob\u002Fmain\u002FLICENSE",[156],") | Noto Sans SC (",[15,328,302],{"href":329,"rel":330},"https:\u002F\u002Fgithub.com\u002Fnotofonts\u002Fnoto-fonts\u002Fblob\u002Fmain\u002FLICENSE",[156],") | Google Sans Code (",[15,333,302],{"href":334,"rel":335}
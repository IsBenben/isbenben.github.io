[{"data":1,"prerenderedAt":326},["ShallowReactive",2],{"article-\u002Fpages\u002Fanimated-calculator":3},{"id":4,"title":5,"body":6,"date":295,"description":296,"downloads":299,"extension":303,"hide":304,"links":305,"meta":309,"navigation":310,"path":311,"seo":312,"stem":314,"tags":315,"__hash__":325},"pages\u002Fpages\u002Fanimated-calculator.md","动画计算器",{"type":7,"value":8,"toc":280},"minimark",[9,18,36,103,114,183,194,202,229,240,262,273],[10,11,5,13],"h1",{"id":5,"class":12},"section-heading",[14,15],"a",{"class":16,"href":17},"section-link","#动画计算器",[19,20,21,22],"h2",{"id":21,"class":12},"运算能力",[14,23,25,31],{"class":16,"href":24},"#运算能力",[26,27,30],"span",{"className":28},[29],"visually-hidden","章节",[26,32,35],{"ariaHidden":33,"tabIndex":34},"true",-1," §",[37,38,39,52,70,80,90],"ul",{},[40,41,42,46,47,51],"li",{},[43,44,45],"strong",{},"基础运算","：支持 ",[48,49,50],"code",{},"+-*\u002F"," 四则运算，遵循标准优先级（先乘除后加减）。",[40,53,54,57,58,61,62,65,66,69],{},[43,55,56],{},"幂运算","：使用 ",[48,59,60],{},"^"," 符号表示乘方，优先级高于乘除，右结合（如 ",[48,63,64],{},"2^3^2"," = ",[48,67,68],{},"2^(3^2)","）。",[40,71,72,75,76,79],{},[43,73,74],{},"括号支持","：允许任意嵌套的 ",[48,77,78],{},"()"," 括号，改变运算顺序。",[40,81,82,85,86,89],{},[43,83,84],{},"负数处理","：支持负号直接输入（如 ",[48,87,88],{},"5+-3"," 解析为 5 + (-3)），也支持负数作为表达式起始。",[40,91,92,95,96,99,100,69],{},[43,93,94],{},"缩写输入","：小数点前后可省略 0（如输入 ",[48,97,98],{},".5"," 自动补全为 ",[48,101,102],{},"0.5",[19,104,105,106],{"id":105,"class":12},"交互体验",[14,107,109,112],{"class":16,"href":108},"#交互体验",[26,110,30],{"className":111},[29],[26,113,35],{"ariaHidden":33,"tabIndex":34},[37,115,116,149,171,177],{},[40,117,118,121,122,125,126,129,130,133,134,136,137,140,141,144,145,148],{},[43,119,120],{},"按键输入","：提供数字键 ",[48,123,124],{},"0-9","、小数点 ",[48,127,128],{},".","、运算符 ",[48,131,132],{},"+-*\u002F^","、括号 ",[48,135,78],{},"、退格 ",[48,138,139],{},"\u003C","、清空 ",[48,142,143],{},"AC","、等于 ",[48,146,147],{},"=","。",[40,150,151,154,155],{},[43,152,153],{},"光标操作","：\n",[37,156,157,168],{},[40,158,159,160,163,164,167],{},"支持 ",[48,161,162],{},"←"," ",[48,165,166],{},"→"," 移动光标，可在表达式任意位置插入\u002F删除。",[40,169,170],{},"光标移动带有非线性缓动动画，视觉反馈柔和。",[40,172,173,176],{},[43,174,175],{},"长按支持","：退格键长按可连续快速删除；数字和运算符长按可重复输入。",[40,178,179,182],{},[43,180,181],{},"动效要求","：所有按键按下时有缩放反馈；光标移动具有缓动效果。",[19,184,185,186],{"id":185,"class":12},"核心算法实现",[14,187,189,192],{"class":16,"href":188},"#核心算法实现",[26,190,30],{"className":191},[29],[26,193,35],{"ariaHidden":33,"tabIndex":34},[195,196,197,198,201],"p",{},"解析策略采用 ",[43,199,200],{},"递归下降 + 结果栈","解析表达式字符串。",[203,204,205,211,217,223],"ol",{},[40,206,207,210],{},[43,208,209],{},"词法分析","：将输入字符串拆解为 Token（数字、运算符、括号、负号标记）。",[40,212,213,216],{},[43,214,215],{},"数值计算","：树形遍历Token，执行运算。遇到除零、NaN、无穷大等异常时，停止递归并抛出错误。",[40,218,219,222],{},[43,220,221],{},"回溯机制","：若计算过程中某节点失败，则向上回溯，将整个表达式标记为无效，并清空栈顶中间结果。",[40,224,225,228],{},[43,226,227],{},"最终输出","：成功解析且无错误时，栈顶即为最终计算结果；否则反馈错误信息。",[19,230,231,232],{"id":231,"class":12},"错误处理与用户反馈",[14,233,235,238],{"class":16,"href":234},"#错误处理与用户反馈",[26,236,30],{"className":237},[29],[26,239,35],{"ariaHidden":33,"tabIndex":34},[37,241,242,248,254],{},[40,243,244,247],{},[43,245,246],{},"实时检查","：输入时动态显示错误消息。",[40,249,250,253],{},[43,251,252],{},"计算错误提示","：语法错误如括号不匹配、Token解析错误，数字格式错误分别显示不同消息。",[40,255,256,261],{},[43,257,258],{},[48,259,260],{},"NaN","：针对常见除0，Infinity加减除等运算错误自动识别。",[19,263,264,265],{"id":264,"class":12},"截图",[14,266,268,271],{"class":16,"href":267},"#截图",[26,269,30],{"className":270},[29],[26,272,35],{"ariaHidden":33,"tabIndex":34},[195,274,275],{},[276,277],"img",{"alt":278,"src":279},"使用Scratch动画计算器计算嵌套表达式","\u002Fraw\u002Fanimated-calculator-screenshot.png",{"title":281,"searchDepth":282,"depth":283,"links":284},"",2,3,[285,287,289,291,293],{"id":21,"depth":282,"text":286},"运算能力章节 §",{"id":105,"depth":282,"text":288},"交互体验章节 §",{"id":185,"depth":282,"text":290},"核心算法实现章节 §",{"id":231,"depth":282,"text":292},"错误处理与用户反馈章节 §",{"id":264,"depth":282,"text":294},"截图章节 §","2025\u002F4\u002F29",[297,298],"支持多种运算格式，负数，小数。用户操作有非线性的流畅动效。支持识别常见语法错误，计算错误。","纯Scratch实现，利用到栈，递归等技巧，实时显示运算结果。",[300],[301,302],"\u002Fraw\u002Fanimated-calculator.sb3","下载","md",false,[306],[307,308],"\u002Fraw\u002Fanimated-calculator.html","体验",{},true,"\u002Fpages\u002Fanimated-calculator",{"title":5,"description":313},[297,298],"pages\u002Fanimated-calculator",[316,319,322],[317,318],"lang","scratch3",[320,321],"inspiration","adaptation",[323,324],"content","tool","_nTglyDPeATIS-5jZLhXI9hVI4FFvNJopT0wLIjHy3E",1781179807510]
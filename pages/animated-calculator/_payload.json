[{"data":1,"prerenderedAt":686},["ShallowReactive",2],{"article-\u002Fpages\u002Fanimated-calculator":3},{"current":4,"prev":328,"next":480},{"id":5,"title":6,"body":7,"date":297,"description":298,"downloads":301,"extension":305,"hide":306,"links":307,"meta":311,"navigation":312,"path":313,"seo":314,"stem":316,"tags":317,"__hash__":327},"pages\u002Fpages\u002Fanimated-calculator.md","动画计算器",{"type":8,"value":9,"toc":282},"minimark",[10,19,37,104,115,185,196,204,231,242,264,275],[11,12,6,14],"h1",{"id":6,"class":13},"section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#动画计算器",[20,21,22,23],"h2",{"id":22,"class":13},"运算能力",[15,24,26,32],{"class":17,"href":25},"#运算能力",[27,28,31],"span",{"className":29},[30],"visually-hidden","章节",[27,33,36],{"ariaHidden":34,"tabIndex":35},"true",-1," §",[38,39,40,53,71,81,91],"ul",{},[41,42,43,47,48,52],"li",{},[44,45,46],"strong",{},"基础运算","：支持 ",[49,50,51],"code",{},"+-*\u002F"," 四则运算，遵循标准优先级（先乘除后加减）。",[41,54,55,58,59,62,63,66,67,70],{},[44,56,57],{},"幂运算","：使用 ",[49,60,61],{},"^"," 符号表示乘方，优先级高于乘除，右结合（如 ",[49,64,65],{},"2^3^2"," = ",[49,68,69],{},"2^(3^2)","）。",[41,72,73,76,77,80],{},[44,74,75],{},"括号支持","：允许任意嵌套的 ",[49,78,79],{},"()"," 括号，改变运算顺序。",[41,82,83,86,87,90],{},[44,84,85],{},"负数处理","：支持负号直接输入（如 ",[49,88,89],{},"5+-3"," 解析为 5 + (-3)），也支持负数作为表达式起始。",[41,92,93,96,97,100,101,70],{},[44,94,95],{},"小数缩写","：小数点前后可省略 0（如输入 ",[49,98,99],{},".5"," 自动补全为 ",[49,102,103],{},"0.5",[20,105,106,107],{"id":106,"class":13},"交互体验",[15,108,110,113],{"class":17,"href":109},"#交互体验",[27,111,31],{"className":112},[30],[27,114,36],{"ariaHidden":34,"tabIndex":35},[38,116,117,158,179],{},[41,118,119,122,123],{},[44,120,121],{},"按键输入","：\n",[38,124,125,155],{},[41,126,127,128,131,132,135,136,139,140,142,143,146,147,150,151,154],{},"提供数字键 ",[49,129,130],{},"0-9","、小数点 ",[49,133,134],{},".","、运算符 ",[49,137,138],{},"+-*\u002F^","、括号 ",[49,141,79],{},"、退格 ",[49,144,145],{},"\u003C","、清空 ",[49,148,149],{},"AC","、等于 ",[49,152,153],{},"=","。",[41,156,157],{},"支持按键连输，退格键长按可连续快速删除；数字和运算符长按可重复输入。",[41,159,160,122,163],{},[44,161,162],{},"光标移动",[38,164,165,176],{},[41,166,167,168,171,172,175],{},"支持 ",[49,169,170],{},"←"," ",[49,173,174],{},"→"," 移动光标，可在表达式任意位置插入\u002F删除。",[41,177,178],{},"光标移动带有非线性缓动动画，视觉反馈柔和。",[41,180,181,184],{},[44,182,183],{},"流畅动效","：所有按键按下时有缩放反馈；光标移动具有缓动效果。",[20,186,187,188],{"id":187,"class":13},"核心算法实现",[15,189,191,194],{"class":17,"href":190},"#核心算法实现",[27,192,31],{"className":193},[30],[27,195,36],{"ariaHidden":34,"tabIndex":35},[197,198,199,200,203],"p",{},"解析策略采用",[44,201,202],{},"递归下降 + 结果栈","解析表达式字符串。",[205,206,207,213,219,225],"ol",{},[41,208,209,212],{},[44,210,211],{},"词法分析","：将输入字符串拆解为Token（数字、运算符、括号、负号标记）。",[41,214,215,218],{},[44,216,217],{},"数值计算","：树形遍历Token，执行运算。遇到除零、NaN、无穷大等异常时，停止递归并抛出错误。",[41,220,221,224],{},[44,222,223],{},"递归回溯","：若计算过程中某节点失败，则向上回溯，将整个表达式标记为无效，并清空栈顶中间结果。",[41,226,227,230],{},[44,228,229],{},"最终输出","：成功解析且无错误时，栈顶即为最终计算结果；否则反馈错误信息。",[20,232,233,234],{"id":233,"class":13},"错误处理与用户反馈",[15,235,237,240],{"class":17,"href":236},"#错误处理与用户反馈",[27,238,31],{"className":239},[30],[27,241,36],{"ariaHidden":34,"tabIndex":35},[38,243,244,250,256],{},[41,245,246,249],{},[44,247,248],{},"实时检查","：输入时动态显示错误消息。",[41,251,252,255],{},[44,253,254],{},"计算错误提示","：语法错误如括号不匹配、Token解析错误，数字格式错误分别显示不同消息。",[41,257,258,263],{},[44,259,260],{},[49,261,262],{},"NaN","：针对常见除0，Infinity加减除等运算错误自动识别。",[20,265,266,267],{"id":266,"class":13},"截图",[15,268,270,273],{"class":17,"href":269},"#截图",[27,271,31],{"className":272},[30],[27,274,36],{"ariaHidden":34,"tabIndex":35},[197,276,277],{},[278,279],"img",{"alt":280,"src":281},"使用Scratch动画计算器计算嵌套表达式","\u002Fraw\u002Fanimated-calculator-screenshot.png",{"title":283,"searchDepth":284,"depth":285,"links":286},"",2,3,[287,289,291,293,295],{"id":22,"depth":284,"text":288},"运算能力章节 §",{"id":106,"depth":284,"text":290},"交互体验章节 §",{"id":187,"depth":284,"text":292},"核心算法实现章节 §",{"id":233,"depth":284,"text":294},"错误处理与用户反馈章节 §",{"id":266,"depth":284,"text":296},"截图章节 §","2025\u002F04\u002F29",[299,300],"支持多种运算格式，负数，小数。用户操作有非线性的流畅动效。支持识别常见语法错误，计算错误。","纯Scratch实现，利用到栈，递归等技巧，实时显示运算结果。",[302],[303,304],"\u002Fraw\u002Fanimated-calculator.sb3","下载","md",false,[308],[309,310],"\u002Fraw\u002Fanimated-calculator.html","体验",{},true,"\u002Fpages\u002Fanimated-calculator",{"title":6,"description":315},[299,300],"pages\u002Fanimated-calculator",[318,321,324],[319,320],"lang","scratch3",[322,323],"inspiration","adaptation",[325,326],"content","tool","Vf-LhRBOJhRGajg7_lnDJgHeZS5oQOfaP9kmOaSD55k",{"id":329,"title":330,"body":331,"date":455,"description":456,"downloads":459,"extension":305,"hide":306,"links":462,"meta":467,"navigation":312,"path":468,"seo":469,"stem":471,"tags":472,"__hash__":479},"pages\u002Fpages\u002Fword-solitaire.md","单词接龙",{"type":8,"value":332,"toc":446},[333,338,341,352,378,381,390,401,404,407,414,425,428,431,440],[11,334,330,335],{"id":330,"class":13},[15,336],{"class":17,"href":337},"#单词接龙",[197,339,340],{},"单词接龙是一个经典的文字游戏，玩家需要根据前一个单词的尾字母，找到一个以该字母开头的新单词。这个网页版游戏支持 AI 辅助和单词释义查询。",[20,342,343,344],{"id":343,"class":13},"基本规则",[15,345,347,350],{"class":17,"href":346},"#基本规则",[27,348,31],{"className":349},[30],[27,351,36],{"ariaHidden":34,"tabIndex":35},[38,353,354,360,366,372],{},[41,355,356,359],{},[44,357,358],{},"首尾相接","：新单词的首字母需要和前一个单词的尾字母完全相同。",[41,361,362,365],{},[44,363,364],{},"单词有效","：单词必须在游戏字典中，否则无效。",[41,367,368,371],{},[44,369,370],{},"无重复","：同一个单词在一轮游戏中不能重复使用。",[41,373,374,377],{},[44,375,376],{},"大小写敏感","：只有小写字母被接受。",[197,379,380],{},"示例如下：",[382,383,388],"pre",{"className":384,"code":386,"language":387},[385],"language-text","apple->elephant->tiger->rabbit\n  ->monkey（首尾不相接，无效）\n  ->tiger (重复，无效)\n  ->ttt（不在字典中，无效）\n  ->TURKEY（大小写错误，无效）\n  ->turkey（正确接龙）\n","text",[49,389,386],{"__ignoreMap":283},[20,391,392,393],{"id":392,"class":13},"操作方法",[15,394,396,399],{"class":17,"href":395},"#操作方法",[27,397,31],{"className":398},[30],[27,400,36],{"ariaHidden":34,"tabIndex":35},[197,402,403],{},"输入框中输入单词即开始。若没有单词可接龙，会自动显示消息。",[197,405,406],{},"在游戏过程中，将鼠标放在单词上，可查看单词的意思。",[197,408,409,410,413],{},"如果不会，可以点击“询问AI”进行 ",[49,411,412],{},"AI"," 辅助，基于输入匹配单词。",[20,415,416,417],{"id":416,"class":13},"游戏特色",[15,418,420,423],{"class":17,"href":419},"#游戏特色",[27,421,31],{"className":422},[30],[27,424,36],{"ariaHidden":34,"tabIndex":35},[197,426,427],{},"词汇库支持约15000词接龙和释义查询，涵盖基础词汇、学术词汇等，自动验证输入的单词是否有效。",[197,429,430],{},"释义涵盖基本释义、词性、常见短语对照，可配合玩家理解、学习单词。",[20,432,266,433],{"id":266,"class":13},[15,434,435,438],{"class":17,"href":269},[27,436,31],{"className":437},[30],[27,439,36],{"ariaHidden":34,"tabIndex":35},[197,441,442],{},[278,443],{"alt":444,"src":445},"单词接龙学习游戏界面","\u002Fraw\u002Fword-solitaire-screenshot.png",{"title":283,"searchDepth":284,"depth":285,"links":447},[448,450,452,454],{"id":343,"depth":284,"text":449},"基本规则章节 §",{"id":392,"depth":284,"text":451},"操作方法章节 §",{"id":416,"depth":284,"text":453},"游戏特色章节 §",{"id":266,"depth":284,"text":296},"2025\u002F03\u002F07",[457,458],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。",[460],[461,304],"\u002Fraw\u002Fword-solitaire.html",[463,466],[464,465],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002Fword-solitaire.html","源代码",[461,310],{},"\u002Fpages\u002Fword-solitaire",{"title":330,"description":470},[457,458],"pages\u002Fword-solitaire",[473,475,477],[319,474],"web",[322,476],"original",[325,478],"entertainment","WhyKIGqBc04pXuzIbYkSifl8lC7QtZ9eNBVB4YDljnk",{"id":481,"title":482,"body":483,"date":656,"description":657,"downloads":661,"extension":305,"hide":306,"links":668,"meta":675,"navigation":312,"path":676,"seo":677,"stem":679,"tags":680,"__hash__":685},"pages\u002Fpages\u002Flife-game.md","Scratch生命游戏",{"type":8,"value":484,"toc":647},[485,491,502,505,512,524,527,583,595,605,608,619,626,635,641],[11,486,482,488],{"id":487,"class":13},"scratch生命游戏",[15,489],{"class":17,"href":490},"#scratch生命游戏",[20,492,493,494],{"id":493,"class":13},"生命游戏介绍",[15,495,497,500],{"class":17,"href":496},"#生命游戏介绍",[27,498,31],{"className":499},[30],[27,501,36],{"ariaHidden":34,"tabIndex":35},[197,503,504],{},"生命游戏由英国数学家康威于1970年发明。它在一个二维方格世界中模拟细胞的生死状态，细胞的存活与否取决于周围相邻细胞的数量。具体规则包括：如果一个细胞周围活细胞过少，它会死亡；如果活细胞过多，它也会死亡；只有在适当的邻居数量下，细胞才能存活。",[197,506,507,508,511],{},"本程序模拟了生命游戏的一种规则：",[49,509,510],{},"B3\u002FS23","。意思是，若细胞周围有3个细胞，则会繁殖新细胞；而若细胞周围有2或3个细胞，则会保持当前状态。需使用TurboWarp运行，或点击快捷体验。",[20,513,515,516],{"id":514,"class":13},"操作方法新版本","操作方法（新版本）",[15,517,519,522],{"class":17,"href":518},"#操作方法新版本",[27,520,31],{"className":521},[30],[27,523,36],{"ariaHidden":34,"tabIndex":35},[197,525,526],{},"新版本是自制的无限地图生命游戏。关键算法包括哈希等。",[38,528,529,535,541,547,553,559,565,571,577],{},[41,530,531,534],{},[44,532,533],{},"工具栏：","包含多个功能，鼠标单击舞台最下方开启，再次单击上方关闭。",[41,536,537,540],{},[44,538,539],{},"添加细胞：","鼠标操作，移动到合适位置，拖拽添加多个细胞。",[41,542,543,546],{},[44,544,545],{},"删除细胞：","在工具栏中点击\"画笔\"第一项，后与添加细胞相同。",[41,548,549,552],{},[44,550,551],{},"清空细胞：","在工具栏中点击\"清空\"，注意清空操作不可撤回。",[41,554,555,558],{},[44,556,557],{},"粗细调整：","在工具栏中点击\"画笔\"第二项，有1x1到3x3三种粗细选择。",[41,560,561,564],{},[44,562,563],{},"位移：","键盘WASD，分别对应上左下右移动。",[41,566,567,570],{},[44,568,569],{},"缩放：","鼠标滚轮，滚动可动态调整缩放。",[41,572,573,576],{},[44,574,575],{},"重置移缩：","在工具栏中点击\"回家\"即可。",[41,578,579,582],{},[44,580,581],{},"模拟：","在工具栏中点击\"播放\"切换模拟运行状态，模拟规则见上。",[20,584,586,587],{"id":585,"class":13},"附加说明旧版本","附加说明（旧版本）",[15,588,590,593],{"class":17,"href":589},"#附加说明旧版本",[27,591,31],{"className":592},[30],[27,594,36],{"ariaHidden":34,"tabIndex":35},[197,596,597,598,604],{},"旧版本生命游戏主要参考",[15,599,603],{"href":600,"rel":601},"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1aB4y1W7cK",[602],"nofollow","编程侯老师","的教程视频制作。",[197,606,607],{},"仅需使用鼠标操作：",[38,609,610,613,616],{},[41,611,612],{},"左侧为地图相关设置，如随机地图，清空地图，和4种预设的地图。",[41,614,615],{},"右上侧为模拟状态。单击下一代模拟一次，长按快速模拟。下面可显示自上次清空，模拟的总代数。",[41,617,618],{},"右下侧为控制细胞，可实现基本的添加、删除细胞。",[197,620,621,622,625],{},"旧版本制作于 ",[49,623,624],{},"2022\u002F12\u002F22","。该版本提供有限的地图，且存在一定bug。暂不提供在线体验链接。",[20,627,266,628],{"id":266,"class":13},[15,629,630,633],{"class":17,"href":269},[27,631,31],{"className":632},[30],[27,634,36],{"ariaHidden":34,"tabIndex":35},[197,636,637],{},[278,638],{"alt":639,"src":640},"在Scratch无限生命游戏模拟高斯帕滑翔枪","\u002Fraw\u002Finfinity-life-game-screenshot.png",[197,642,643],{},[278,644],{"alt":645,"src":646},"在Scratch生命游戏中模拟简单飞船","\u002Fraw\u002Flife-game-screenshot.png",{"title":283,"searchDepth":284,"depth":285,"links":648},[649,651,653,655],{"id":493,"depth":284,"text":650},"生命游戏介绍章节 §",{"id":514,"depth":284,"text":652},"操作方法（新版本）章节 §",{"id":585,"depth":284,"text":654},"附加说明（旧版本）章节 §",{"id":266,"depth":284,"text":296},"2025\u002F07\u002F20",[658,659,660],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。",[662,665],[663,664],"\u002Fraw\u002Finfinity-life-game.sb3","下载：新版本",[666,667],"\u002Fraw\u002Flife-game.sb3","下载：旧版本",[669,672],[670,671],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1ingezAEem\u002F","演示视频（新版本）",[673,674],"\u002Fraw\u002Finfinity-life-game.html","体验：新版本",{},"\u002Fpages\u002Flife-game",{"title":482,"description":678},[658,659,660],"pages\u002Flife-game",[681,682,683],[319,320],[322,323],[325,684],"art","T1fcYeSq4jCC4fwzefXxF3VDHsNP6qYtZOdOdmOCAh0",1782556477764]
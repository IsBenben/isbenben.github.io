[{"data":1,"prerenderedAt":635},["ShallowReactive",2],{"article-\u002Fpages\u002Fguess-the-word":3},{"id":4,"title":5,"body":6,"date":604,"description":605,"downloads":609,"extension":613,"hide":614,"links":615,"meta":618,"navigation":619,"path":620,"seo":621,"stem":623,"tags":624,"__hash__":634},"pages\u002Fpages\u002Fguess-the-word.md","猜词游戏",{"type":7,"value":8,"toc":561},"minimark",[9,18,22,40,47,58,152,163,183,194,206,213,224,230,233,244,282,293,296,307,317,328,339,346,357,367,378,397,408,419,425,436,443,504,515,535,546,557],[10,11,5,13],"h1",{"id":5,"class":12},"section-heading",[14,15],"a",{"class":16,"href":17},"section-link","#猜词游戏",[19,20,21],"p",{},"一个基于Web的交互式猜词游戏，玩家通过点击屏幕键盘或物理键盘猜测单词中的字母。游戏实时统计按键数据（正确\u002F错误\u002F无效）、字母匹配率、完成进度和用时，并支持通过URL分享自定义单词。",[23,24,25,26],"h2",{"id":25,"class":12},"游戏截图",[14,27,29,35],{"class":16,"href":28},"#游戏截图",[30,31,34],"span",{"className":32},[33],"visually-hidden","章节",[30,36,39],{"ariaHidden":37,"tabIndex":38},"true",-1," §",[19,41,42],{},[43,44],"img",{"alt":45,"src":46},"基于Web的交互式猜词游戏界面","\u002Fraw\u002Fguess-the-word-screenshot.png",[23,48,49,50],{"id":49,"class":12},"核心功能特性",[14,51,53,56],{"class":16,"href":52},"#核心功能特性",[30,54,34],{"className":55},[33],[30,57,39],{"ariaHidden":37,"tabIndex":38},[59,60,61,69,88,110,127,140,146],"ul",{},[62,63,64,68],"li",{},[65,66,67],"strong",{},"核心玩法","：猜测隐藏单词的字母，每猜对一个字母，单词中所有对应位置都会揭示。",[62,70,71,74,75],{},[65,72,73],{},"双输入方式","：\n",[59,76,77,80],{},[62,78,79],{},"虚拟键盘（响应式布局，PC\u002F移动端自适应）",[62,81,82,83,87],{},"物理键盘（监听",[84,85,86],"code",{},"keydown","事件）",[62,89,90,74,93],{},[65,91,92],{},"实时统计面板",[59,94,95,98,101,104,107],{},[62,96,97],{},"总按键次数 \u002F 速率",[62,99,100],{},"正确\u002F错误\u002F无效按键统计（次数、速率、占比）",[62,102,103],{},"字母匹配数（每个按键平均匹配字母数、速率）",[62,105,106],{},"完成百分比（进度\u002F按键\u002F秒）",[62,108,109],{},"游戏用时",[62,111,112,74,115],{},[65,113,114],{},"分享机制",[59,116,117,120],{},[62,118,119],{},"点击「分享」按钮生成当前单词的 Base64 编码链接",[62,121,122,123,126],{},"通过 URL 参数",[84,124,125],{},"?w=\u003Cbase64>","直接加载指定单词",[62,128,129,74,132],{},[65,130,131],{},"视觉反馈",[59,133,134,137],{},[62,135,136],{},"正确字母按键变绿，错误字母按键变红，无效重复按键忽略",[62,138,139],{},"单词区域以下划线展示未猜字母，已猜字母直接显示",[62,141,142,145],{},[65,143,144],{},"日志系统","：所有操作（游戏开始、按键结果、分享等）都记录在侧边日志区，带时间戳。",[62,147,148,151],{},[65,149,150],{},"新游戏","：可随时重置随机单词（内置约5000个英文单词库）或通过分享链接开始新游戏。",[23,153,154,155],{"id":154,"class":12},"技术栈",[14,156,158,161],{"class":16,"href":157},"#技术栈",[30,159,34],{"className":160},[33],[30,162,39],{"ariaHidden":37,"tabIndex":38},[59,164,165,171,177],{},[62,166,167,170],{},[65,168,169],{},"HTML5 \u002F CSS3","：响应式Grid布局（两栏 → 单栏自适应）",[62,172,173,176],{},[65,174,175],{},"jQuery 4.0.0","：DOM操作、事件绑定、动画帧优化",[62,178,179,182],{},[65,180,181],{},"原生 JavaScript","：核心游戏逻辑、日期格式化、Base64编解码",[23,184,185,186],{"id":185,"class":12},"快速开始",[14,187,189,192],{"class":16,"href":188},"#快速开始",[30,190,34],{"className":191},[33],[30,193,39],{"ariaHidden":37,"tabIndex":38},[195,196,197,198],"h3",{"id":197,"class":12},"下载项目",[14,199,201,204],{"class":16,"href":200},"#下载项目",[30,202,34],{"className":203},[33],[30,205,39],{"ariaHidden":37,"tabIndex":38},[19,207,208,209,212],{},"将提供的",[84,210,211],{},"index.html","保存到本地（或部署到 Web 服务器）。",[195,214,215,216],{"id":215,"class":12},"运行游戏",[14,217,219,222],{"class":16,"href":218},"#运行游戏",[30,220,34],{"className":221},[33],[30,223,39],{"ariaHidden":37,"tabIndex":38},[19,225,226,227,229],{},"直接用浏览器打开",[84,228,211],{},"即可开始游戏（无需任何构建步骤）。",[19,231,232],{},"游戏代码已内嵌所有样式、脚本和单词库，单文件即可运行。",[195,234,235,236],{"id":235,"class":12},"游戏规则",[14,237,239,242],{"class":16,"href":238},"#游戏规则",[30,240,34],{"className":241},[33],[30,243,39],{"ariaHidden":37,"tabIndex":38},[59,245,246,253,276,279],{},[62,247,248,249,252],{},"页面上方展示待猜单词（以下划线",[84,250,251],{},"_","表示未猜字母）。",[62,254,255,256],{},"点击虚拟键盘上的字母（或直接按物理键盘字母键）猜测。\n",[59,257,258,264,270],{},[62,259,260,263],{},[65,261,262],{},"正确猜测","：单词中所有相同字母位置会揭示，该按键变为绿色。",[62,265,266,269],{},[65,267,268],{},"错误猜测","：按键变为红色，无字母匹配。",[62,271,272,275],{},[65,273,274],{},"重复猜测","：已猜过的字母（无论对错）再次点击无效，计入“无效按键”。",[62,277,278],{},"猜出所有字母后游戏胜利，计时停止。",[62,280,281],{},"可通过“新游戏”按钮重置随机单词，“显示答案”直接揭示单词并结束游戏。",[195,283,284,285],{"id":284,"class":12},"分享单词",[14,286,288,291],{"class":16,"href":287},"#分享单词",[30,289,34],{"className":290},[33],[30,292,39],{"ariaHidden":37,"tabIndex":38},[19,294,295],{},"点击“分享”按钮，游戏会生成当前单词的Base64编码，并打印一条包含完整链接的日志。该链接可直接复制发送给朋友，对方打开后会自动加载相同的单词（无需手动输入）。",[23,297,298,299],{"id":298,"class":12},"项目结构",[14,300,302,305],{"class":16,"href":301},"#项目结构",[30,303,34],{"className":304},[33],[30,306,39],{"ariaHidden":37,"tabIndex":38},[308,309,315],"pre",{"className":310,"code":312,"language":313,"meta":314},[311],"language-text","index.html    单文件应用，包含：\n├── \u003Cstyle>    全部CSS样式（布局、键盘、按钮等）\n├── \u003Cbody>    DOM结构（单词区、信息面板、日志区、控制按钮、虚拟键盘）\n└── \u003Cscript>    所有游戏逻辑：\n    ├── 工具函数（数组填充、随机选择、日期格式化等）\n    ├── 虚拟键盘生成与渲染\n    ├── 单词库（内置约5000个常见英语单词）\n    ├── 游戏状态管理（guess数组、按键统计、计时）\n    ├── 统计面板自动刷新（使用requestAnimationFrame）\n    ├── 事件绑定（键盘点击、物理按键、按钮操作）\n    └── 分享链接解析与Base64解码\n","text","",[84,316,312],{"__ignoreMap":314},[23,318,319,320],{"id":319,"class":12},"核心代码说明",[14,321,323,326],{"class":16,"href":322},"#核心代码说明",[30,324,34],{"className":325},[33],[30,327,39],{"ariaHidden":37,"tabIndex":38},[195,329,330,331],{"id":330,"class":12},"单词库",[14,332,334,337],{"class":16,"href":333},"#单词库",[30,335,34],{"className":336},[33],[30,338,39],{"ariaHidden":37,"tabIndex":38},[19,340,341,342,345],{},"变量",[84,343,344],{},"words","存储了约5000个英文单词（以逗号分隔的字符串）。新游戏时随机选取单词库中的单词。",[195,347,348,349],{"id":348,"class":12},"统计面板更新",[14,350,352,355],{"class":16,"href":351},"#统计面板更新",[30,353,34],{"className":354},[33],[30,356,39],{"ariaHidden":37,"tabIndex":38},[19,358,359,362,363,366],{},[84,360,361],{},"renderInfo","函数使用闭包缓存所有DOM元素，通过数据对象一次性更新。",[84,364,365],{},"updateInfo()","会每帧调用该函数，计算用时、速率、百分比等，并刷新面板。",[195,368,369,370],{"id":369,"class":12},"分享链接原理",[14,371,373,376],{"class":16,"href":372},"#分享链接原理",[30,374,34],{"className":375},[33],[30,377,39],{"ariaHidden":37,"tabIndex":38},[19,379,380,381,384,385,388,389,392,393,396],{},"点击“分享”时，",[84,382,383],{},"btoa(wordRaw)","将原始单词编码为Base64，拼接成",[84,386,387],{},"?w=xxx","形式的 URL。页面加载时，读取",[84,390,391],{},"window.location.search","，若存在",[84,394,395],{},"w","参数，尝试Base64解码后作为初始单词。",[23,398,399,400],{"id":399,"class":12},"自定义配置",[14,401,403,406],{"class":16,"href":402},"#自定义配置",[30,404,34],{"className":405},[33],[30,407,39],{"ariaHidden":37,"tabIndex":38},[195,409,410,411],{"id":410,"class":12},"修改单词库",[14,412,414,417],{"class":16,"href":413},"#修改单词库",[30,415,34],{"className":416},[33],[30,418,39],{"ariaHidden":37,"tabIndex":38},[19,420,421,422,424],{},"直接编辑代码中",[84,423,344],{},"数组，增加或替换为自己的单词列表。",[195,426,427,428],{"id":427,"class":12},"调整键盘布局",[14,429,431,434],{"class":16,"href":430},"#调整键盘布局",[30,432,34],{"className":433},[33],[30,435,39],{"ariaHidden":37,"tabIndex":38},[19,437,438,439,442],{},"修改",[84,440,441],{},"rows","数组，例如：",[308,444,448],{"className":445,"code":446,"language":447,"meta":314,"style":314},"language-js shiki shiki-themes dracula","var rows = [\"qwertyuiop\", \"asdfghjkl\", \"zxcvbnm,\"]; \u002F\u002F 逗号代表空按键，仅用作布局\n","js",[84,449,450],{"__ignoreMap":314},[30,451,454,458,462,465,468,472,476,478,481,483,486,488,490,492,495,497,500],{"class":452,"line":453},"line",1,[30,455,457],{"class":456},"s0Tla","var",[30,459,461],{"class":460},"sCdxs"," rows ",[30,463,464],{"class":456},"=",[30,466,467],{"class":460}," [",[30,469,471],{"class":470},"seVfx","\"",[30,473,475],{"class":474},"s-mGx","qwertyuiop",[30,477,471],{"class":470},[30,479,480],{"class":460},", ",[30,482,471],{"class":470},[30,484,485],{"class":474},"asdfghjkl",[30,487,471],{"class":470},[30,489,480],{"class":460},[30,491,471],{"class":470},[30,493,494],{"class":474},"zxcvbnm,",[30,496,471],{"class":470},[30,498,499],{"class":460},"]; ",[30,501,503],{"class":502},"shSDL","\u002F\u002F 逗号代表空按键，仅用作布局\n",[23,505,506,507],{"id":506,"class":12},"兼容性",[14,508,510,513],{"class":16,"href":509},"#兼容性",[30,511,34],{"className":512},[33],[30,514,39],{"ariaHidden":37,"tabIndex":38},[59,516,517,523,529],{},[62,518,519,522],{},[65,520,521],{},"桌面浏览器","：Chrome, Firefox, Edge, Safari",[62,524,525,528],{},[65,526,527],{},"移动端","：iOS Safari, Android Chrome",[62,530,531,534],{},[65,532,533],{},"IE兼容","：游戏核心逻辑基于ES5，但部分功能在IE中不支持，推荐使用现代浏览器。",[23,536,537,538],{"id":537,"class":12},"注意事项",[14,539,541,544],{"class":16,"href":540},"#注意事项",[30,542,34],{"className":543},[33],[30,545,39],{"ariaHidden":37,"tabIndex":38},[59,547,548,551,554],{},[62,549,550],{},"物理键盘输入会自动转为小写匹配，单词中的字母比较时不区分大小写。",[62,552,553],{},"游戏开始时，非字母字符（如标点、空格）会被自动视为“已猜”，不计入需要猜测的字母数。",[62,555,556],{},"“显示答案”按钮会直接揭示所有字母，游戏标记为胜利，不再接受新输入。",[558,559,560],"style",{},"html pre.shiki code .s0Tla, html code.shiki .s0Tla{--shiki-default:#FF79C6}html pre.shiki code .sCdxs, html code.shiki .sCdxs{--shiki-default:#F8F8F2}html pre.shiki code .seVfx, html code.shiki .seVfx{--shiki-default:#E9F284}html pre.shiki code .s-mGx, html code.shiki .s-mGx{--shiki-default:#F1FA8C}html pre.shiki code .shSDL, html code.shiki .shSDL{--shiki-default:#6272A4}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":314,"searchDepth":562,"depth":563,"links":564},2,3,[565,567,569,571,582,584,593,600,602],{"id":25,"depth":562,"text":566},"游戏截图章节 §",{"id":49,"depth":562,"text":568},"核心功能特性章节 §",{"id":154,"depth":562,"text":570},"技术栈章节 §",{"id":185,"depth":562,"text":572,"children":573},"快速开始章节 §",[574,576,578,580],{"id":197,"depth":563,"text":575},"下载项目章节 §",{"id":215,"depth":563,"text":577},"运行游戏章节 §",{"id":235,"depth":563,"text":579},"游戏规则章节 §",{"id":284,"depth":563,"text":581},"分享单词章节 §",{"id":298,"depth":562,"text":583},"项目结构章节 §",{"id":319,"depth":562,"text":585,"children":586},"核心代码说明章节 §",[587,589,591],{"id":330,"depth":563,"text":588},"单词库章节 §",{"id":348,"depth":563,"text":590},"统计面板更新章节 §",{"id":369,"depth":563,"text":592},"分享链接原理章节 §",{"id":399,"depth":562,"text":594,"children":595},"自定义配置章节 §",[596,598],{"id":410,"depth":563,"text":597},"修改单词库章节 §",{"id":427,"depth":563,"text":599},"调整键盘布局章节 §",{"id":506,"depth":562,"text":601},"兼容性章节 §",{"id":537,"depth":562,"text":603},"注意事项章节 §","2026\u002F5\u002F20",[606,607,608],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。",[610],[611,612],"\u002Fraw\u002Fguess-the-word.html","下载","md",false,[616],[611,617],"体验",{},true,"\u002Fpages\u002Fguess-the-word",{"title":5,"description":622},[606,607,608],"pages\u002Fguess-the-word",[625,628,631],[626,627],"lang","web",[629,630],"inspiration","original",[632,633],"content","entertainment","XUhQboB_wTenRLhbjbFpdFgAN9UJHUNsUIA2RfExZNI",1781179807343]
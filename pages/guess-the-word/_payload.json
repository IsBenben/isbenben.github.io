[{"data":1,"prerenderedAt":630},["ShallowReactive",2],{"article-guess-the-word":3},{"id":4,"title":5,"body":6,"date":598,"description":599,"downloads":603,"extension":607,"hide":608,"links":609,"meta":612,"navigation":613,"path":614,"seo":615,"slug":617,"stem":618,"tags":619,"__hash__":629},"articles\u002Farticles\u002Fguess-the-word.md","猜词游戏",{"type":7,"value":8,"toc":555},"minimark",[9,13,34,41,52,146,157,177,188,200,207,218,224,227,238,276,287,290,301,311,322,333,340,351,361,372,391,402,413,419,430,437,498,509,529,540,551],[10,11,12],"p",{},"一个基于Web的交互式猜词游戏，玩家通过点击屏幕键盘或物理键盘猜测单词中的字母。游戏实时统计按键数据（正确\u002F错误\u002F无效）、字母匹配率、完成进度和用时，并支持通过URL分享自定义单词。",[14,15,16,18],"h2",{"id":16,"class":17},"游戏截图","section-heading",[19,20,23,29],"a",{"class":21,"href":22},"section-link","#游戏截图",[24,25,28,16],"span",{"className":26},[27],"visually-hidden","章节",[24,30,33],{"ariaHidden":31,"tabIndex":32},"true",-1," §",[10,35,36],{},[37,38],"img",{"alt":39,"src":40},"基于Web的交互式猜词游戏界面","\u002Fraw\u002Fguess-the-word-screenshot.png",[14,42,43,44],{"id":43,"class":17},"核心功能特性",[19,45,47,50],{"class":21,"href":46},"#核心功能特性",[24,48,28,43],{"className":49},[27],[24,51,33],{"ariaHidden":31,"tabIndex":32},[53,54,55,63,82,104,121,134,140],"ul",{},[56,57,58,62],"li",{},[59,60,61],"strong",{},"核心玩法","：猜测隐藏单词的字母，每猜对一个字母，单词中所有对应位置都会揭示。",[56,64,65,68,69],{},[59,66,67],{},"双输入方式","：\n",[53,70,71,74],{},[56,72,73],{},"虚拟键盘（响应式布局，PC\u002F移动端自适应）",[56,75,76,77,81],{},"物理键盘（监听",[78,79,80],"code",{},"keydown","事件）",[56,83,84,68,87],{},[59,85,86],{},"实时统计面板",[53,88,89,92,95,98,101],{},[56,90,91],{},"总按键次数 \u002F 速率",[56,93,94],{},"正确\u002F错误\u002F无效按键统计（次数、速率、占比）",[56,96,97],{},"字母匹配数（每个按键平均匹配字母数、速率）",[56,99,100],{},"完成百分比（进度\u002F按键\u002F秒）",[56,102,103],{},"游戏用时",[56,105,106,68,109],{},[59,107,108],{},"分享机制",[53,110,111,114],{},[56,112,113],{},"点击「分享」按钮生成当前单词的 Base64 编码链接",[56,115,116,117,120],{},"通过 URL 参数",[78,118,119],{},"?w=\u003Cbase64>","直接加载指定单词",[56,122,123,68,126],{},[59,124,125],{},"视觉反馈",[53,127,128,131],{},[56,129,130],{},"正确字母按键变绿，错误字母按键变红，无效重复按键忽略",[56,132,133],{},"单词区域以下划线展示未猜字母，已猜字母直接显示",[56,135,136,139],{},[59,137,138],{},"日志系统","：所有操作（游戏开始、按键结果、分享等）都记录在侧边日志区，带时间戳。",[56,141,142,145],{},[59,143,144],{},"新游戏","：可随时重置随机单词（内置约5000个英文单词库）或通过分享链接开始新游戏。",[14,147,148,149],{"id":148,"class":17},"技术栈",[19,150,152,155],{"class":21,"href":151},"#技术栈",[24,153,28,148],{"className":154},[27],[24,156,33],{"ariaHidden":31,"tabIndex":32},[53,158,159,165,171],{},[56,160,161,164],{},[59,162,163],{},"HTML5 \u002F CSS3","：响应式Grid布局（两栏 → 单栏自适应）",[56,166,167,170],{},[59,168,169],{},"jQuery 4.0.0","：DOM操作、事件绑定、动画帧优化",[56,172,173,176],{},[59,174,175],{},"原生 JavaScript","：核心游戏逻辑、日期格式化、Base64编解码",[14,178,179,180],{"id":179,"class":17},"快速开始",[19,181,183,186],{"class":21,"href":182},"#快速开始",[24,184,28,179],{"className":185},[27],[24,187,33],{"ariaHidden":31,"tabIndex":32},[189,190,191,192],"h3",{"id":191,"class":17},"下载项目",[19,193,195,198],{"class":21,"href":194},"#下载项目",[24,196,28,191],{"className":197},[27],[24,199,33],{"ariaHidden":31,"tabIndex":32},[10,201,202,203,206],{},"将提供的",[78,204,205],{},"index.html","保存到本地（或部署到 Web 服务器）。",[189,208,209,210],{"id":209,"class":17},"运行游戏",[19,211,213,216],{"class":21,"href":212},"#运行游戏",[24,214,28,209],{"className":215},[27],[24,217,33],{"ariaHidden":31,"tabIndex":32},[10,219,220,221,223],{},"直接用浏览器打开",[78,222,205],{},"即可开始游戏（无需任何构建步骤）。",[10,225,226],{},"游戏代码已内嵌所有样式、脚本和单词库，单文件即可运行。",[189,228,229,230],{"id":229,"class":17},"游戏规则",[19,231,233,236],{"class":21,"href":232},"#游戏规则",[24,234,28,229],{"className":235},[27],[24,237,33],{"ariaHidden":31,"tabIndex":32},[53,239,240,247,270,273],{},[56,241,242,243,246],{},"页面上方展示待猜单词（以下划线",[78,244,245],{},"_","表示未猜字母）。",[56,248,249,250],{},"点击虚拟键盘上的字母（或直接按物理键盘字母键）猜测。\n",[53,251,252,258,264],{},[56,253,254,257],{},[59,255,256],{},"正确猜测","：单词中所有相同字母位置会揭示，该按键变为绿色。",[56,259,260,263],{},[59,261,262],{},"错误猜测","：按键变为红色，无字母匹配。",[56,265,266,269],{},[59,267,268],{},"重复猜测","：已猜过的字母（无论对错）再次点击无效，计入“无效按键”。",[56,271,272],{},"猜出所有字母后游戏胜利，计时停止。",[56,274,275],{},"可通过“新游戏”按钮重置随机单词，“显示答案”直接揭示单词并结束游戏。",[189,277,278,279],{"id":278,"class":17},"分享单词",[19,280,282,285],{"class":21,"href":281},"#分享单词",[24,283,28,278],{"className":284},[27],[24,286,33],{"ariaHidden":31,"tabIndex":32},[10,288,289],{},"点击“分享”按钮，游戏会生成当前单词的Base64编码，并打印一条包含完整链接的日志。该链接可直接复制发送给朋友，对方打开后会自动加载相同的单词（无需手动输入）。",[14,291,292,293],{"id":292,"class":17},"项目结构",[19,294,296,299],{"class":21,"href":295},"#项目结构",[24,297,28,292],{"className":298},[27],[24,300,33],{"ariaHidden":31,"tabIndex":32},[302,303,309],"pre",{"className":304,"code":306,"language":307,"meta":308},[305],"language-text","index.html    单文件应用，包含：\n├── \u003Cstyle>    全部CSS样式（布局、键盘、按钮等）\n├── \u003Cbody>    DOM结构（单词区、信息面板、日志区、控制按钮、虚拟键盘）\n└── \u003Cscript>    所有游戏逻辑：\n    ├── 工具函数（数组填充、随机选择、日期格式化等）\n    ├── 虚拟键盘生成与渲染\n    ├── 单词库（内置约5000个常见英语单词）\n    ├── 游戏状态管理（guess数组、按键统计、计时）\n    ├── 统计面板自动刷新（使用requestAnimationFrame）\n    ├── 事件绑定（键盘点击、物理按键、按钮操作）\n    └── 分享链接解析与Base64解码\n","text","",[78,310,306],{"__ignoreMap":308},[14,312,313,314],{"id":313,"class":17},"核心代码说明",[19,315,317,320],{"class":21,"href":316},"#核心代码说明",[24,318,28,313],{"className":319},[27],[24,321,33],{"ariaHidden":31,"tabIndex":32},[189,323,324,325],{"id":324,"class":17},"单词库",[19,326,328,331],{"class":21,"href":327},"#单词库",[24,329,28,324],{"className":330},[27],[24,332,33],{"ariaHidden":31,"tabIndex":32},[10,334,335,336,339],{},"变量",[78,337,338],{},"words","存储了约5000个英文单词（以逗号分隔的字符串）。新游戏时随机选取单词库中的单词。",[189,341,342,343],{"id":342,"class":17},"统计面板更新",[19,344,346,349],{"class":21,"href":345},"#统计面板更新",[24,347,28,342],{"className":348},[27],[24,350,33],{"ariaHidden":31,"tabIndex":32},[10,352,353,356,357,360],{},[78,354,355],{},"renderInfo","函数使用闭包缓存所有DOM元素，通过数据对象一次性更新。",[78,358,359],{},"updateInfo()","会每帧调用该函数，计算用时、速率、百分比等，并刷新面板。",[189,362,363,364],{"id":363,"class":17},"分享链接原理",[19,365,367,370],{"class":21,"href":366},"#分享链接原理",[24,368,28,363],{"className":369},[27],[24,371,33],{"ariaHidden":31,"tabIndex":32},[10,373,374,375,378,379,382,383,386,387,390],{},"点击“分享”时，",[78,376,377],{},"btoa(wordRaw)","将原始单词编码为Base64，拼接成",[78,380,381],{},"?w=xxx","形式的 URL。页面加载时，读取",[78,384,385],{},"window.location.search","，若存在",[78,388,389],{},"w","参数，尝试Base64解码后作为初始单词。",[14,392,393,394],{"id":393,"class":17},"自定义配置",[19,395,397,400],{"class":21,"href":396},"#自定义配置",[24,398,28,393],{"className":399},[27],[24,401,33],{"ariaHidden":31,"tabIndex":32},[189,403,404,405],{"id":404,"class":17},"修改单词库",[19,406,408,411],{"class":21,"href":407},"#修改单词库",[24,409,28,404],{"className":410},[27],[24,412,33],{"ariaHidden":31,"tabIndex":32},[10,414,415,416,418],{},"直接编辑代码中",[78,417,338],{},"数组，增加或替换为自己的单词列表。",[189,420,421,422],{"id":421,"class":17},"调整键盘布局",[19,423,425,428],{"class":21,"href":424},"#调整键盘布局",[24,426,28,421],{"className":427},[27],[24,429,33],{"ariaHidden":31,"tabIndex":32},[10,431,432,433,436],{},"修改",[78,434,435],{},"rows","数组，例如：",[302,438,442],{"className":439,"code":440,"language":441,"meta":308,"style":308},"language-js shiki shiki-themes dracula","var rows = [\"qwertyuiop\", \"asdfghjkl\", \"zxcvbnm,\"]; \u002F\u002F 逗号代表空按键，仅用作布局\n","js",[78,443,444],{"__ignoreMap":308},[24,445,448,452,456,459,462,466,470,472,475,477,480,482,484,486,489,491,494],{"class":446,"line":447},"line",1,[24,449,451],{"class":450},"s0Tla","var",[24,453,455],{"class":454},"sCdxs"," rows ",[24,457,458],{"class":450},"=",[24,460,461],{"class":454}," [",[24,463,465],{"class":464},"seVfx","\"",[24,467,469],{"class":468},"s-mGx","qwertyuiop",[24,471,465],{"class":464},[24,473,474],{"class":454},", ",[24,476,465],{"class":464},[24,478,479],{"class":468},"asdfghjkl",[24,481,465],{"class":464},[24,483,474],{"class":454},[24,485,465],{"class":464},[24,487,488],{"class":468},"zxcvbnm,",[24,490,465],{"class":464},[24,492,493],{"class":454},"]; ",[24,495,497],{"class":496},"shSDL","\u002F\u002F 逗号代表空按键，仅用作布局\n",[14,499,500,501],{"id":500,"class":17},"兼容性",[19,502,504,507],{"class":21,"href":503},"#兼容性",[24,505,2
[{"data":1,"prerenderedAt":641},["ShallowReactive",2],{"article-guess-the-word":3},{"id":4,"title":5,"body":6,"date":609,"description":610,"downloads":614,"extension":618,"hide":619,"links":620,"meta":623,"navigation":624,"path":625,"seo":626,"slug":628,"stem":629,"tags":630,"__hash__":640},"articles\u002Farticles\u002Fguess-the-word.md","猜词游戏",{"type":7,"value":8,"toc":566},"minimark",[9,29,33,45,52,63,157,168,188,199,211,218,229,235,238,249,287,298,301,312,322,333,344,351,362,372,383,402,413,424,430,441,448,509,520,540,551,562],[10,11,5,13],"h1",{"id":5,"class":12},"section-heading",[14,15,18,24],"a",{"class":16,"href":17},"section-link","#猜词游戏",[19,20,23,5],"span",{"className":21},[22],"visually-hidden","章节",[19,25,28],{"ariaHidden":26,"tabIndex":27},"true",-1," §",[30,31,32],"p",{},"一个基于Web的交互式猜词游戏，玩家通过点击屏幕键盘或物理键盘猜测单词中的字母。游戏实时统计按键数据（正确\u002F错误\u002F无效）、字母匹配率、完成进度和用时，并支持通过URL分享自定义单词。",[34,35,36,37],"h2",{"id":36,"class":12},"游戏截图",[14,38,40,43],{"class":16,"href":39},"#游戏截图",[19,41,23,36],{"className":42},[22],[19,44,28],{"ariaHidden":26,"tabIndex":27},[30,46,47],{},[48,49],"img",{"alt":50,"src":51},"基于Web的交互式猜词游戏界面","\u002Fraw\u002Fguess-the-word-screenshot.png",[34,53,54,55],{"id":54,"class":12},"核心功能特性",[14,56,58,61],{"class":16,"href":57},"#核心功能特性",[19,59,23,54],{"className":60},[22],[19,62,28],{"ariaHidden":26,"tabIndex":27},[64,65,66,74,93,115,132,145,151],"ul",{},[67,68,69,73],"li",{},[70,71,72],"strong",{},"核心玩法","：猜测隐藏单词的字母，每猜对一个字母，单词中所有对应位置都会揭示。",[67,75,76,79,80],{},[70,77,78],{},"双输入方式","：\n",[64,81,82,85],{},[67,83,84],{},"虚拟键盘（响应式布局，PC\u002F移动端自适应）",[67,86,87,88,92],{},"物理键盘（监听",[89,90,91],"code",{},"keydown","事件）",[67,94,95,79,98],{},[70,96,97],{},"实时统计面板",[64,99,100,103,106,109,112],{},[67,101,102],{},"总按键次数 \u002F 速率",[67,104,105],{},"正确\u002F错误\u002F无效按键统计（次数、速率、占比）",[67,107,108],{},"字母匹配数（每个按键平均匹配字母数、速率）",[67,110,111],{},"完成百分比（进度\u002F按键\u002F秒）",[67,113,114],{},"游戏用时",[67,116,117,79,120],{},[70,118,119],{},"分享机制",[64,121,122,125],{},[67,123,124],{},"点击「分享」按钮生成当前单词的 Base64 编码链接",[67,126,127,128,131],{},"通过 URL 参数",[89,129,130],{},"?w=\u003Cbase64>","直接加载指定单词",[67,133,134,79,137],{},[70,135,136],{},"视觉反馈",[64,138,139,142],{},[67,140,141],{},"正确字母按键变绿，错误字母按键变红，无效重复按键忽略",[67,143,144],{},"单词区域以下划线展示未猜字母，已猜字母直接显示",[67,146,147,150],{},[70,148,149],{},"日志系统","：所有操作（游戏开始、按键结果、分享等）都记录在侧边日志区，带时间戳。",[67,152,153,156],{},[70,154,155],{},"新游戏","：可随时重置随机单词（内置约5000个英文单词库）或通过分享链接开始新游戏。",[34,158,159,160],{"id":159,"class":12},"技术栈",[14,161,163,166],{"class":16,"href":162},"#技术栈",[19,164,23,159],{"className":165},[22],[19,167,28],{"ariaHidden":26,"tabIndex":27},[64,169,170,176,182],{},[67,171,172,175],{},[70,173,174],{},"HTML5 \u002F CSS3","：响应式Grid布局（两栏 → 单栏自适应）",[67,177,178,181],{},[70,179,180],{},"jQuery 4.0.0","：DOM操作、事件绑定、动画帧优化",[67,183,184,187],{},[70,185,186],{},"原生 JavaScript","：核心游戏逻辑、日期格式化、Base64编解码",[34,189,190,191],{"id":190,"class":12},"快速开始",[14,192,194,197],{"class":16,"href":193},"#快速开始",[19,195,23,190],{"className":196},[22],[19,198,28],{"ariaHidden":26,"tabIndex":27},[200,201,202,203],"h3",{"id":202,"class":12},"下载项目",[14,204,206,209],{"class":16,"href":205},"#下载项目",[19,207,23,202],{"className":208},[22],[19,210,28],{"ariaHidden":26,"tabIndex":27},[30,212,213,214,217],{},"将提供的",[89,215,216],{},"index.html","保存到本地（或部署到 Web 服务器）。",[200,219,220,221],{"id":220,"class":12},"运行游戏",[14,222,224,227],{"class":16,"href":223},"#运行游戏",[19,225,23,220],{"className":226},[22],[19,228,28],{"ariaHidden":26,"tabIndex":27},[30,230,231,232,234],{},"直接用浏览器打开",[89,233,216],{},"即可开始游戏（无需任何构建步骤）。",[30,236,237],{},"游戏代码已内嵌所有样式、脚本和单词库，单文件即可运行。",[200,239,240,241],{"id":240,"class":12},"游戏规则",[14,242,244,247],{"class":16,"href":243},"#游戏规则",[19,245,23,240],{"className":246},[22],[19,248,28],{"ariaHidden":26,"tabIndex":27},[64,250,251,258,281,284],{},[67,252,253,254,257],{},"页面上方展示待猜单词（以下划线",[89,255,256],{},"_","表示未猜字母）。",[67,259,260,261],{},"点击虚拟键盘上的字母（或直接按物理键盘字母键）猜测。\n",[64,262,263,269,275],{},[67,264,265,268],{},[70,266,267],{},"正确猜测","：单词中所有相同字母位置会揭示，该按键变为绿色。",[67,270,271,274],{},[70,272,273],{},"错误猜测","：按键变为红色，无字母匹配。",[67,276,277,280],{},[70,278,279],{},"重复猜测","：已猜过的字母（无论对错）再次点击无效，计入“无效按键”。",[67,282,283],{},"猜出所有字母后游戏胜利，计时停止。",[67,285,286],{},"可通过“新游戏”按钮重置随机单词，“显示答案”直接揭示单词并结束游戏。",[200,288,289,290],{"id":289,"class":12},"分享单词",[14,291,293,296],{"class":16,"href":292},"#分享单词",[19,294,23,289],{"className":295},[22],[19,297,28],{"ariaHidden":26,"tabIndex":27},[30,299,300],{},"点击“分享”按钮，游戏会生成当前单词的Base64编码，并打印一条包含完整链接的日志。该链接可直接复制发送给朋友，对方打开后会自动加载相同的单词（无需手动输入）。",[34,302,303,304],{"id":303,"class":12},"项目结构",[14,305,307,310],{"class":16,"href":306},"#项目结构",[19,308,23,303],{"className":309},[22],[19,311,28],{"ariaHidden":26,"tabIndex":27},[313,314,320],"pre",{"className":315,"code":317,"language":318,"meta":319},[316],"language-text","index.html    单文件应用，包含：\n├── \u003Cstyle>    全部CSS样式（布局、键盘、按钮等）\n├── \u003Cbody>    DOM结构（单词区、信息面板、日志区、控制按钮、虚拟键盘）\n└── \u003Cscript>    所有游戏逻辑：\n    ├── 工具函数（数组填充、随机选择、日期格式化等）\n    ├── 虚拟键盘生成与渲染\n    ├── 单词库（内置约5000个常见英语单词）\n    ├── 游戏状态管理（guess数组、按键统计、计时）\n    ├── 统计面板自动刷新（使用requestAnimationFrame）\n    ├── 事件绑定（键盘点击、物理按键、按钮操作）\n    └── 分享链接解析与Base64解码\n","text","",[89,321,317],{"__ignoreMap":319},[34,323,324,325],{"id":324,"class":12},"核心代码说明",[14,326,328,331],{"class":16,"href":327},"#核心代码说明",[19,329,23,324],{"className":330},[22],[19,332,28],{"ariaHidden":26,"tabIndex":27},[200,334,335,336],{"id":335,"class":12},"单词库",[14,337,339,342],{"class":16,"href":338},"#单词库",[19,340,23,335],{"className":341},[22],[19,343,28],{"ariaHidden":26,"tabIndex":27},[30,345,346,347,350],{},"变量",[89,348,349],{},"words","存储了约5000个英文单词（以逗号分隔的字符串）。新游戏时随机选取单词库中的单词。",[200,352,353,354],{"id":353,"class":12},"统计面板更新",[14,355,357,360],{"class":16,"href":356},"#统计面板更新",[19,358,23,353],{"className":359},[22],[19,361,28],{"ariaHidden":26,"tabIndex":27},[30,363,364,367,368,371],{},[89,365,366],{},"renderInfo","函数使用闭包缓存所有DOM元素，通过数据对象一次性更新。",[89,369,370],{},"updateInfo()","会每帧调用该函数，计算用时、速率、百分比等，并刷新面板。",[200,373,374,375],{"id":374,"class":12},"分享链接原理",[14,376,378,381],{"class":16,"href":377},"#分享链接原理",[19,379,23,374],{"className":380},[22],[19,382,28],{"ariaHidden":26,"tabIndex":27},[30,384,385,386,389,390,393,394,397,398,401],{},"点击“分享”时，",[89,387,388],{},"btoa(wordRaw)","将原始单词编码为Base64，拼接成",[89,391,392],{},"?w=xxx","形式的 URL。页面加载时，读取",[89,395,396],{},"window.location.search","，若存在",[89,399,400],{},"w","参数，尝试Base64解码后作为初始单词。",[34,403,404,405],{"id":404,"class":12},"自定义配置",[14,406,408,411],{"class":16,"href":407},"#自定义配置",[19,409,23,404],{"className":410},[22],[19,412,28],{"ariaHidden":26,"tabIndex":27},[200,414,415,416],{"id":415,"class":12},"修改单词库",[14,417,419,422],{"class":16,"href":418},"#修改单词库",[19,420,23,415],{"className":421},[22],[19,423,28],{"ariaHidden":26,"tabIndex":27},[30,425,426,427,429],{},"直接编辑代码中",[89,428,349],{},"数组，增加或替换为自己的单词列表。",[200,431,432,433],{"id":432,"class":12},"调整键盘布局",[14,434,436,439],{"class":16,"href":435},"#调整键盘布局",[19,437,23,432],{"className":438},[22],[19,440,28],{"ariaHidden":26,"tabIndex":27},[30,442,443,444,447],{},"修改",[89,445,446],{},"rows","数组，例如：",[313,449,453],{"className":450,"code":451,"language":452,"meta":319,"style":319},"language-js shiki shiki-themes dracula","var rows = [\"qwertyuiop\", \"asdfghjkl\", \"zxcvbnm,\"]; \u002F\u002F 逗号代表空按键，仅用作布局\n","js",[89,454,455],{"__ignoreMap":319},[19,456,459,463,467,470,473,477,481,483,486,488,491,493,495,497,500,502,505],{"class":457,"line":458},"line",1,[19,460,462],{"class":461},"s0Tla","var",[19,464,466],{"class":465},"sCdxs"," rows ",[19,468,469],{"class":461},"=",[19,471,472],{"class":465}," [",[19,474,476],{"class":475},"seVfx","\"",[19,478,480],{"class":479},"s-mGx","qwertyuiop",[19,482,476],{"class":475},[19,484,485],{"class":465},", ",[19,487,476],{"class":475},[19,489,490],{"class":479},"asdfghjkl",[19,492,476],{"class":475},[19,494,485],{"class":465},[19,496,476],{"class":475},[19,498,499],{"class":479},"zxcvbnm,",[19,501,476],{"class":475},[19,503,504],{"class":465},"]; ",[19,506,508],{"class":507},"shSDL","\u002F\u002F 逗号代表空按键，仅用作布局\n",[34,510,511,512],{"id":511,"class":12},"兼容性",[14,513,515,518],{"class":16,"href":514},"#兼容性",[19,516,23,511],{"className":517},[22],[19,519,28],{"ariaHidden":26,"tabIndex":27},[64,521,522,528,534],{},[67,523,524,527],{},[70,525,526],{},"桌面浏览器","：Chrome, Firefox, Edge, Safari",[67,529,530,533],{},[70,531,532],{},"移动端","：iOS Safari, Android Chrome",[67,535,536,539],{},[70,537,538],{},"IE兼容","：游戏核心逻辑基于ES5，但部分功能在IE中不支持，推荐使用现代浏览器。",[34,541,542,543],{"id":542,"class":12},"注意事项",[14,544,546,549],{"class":16,"href":545},"#注意事项",[19,547,23,542],{"className":548},[22],[19,550,28],{"ariaHidden":26,"tabIndex":27},[64,552,553,556,559],{},[67,554,555],{},"物理键盘输入会自动转为小写匹配，单词中的字母比较时不区分大小写。",[67,557,558],{},"游戏开始时，非字母字符（如标点、空格）会被自动视为“已猜”，不计入需要猜测的字母数。",[67,560,561],{},"“显示答案”按钮会直接揭示所有字母，游戏标记为胜利，不再接受新输入。",[563,564,565],"style",{},"html pre.shiki code .s0Tla, html code.shiki .s0Tla{--shiki-default:#FF79C6}html pre.shiki code .sCdxs, html code.shiki .sCdxs{--shiki-default:#F8F8F2}html pre.shiki code .seVfx, html code.shiki .seVfx{--shiki-default:#E9F284}html pre.shiki code .s-mGx, html code.shiki .s-mGx{--shiki-default:#F1FA8C}html pre.shiki code .shSDL, html code.shiki .shSDL{--shiki-default:#6272A4}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":319,"searchDepth":567,"depth":567,"links":568},2,[569,571,573,575,587,589,598,605,607],{"id":36,"depth":567,"text":570},"游戏截图章节游戏截图 §",{"id":54,"depth":567,"text":572},"核心功能特性章节核心功能特性 §",{"id":159,"depth":567,"text":574},"技术栈章节技术栈 §",{"id":190,"depth":567,"text":576,"children":577},"快速开始章节快速开始 §",[578,581,583,585],{"id":202,"depth":579,"text":580},3,"下载项目章节下载项目 §",{"id":220,"depth":579,"text":582},"运行游戏章节运行游戏 §",{"id":240,"depth":579,"text":584},"游戏规则章节游戏规则 §",{"id":289,"depth":579,"text":586},"分享单词章节分享单词 §",{"id":303,"depth":567,"text":588},"项目结构章节项目结构 §",{"id":324,"depth":567,"text":590,"children":591},"核心代码说明章节核心代码说明 §",[592,594,596],{"id":335,"depth":579,"text":593},"单词库章节单词库 §",{"id":353,"depth":579,"text":595},"统计面板更新章节统计面板更新 §",{"id":374,"depth":579,"text":597},"分享链接原理章节分享链接原理 §",{"id":404,"depth":567,"text":599,"children":600},"自定义配置章节自定义配置 §",[601,603],{"id":415,"depth":579,"text":602},"修改单词库章节修改单词库 §",{"id":432,"depth":579,"text":604},"调整键盘布局章节调整键盘布局 §",{"id":511,"depth":567,"text":606},"兼容性章节兼容性 §",{"id":542,"depth":567,"text":608},"注意事项章节注意事项 §","2026\u002F5\u002F20",[611,612,613],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。",[615],[616,617],"\u002Fraw\u002Fguess-the-word.html","下载","md",false,[621],[616,622],"体验",{},true,"\u002Farticles\u002Fguess-the-word",{"title":5,"description":627},[611,612,613],"guess-the-word","articles\u002Fguess-the-word",[631,634,637],[632,633],"lang","web",[635,636],"inspiration","original",[638,639],"content","entertainment","Shi426k8tyPvxzH1KrjbpoKv_B5Dnj7w8XRu7mw1zrw",1779278207578]
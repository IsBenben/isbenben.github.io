pth":568,"text":573},"游戏规则章节游戏规则 §",{"id":278,"depth":568,"text":575},"分享单词章节分享单词 §",{"id":292,"depth":556,"text":577},"项目结构章节项目结构 §",{"id":313,"depth":556,"text":579,"children":580},"核心代码说明章节核心代码说明 §",[581,583,585],{"id":324,"depth":568,"text":582},"单词库章节单词库 §",{"id":342,"depth":568,"text":584},"统计面板更新章节统计面板更新 §",{"id":363,"depth":568,"text":586},"分享链接原理章节分享链接原理 §",{"id":393,"depth":556,"text":588,"children":589},"自定义配置章节自定义配置 §",[590,592],{"id":404,"depth":568,"text":591},"修改单词库章节修改单词库 §",{"id":421,"depth":568,"text":593},"调整键盘布局章节调整键盘布局 §",{"id":500,"depth":556,"text":595},"兼容性章节兼容性 §",{"id":531,"depth":556,"text":597},"注意事项章节注意事项 §","2026\u002F5\u002F20",[600,601,602],"这是一个基于Web的猜词游戏，支持键盘输入字母，实时显示统计信息。","游戏内置约5000个单词库，可将当前单词编码为分享链接，实现单词的便捷传播与挑战。","页面采用响应式布局，适配PC与移动端，提供流畅的猜词体验。",[604],[605,606],"\u002Fraw\u002Fguess-the-word.html","下载","md",false,[610],[605,611],"体验",{},true,"\u002Farticles\u002Fguess-the-word",{"title":5,"description":616},[600,601,602],"guess-the-word","articles\u002Fguess-the-word",[620,623,626],[621,622],"lang","web",[624,625],"inspiration","original",[627,628],"content","entertainment","dZjezCncylAeiJ_ldyahWNUJfEJnw3wGAPzBFU6dSzI",1779597318457]
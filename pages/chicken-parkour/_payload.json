[{"data":1,"prerenderedAt":350},["ShallowReactive",2],{"article-\u002Fpages\u002Fchicken-parkour":3},{"id":4,"title":5,"body":6,"date":318,"description":319,"downloads":323,"extension":327,"hide":328,"links":329,"meta":333,"navigation":334,"path":335,"seo":336,"stem":338,"tags":339,"__hash__":349},"pages\u002Fpages\u002Fchicken-parkour.md","小鸡跑酷",{"type":7,"value":8,"toc":298},"minimark",[9,18,36,40,52,81,92,106,117,137,148,151,156,187,192,229,234,249,260,263,280,291],[10,11,5,13],"h1",{"id":5,"class":12},"section-heading",[14,15],"a",{"class":16,"href":17},"section-link","#小鸡跑酷",[19,20,21,22],"h2",{"id":21,"class":12},"介绍",[14,23,25,31],{"class":16,"href":24},"#介绍",[26,27,30],"span",{"className":28},[29],"visually-hidden","章节",[26,32,35],{"ariaHidden":33,"tabIndex":34},"true",-1," §",[37,38,39],"p",{},"小鸡跑酷是一款基于Scratch风格的横版跑酷游戏，玩家需要控制一只可爱的小鸡在不断滚动的背景中前进。",[41,42,43,44],"h3",{"id":43,"class":12},"核心机制",[14,45,47,50],{"class":16,"href":46},"#核心机制",[26,48,30],{"className":49},[29],[26,51,35],{"ariaHidden":33,"tabIndex":34},[53,54,55,63,69,75],"ul",{},[56,57,58,62],"li",{},[59,60,61],"strong",{},"背景滚动","：通过背景的连续滚动模拟小鸡的向前移动效果",[56,64,65,68],{},[59,66,67],{},"跳跃控制","：玩家按下空格键可以让小鸡跳跃，躲避地面障碍物",[56,70,71,74],{},[59,72,73],{},"重力系统","：游戏内置了重力模拟，小鸡跳跃后会自然下落，需要掌握好跳跃时机",[56,76,77,80],{},[59,78,79],{},"道具系统","：地图右侧会不断随机出现各种道具，碰到道具会获得或失去相应分数",[41,82,83,84],{"id":83,"class":12},"操作方式",[14,85,87,90],{"class":16,"href":86},"#操作方式",[26,88,30],{"className":89},[29],[26,91,35],{"ariaHidden":33,"tabIndex":34},[53,93,94,100],{},[56,95,96,99],{},[59,97,98],{},"空格键","：让小鸡跳跃",[56,101,102,105],{},[59,103,104],{},"点击按钮","：可以开始或结束游戏",[41,107,108,109],{"id":108,"class":12},"游戏特色",[14,110,112,115],{"class":16,"href":111},"#游戏特色",[26,113,30],{"className":114},[29],[26,116,35],{"ariaHidden":33,"tabIndex":34},[53,118,119,125,131],{},[56,120,121,124],{},[59,122,123],{},"Scratch风格","：采用经典的Scratch编程风格，画面简洁可爱",[56,126,127,130],{},[59,128,129],{},"简单易上手","：操作简单，点击即玩",[56,132,133,136],{},[59,134,135],{},"随机性","：道具的出现位置和类型具有随机性，每次游戏体验都不同",[19,138,139,140],{"id":139,"class":12},"道具",[14,141,143,146],{"class":16,"href":142},"#道具",[26,144,30],{"className":145},[29],[26,147,35],{"ariaHidden":33,"tabIndex":34},[37,149,150],{},"游戏中会出现各种道具，玩家需要根据道具类型决定是否收集：",[37,152,153],{},[59,154,155],{},"加分道具：",[53,157,158,169,178],{},[56,159,160,163,164,168],{},[59,161,162],{},"钻石","：",[165,166,167],"code",{},"+20","分 - 珍贵的加分道具，需要跳跃收集",[56,170,171,163,174,177],{},[59,172,173],{},"金币",[165,175,176],{},"+15","分 - 常见的高分道具",[56,179,180,163,183,186],{},[59,181,182],{},"鸡蛋",[165,184,185],{},"+10","分 - 基础的加分道具",[37,188,189],{},[59,190,191],{},"减分道具（需要躲避）：",[53,193,194,203,212,221],{},[56,195,196,163,199,202],{},[59,197,198],{},"毒药",[165,200,201],{},"-20","分 - 危险道具，会大幅减分",[56,204,205,163,208,211],{},[59,206,207],{},"坑",[165,209,210],{},"-15","分 - 地面陷阱，需要跳跃躲避",[56,213,214,163,217,220],{},[59,215,216],{},"刺猬",[165,218,219],{},"-10","分 - 会扎到小鸡受伤减分",[56,222,223,163,226,228],{},[59,224,225],{},"云朵",[165,227,219],{},"分 - 乌云下雨导致减分",[37,230,231],{},[59,232,233],{},"特殊道具：",[53,235,236],{},[56,237,238,241,242,244,245,248],{},[59,239,240],{},"盲盒","：随机",[165,243,210],{},"~",[165,246,247],{},"15","分 - 运气道具，可能加分也可能减分，适合喜欢冒险的玩家",[19,250,251,252],{"id":251,"class":12},"游戏技巧",[14,253,255,258],{"class":16,"href":254},"#游戏技巧",[26,256,30],{"className":257},[29],[26,259,35],{"ariaHidden":33,"tabIndex":34},[37,261,262],{},"想要获得更高分数，玩家需要掌握以下技巧：",[53,264,265,268,271,274,277],{},[56,266,267],{},"根据道具出现的频率调整跳跃节奏，既不能频繁跳跃浪费体力，也不能错过收集道具的机会",[56,269,270],{},"预判能力，提前观察道具类型，判断是否需要跳跃收集或躲避",[56,272,273],{},"优先收集钻石和金币等高分道具",[56,275,276],{},"坚决躲避毒药和坑等高危障碍",[56,278,279],{},"对于盲盒，根据当前分数决定是否冒险",[19,281,282,283],{"id":282,"class":12},"截图",[14,284,286,289],{"class":16,"href":285},"#截图",[26,287,30],{"className":288},[29],[26,290,35],{"ariaHidden":33,"tabIndex":34},[37,292,293],{},[294,295],"img",{"alt":296,"src":297},"小鸡跑酷游戏画面截图","\u002Fraw\u002Fchicken-pakour-screenshot.png",{"title":299,"searchDepth":300,"depth":301,"links":302},"",2,3,[303,312,314,316],{"id":21,"depth":300,"text":304,"children":305},"介绍章节 §",[306,308,310],{"id":43,"depth":301,"text":307},"核心机制章节 §",{"id":83,"depth":301,"text":309},"操作方式章节 §",{"id":108,"depth":301,"text":311},"游戏特色章节 §",{"id":139,"depth":300,"text":313},"道具章节 §",{"id":251,"depth":300,"text":315},"游戏技巧章节 §",{"id":282,"depth":300,"text":317},"截图章节 §","2025\u002F2\u002F10",[320,321,322],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。",[324],[325,326],"\u002Fraw\u002Fchicken-parkour.sb3","下载：游戏SB3","md",false,[330],[331,332],"\u002Fraw\u002Fchicken-parkour.html","体验游戏",{},true,"\u002Fpages\u002Fchicken-parkour",{"title":5,"description":337},[320,321,322],"pages\u002Fchicken-parkour",[340,343,346],[341,342],"lang","scratch3",[344,345],"inspiration","original",[347,348],"content","entertainment","tITyi6MiYFD0cQPcr4Sf5tu3BKsETdAvtyYnj4591fA",1781181638557]
decoration);}",{"title":300,"searchDepth":301,"depth":302,"links":529},[530,531],{"id":22,"depth":301,"text":305},{"id":509,"depth":301,"text":532},"游戏内截图章节 §","2025\u002F02\u002F09",[535,536,537],"在JavaScript中，==相等运算符有一些特殊的行为。","这个消消乐游戏利用了这一特点。","只要每个选择的相邻元素满足==判断为true，就可以消除。消除的越多得分越多。",[539],[540,327],"\u002Fraw\u002Foh-my-dear-js.sb3",[542,544],[543,333],"\u002Fraw\u002Foh-my-dear-js.html",[545,546],"https:\u002F\u002Fjs.wdn.md\u002F","原作品（Vue）",{},"\u002Fpages\u002Foh-my-dear-js",{"title":353,"description":550},[535,536,537],"pages\u002Foh-my-dear-js",[553,554,556],[342,343],[345,555],"adaptation",[348,349],"CpShq8Zr6ecJGpjwxr23PVgUWYPjdFvrXgGf7uQ4N_Y",{"id":559,"title":560,"body":561,"date":690,"description":691,"downloads":695,"extension":328,"hide":329,"links":699,"meta":702,"navigation":335,"path":703,"seo":704,"stem":706,"tags":707,"__hash__":711},"pages\u002Fpages\u002Fnumbers-eating-game.md","大数吃小数游戏",{"type":8,"value":562,"toc":677},[563,568,579,590,596,599,610,613,616,623,634,641,650,653,656,659,662,671],[11,564,560,565],{"id":560,"class":13},[15,566],{"class":17,"href":567},"#大数吃小数游戏",[20,569,570,571],{"id":570,"class":13},"游戏设定",[15,572,574,577],{"class":17,"href":573},"#游戏设定",[27,575,31],{"className":576},[30],[27,578,36],{"ariaHidden":34,"tabIndex":35},[42,580,581,582],{"id":581,"class":13},"基础规则",[15,583,585,588],{"class":17,"href":584},"#基础规则",[27,586,31],{"className":587},[30],[27,589,36],{"ariaHidden":34,"tabIndex":35},[38,591,592,593,595],{},"舞台一开始会刷新数字 ",[166,594,427],{},"，即你操控的数字。你通过方向键操控着数字上下左右移动。",[38,597,598],{},"你的数字如果碰到比它小的数字，就会“吃掉”它，并加上它的数值。但是，如果你的数字碰到比它大的数字，你就输了。",[42,600,601,602],{"id":601,"class":13},"数字生成",[15,603,605,608],{"class":17,"href":604},"#数字生成",[27,606,31],{"className":607},[30],[27,609,36],{"ariaHidden":34,"tabIndex":35},[38,611,612],{},"舞台上会从四面八方随机位置，按一定频率刷新刷新数字。有的数字大，有的数字小了，根据玩家数字大小动态调整。",[38,614,615],{},"数字会在随机位置，一定频率刷新，大小，。",[38,617,618,619,622],{},"数字包含包含简单数字和四则算式，即包含加法、减法、乘法、除法的简单算式（",[166,620,621],{},"+-*\u002F","），需要计算才能吃数字。算式逐步解锁，会随着你的数字越来越大，变得越来越难。",[20,624,625,626],{"id":625,"class":13},"操作方法",[15,627,629,632],{"class":17,"href":628},"#操作方法",[27,630,31],{"className":631},[30],[27,633,36],{"ariaHidden":34,"tabIndex":35},[38,635,636,637,640],{},"鼠标点击“Restart”（重启）开始游戏。使用",[166,638,639],{},"↑↓←→","方向键移动数字。",[20,642,252,643],{"id":252,"class":13},[15,644,645,648],{"class":17,"href":255},[27,646,31],{"className":647},[30],[27,649,36],{"ariaHidden":34,"tabIndex":35},[38,651,652],{},"在初期，玩家需要谨慎移动，避免冒险，快速积累初始数值。",[38,654,655],{},"中期，玩家需要主动出击，规划路线，尝试吃掉中等数字。",[38,657,658],{},"对于后期计算，玩家需要提升运算速度，并进行一定估算，才能吃掉正确的数字。",[38,660,661],{},"这个游戏是无尽模式的，挑战你的极限吧！",[20,663,283,664],{"id":283,"class":13},[15,665,666,669],{"class":17,"href":286},[27,667,31],{"className":668},[30],[27,670,36],{"ariaHidden":34,"tabIndex":35},[38,672,673],{},[295,674],{"alt":675,"src":676},"大数吃小数数学游戏画面截图","\u002Fraw\u002Fnumbers-eating-game-screenshot.png",{"title":300,"searchDepth":301,"depth":302,"links":678},[679,686,688,689],{"id":570,"depth":301,"text":680,"children":681},"游戏设定章节 §",[682,684],{"id":581,"depth":302,"text":683},"基础规则章节 §",{"id":601,"depth":302,"text":685},"数字生成章节 §",{"id":625,"depth":301,"text":687},"操作方法章节 §",{"id":252,"depth":301,"text":316},{"id":283,"depth":301,"text":318},"2025\u002F02\u002F17",[692,693,694],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！",[696],[697,698],"\u002Fraw\u002Fnumbers-eating-game.sb3","下载游戏SB3",[700],[701,333],"\u002Fraw\u002Fnumbers-eating-game.html",{},"\u002Fpages\u002Fnumbers-eating-game",{"title":560,"description":705},[692,693,694],"pages\u002Fnumbers-eating-game",[708,709,710],[342,343],[345,555],[348,349],"i44ZtrCd8y81I-LVIUQWODpgF-l4yRHVbW70Q01M0Ts",1782554825477]
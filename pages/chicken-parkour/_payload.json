[{"data":1,"prerenderedAt":712},["ShallowReactive",2],{"article-\u002Fpages\u002Fchicken-parkour":3},{"current":4,"prev":351,"next":558},{"id":5,"title":6,"body":7,"date":319,"description":320,"downloads":324,"extension":328,"hide":329,"links":330,"meta":334,"navigation":335,"path":336,"seo":337,"stem":339,"tags":340,"__hash__":350},"pages\u002Fpages\u002Fchicken-parkour.md","小鸡跑酷",{"type":8,"value":9,"toc":299},"minimark",[10,19,37,41,53,82,93,107,118,138,149,152,157,188,193,230,235,250,261,264,281,292],[11,12,6,14],"h1",{"id":6,"class":13},"section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#小鸡跑酷",[20,21,22,23],"h2",{"id":22,"class":13},"介绍",[15,24,26,32],{"class":17,"href":25},"#介绍",[27,28,31],"span",{"className":29},[30],"visually-hidden","章节",[27,33,36],{"ariaHidden":34,"tabIndex":35},"true",-1," §",[38,39,40],"p",{},"小鸡跑酷是一款基于Scratch风格的横版跑酷游戏，玩家需要控制一只可爱的小鸡在不断滚动的背景中前进。",[42,43,44,45],"h3",{"id":44,"class":13},"核心机制",[15,46,48,51],{"class":17,"href":47},"#核心机制",[27,49,31],{"className":50},[30],[27,52,36],{"ariaHidden":34,"tabIndex":35},[54,55,56,64,70,76],"ul",{},[57,58,59,63],"li",{},[60,61,62],"strong",{},"背景滚动","：通过背景的连续滚动模拟小鸡的向前移动效果",[57,65,66,69],{},[60,67,68],{},"跳跃控制","：玩家按下空格键可以让小鸡跳跃，躲避地面障碍物",[57,71,72,75],{},[60,73,74],{},"重力系统","：游戏内置了重力模拟，小鸡跳跃后会自然下落，需要掌握好跳跃时机",[57,77,78,81],{},[60,79,80],{},"道具系统","：地图右侧会不断随机出现各种道具，碰到道具会获得或失去相应分数",[42,83,84,85],{"id":84,"class":13},"操作方式",[15,86,88,91],{"class":17,"href":87},"#操作方式",[27,89,31],{"className":90},[30],[27,92,36],{"ariaHidden":34,"tabIndex":35},[54,94,95,101],{},[57,96,97,100],{},[60,98,99],{},"空格键","：让小鸡跳跃",[57,102,103,106],{},[60,104,105],{},"点击按钮","：可以开始或结束游戏",[42,108,109,110],{"id":109,"class":13},"游戏特色",[15,111,113,116],{"class":17,"href":112},"#游戏特色",[27,114,31],{"className":115},[30],[27,117,36],{"ariaHidden":34,"tabIndex":35},[54,119,120,126,132],{},[57,121,122,125],{},[60,123,124],{},"Scratch风格","：采用经典的Scratch编程风格，画面简洁可爱",[57,127,128,131],{},[60,129,130],{},"简单易上手","：操作简单，点击即玩",[57,133,134,137],{},[60,135,136],{},"随机性","：道具的出现位置和类型具有随机性，每次游戏体验都不同",[20,139,140,141],{"id":140,"class":13},"道具",[15,142,144,147],{"class":17,"href":143},"#道具",[27,145,31],{"className":146},[30],[27,148,36],{"ariaHidden":34,"tabIndex":35},[38,150,151],{},"游戏中会出现各种道具，玩家需要根据道具类型决定是否收集：",[38,153,154],{},[60,155,156],{},"加分道具：",[54,158,159,170,179],{},[57,160,161,164,165,169],{},[60,162,163],{},"钻石","：",[166,167,168],"code",{},"+20","分 - 珍贵的加分道具，需要跳跃收集",[57,171,172,164,175,178],{},[60,173,174],{},"金币",[166,176,177],{},"+15","分 - 常见的高分道具",[57,180,181,164,184,187],{},[60,182,183],{},"鸡蛋",[166,185,186],{},"+10","分 - 基础的加分道具",[38,189,190],{},[60,191,192],{},"减分道具（需要躲避）：",[54,194,195,204,213,222],{},[57,196,197,164,200,203],{},[60,198,199],{},"毒药",[166,201,202],{},"-20","分 - 危险道具，会大幅减分",[57,205,206,164,209,212],{},[60,207,208],{},"坑",[166,210,211],{},"-15","分 - 地面陷阱，需要跳跃躲避",[57,214,215,164,218,221],{},[60,216,217],{},"刺猬",[166,219,220],{},"-10","分 - 会扎到小鸡受伤减分",[57,223,224,164,227,229],{},[60,225,226],{},"云朵",[166,228,220],{},"分 - 乌云下雨导致减分",[38,231,232],{},[60,233,234],{},"特殊道具：",[54,236,237],{},[57,238,239,242,243,245,246,249],{},[60,240,241],{},"盲盒","：随机",[166,244,211],{},"~",[166,247,248],{},"15","分 - 运气道具，可能加分也可能减分，适合喜欢冒险的玩家",[20,251,252,253],{"id":252,"class":13},"游戏技巧",[15,254,256,259],{"class":17,"href":255},"#游戏技巧",[27,257,31],{"className":258},[30],[27,260,36],{"ariaHidden":34,"tabIndex":35},[38,262,263],{},"想要获得更高分数，玩家需要掌握以下技巧：",[54,265,266,269,272,275,278],{},[57,267,268],{},"根据道具出现的频率调整跳跃节奏，既不能频繁跳跃浪费体力，也不能错过收集道具的机会",[57,270,271],{},"预判能力，提前观察道具类型，判断是否需要跳跃收集或躲避",[57,273,274],{},"优先收集钻石和金币等高分道具",[57,276,277],{},"坚决躲避毒药和坑等高危障碍",[57,279,280],{},"对于盲盒，根据当前分数决定是否冒险",[20,282,283,284],{"id":283,"class":13},"截图",[15,285,287,290],{"class":17,"href":286},"#截图",[27,288,31],{"className":289},[30],[27,291,36],{"ariaHidden":34,"tabIndex":35},[38,293,294],{},[295,296],"img",{"alt":297,"src":298},"小鸡跑酷游戏画面截图","\u002Fraw\u002Fchicken-pakour-screenshot.png",{"title":300,"searchDepth":301,"depth":302,"links":303},"",2,3,[304,313,315,317],{"id":22,"depth":301,"text":305,"children":306},"介绍章节 §",[307,309,311],{"id":44,"depth":302,"text":308},"核心机制章节 §",{"id":84,"depth":302,"text":310},"操作方式章节 §",{"id":109,"depth":302,"text":312},"游戏特色章节 §",{"id":140,"depth":301,"text":314},"道具章节 §",{"id":252,"depth":301,"text":316},"游戏技巧章节 §",{"id":283,"depth":301,"text":318},"截图章节 §","2025\u002F02\u002F10",[321,322,323],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。",[325],[326,327],"\u002Fraw\u002Fchicken-parkour.sb3","下载：游戏SB3","md",false,[331],[332,333],"\u002Fraw\u002Fchicken-parkour.html","体验游戏",{},true,"\u002Fpages\u002Fchicken-parkour",{"title":6,"description":338},[321,322,323],"pages\u002Fchicken-parkour",[341,344,347],[342,343],"lang","scratch3",[345,346],"inspiration","original",[348,349],"content","entertainment","EdYW76_2qu1lQrwSV-3CcYYYbIi80bPBsLSHHTo26yU",{"id":352,"title":353,"body":354,"date":533,"description":534,"downloads":538,"extension":328,"hide":329,"links":541,"meta":547,"navigation":335,"path":548,"seo":549,"stem":551,"tags":552,"__hash__":557},"pages\u002Fpages\u002Foh-my-dear-js.md","Oh my dear JavaScript",{"type":8,"value":355,"toc":528},[356,362,371,374,381,471,479,493,500,507,518,524],[11,357,353,359],{"id":358,"class":13},"oh-my-dear-javascript",[15,360],{"class":17,"href":361},"#oh-my-dear-javascript",[20,363,22,364],{"id":22,"class":13},[15,365,366,369],{"class":17,"href":25},[27,367,31],{"className":368},[30],[27,370,36],{"ariaHidden":34,"tabIndex":35},[38,372,373],{},"这个游戏是一个Scratch消消乐游戏，改编了nice.js——js真值表消消乐。",[38,375,376,377,380],{},"在JavaScript中，",[166,378,379],{},"=="," 相等是再正常不过的运算符：",[382,383,387],"pre",{"className":384,"code":385,"language":386,"meta":300,"style":300},"language-js shiki shiki-themes one-dark-pro one-dark-pro one-light","[]==[] \u002F\u002F false\n[]==![] \u002F\u002F true\n[1]==true \u002F\u002F true\n[2]==true \u002F\u002F false\n[2]==false \u0
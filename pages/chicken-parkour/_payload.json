[{"data":1,"prerenderedAt":345},["ShallowReactive",2],{"article-chicken-parkour":3},{"id":4,"title":5,"body":6,"date":312,"description":313,"downloads":317,"extension":321,"hide":322,"links":323,"meta":327,"navigation":328,"path":329,"seo":330,"slug":332,"stem":333,"tags":334,"__hash__":344},"articles\u002Farticles\u002Fchicken-parkour.md","小鸡跑酷",{"type":7,"value":8,"toc":292},"minimark",[9,30,34,46,75,86,100,111,131,142,145,150,181,186,223,228,243,254,257,274,285],[10,11,12,14],"h2",{"id":12,"class":13},"介绍","section-heading",[15,16,19,25],"a",{"class":17,"href":18},"section-link","#介绍",[20,21,24,12],"span",{"className":22},[23],"visually-hidden","章节",[20,26,29],{"ariaHidden":27,"tabIndex":28},"true",-1," §",[31,32,33],"p",{},"小鸡跑酷是一款基于Scratch风格的横版跑酷游戏，玩家需要控制一只可爱的小鸡在不断滚动的背景中前进。",[35,36,37,38],"h3",{"id":37,"class":13},"核心机制",[15,39,41,44],{"class":17,"href":40},"#核心机制",[20,42,24,37],{"className":43},[23],[20,45,29],{"ariaHidden":27,"tabIndex":28},[47,48,49,57,63,69],"ul",{},[50,51,52,56],"li",{},[53,54,55],"strong",{},"背景滚动","：通过背景的连续滚动模拟小鸡的向前移动效果",[50,58,59,62],{},[53,60,61],{},"跳跃控制","：玩家按下空格键可以让小鸡跳跃，躲避地面障碍物",[50,64,65,68],{},[53,66,67],{},"重力系统","：游戏内置了重力模拟，小鸡跳跃后会自然下落，需要掌握好跳跃时机",[50,70,71,74],{},[53,72,73],{},"道具系统","：地图右侧会不断随机出现各种道具，碰到道具会获得或失去相应分数",[35,76,77,78],{"id":77,"class":13},"操作方式",[15,79,81,84],{"class":17,"href":80},"#操作方式",[20,82,24,77],{"className":83},[23],[20,85,29],{"ariaHidden":27,"tabIndex":28},[47,87,88,94],{},[50,89,90,93],{},[53,91,92],{},"空格键","：让小鸡跳跃",[50,95,96,99],{},[53,97,98],{},"点击按钮","：可以开始或结束游戏",[35,101,102,103],{"id":102,"class":13},"游戏特色",[15,104,106,109],{"class":17,"href":105},"#游戏特色",[20,107,24,102],{"className":108},[23],[20,110,29],{"ariaHidden":27,"tabIndex":28},[47,112,113,119,125],{},[50,114,115,118],{},[53,116,117],{},"Scratch风格","：采用经典的Scratch编程风格，画面简洁可爱",[50,120,121,124],{},[53,122,123],{},"简单易上手","：操作简单，点击即玩",[50,126,127,130],{},[53,128,129],{},"随机性","：道具的出现位置和类型具有随机性，每次游戏体验都不同",[10,132,133,134],{"id":133,"class":13},"道具",[15,135,137,140],{"class":17,"href":136},"#道具",[20,138,24,133],{"className":139},[23],[20,141,29],{"ariaHidden":27,"tabIndex":28},[31,143,144],{},"游戏中会出现各种道具，玩家需要根据道具类型决定是否收集：",[31,146,147],{},[53,148,149],{},"加分道具：",[47,151,152,163,172],{},[50,153,154,157,158,162],{},[53,155,156],{},"钻石","：",[159,160,161],"code",{},"+20","分 - 珍贵的加分道具，需要跳跃收集",[50,164,165,157,168,171],{},[53,166,167],{},"金币",[159,169,170],{},"+15","分 - 常见的高分道具",[50,173,174,157,177,180],{},[53,175,176],{},"鸡蛋",[159,178,179],{},"+10","分 - 基础的加分道具",[31,182,183],{},[53,184,185],{},"减分道具（需要躲避）：",[47,187,188,197,206,215],{},[50,189,190,157,193,196],{},[53,191,192],{},"毒药",[159,194,195],{},"-20","分 - 危险道具，会大幅减分",[50,198,199,157,202,205],{},[53,200,201],{},"坑",[159,203,204],{},"-15","分 - 地面陷阱，需要跳跃躲避",[50,207,208,157,211,214],{},[53,209,210],{},"刺猬",[159,212,213],{},"-10","分 - 会扎到小鸡受伤减分",[50,216,217,157,220,222],{},[53,218,219],{},"云朵",[159,221,213],{},"分 - 乌云下雨导致减分",[31,224,225],{},[53,226,227],{},"特殊道具：",[47,229,230],{},[50,231,232,235,236,238,239,242],{},[53,233,234],{},"盲盒","：随机",[159,237,204],{},"~",[159,240,241],{},"15","分 - 运气道具，可能加分也可能减分，适合喜欢冒险的玩家",[10,244,245,246],{"id":245,"class":13},"游戏技巧",[15,247,249,252],{"class":17,"href":248},"#游戏技巧",[20,250,24,245],{"className":251},[23],[20,253,29],{"ariaHidden":27,"tabIndex":28},[31,255,256],{},"想要获得更高分数，玩家需要掌握以下技巧：",[47,258,259,262,265,268,271],{},[50,260,261],{},"根据道具出现的频率调整跳跃节奏，既不能频繁跳跃浪费体力，也不能错过收集道具的机会",[50,263,264],{},"预判能力，提前观察道具类型，判断是否需要跳跃收集或躲避",[50,266,267],{},"优先收集钻石和金币等高分道具",[50,269,270],{},"坚决躲避毒药和坑等高危障碍",[50,272,273],{},"对于盲盒，根据当前分数决定是否冒险",[10,275,276,277],{"id":276,"class":13},"截图",[15,278,280,283],{"class":17,"href":279},"#截图",[20,281,24,276],{"className":282},[23],[20,284,29],{"ariaHidden":27,"tabIndex":28},[31,286,287],{},[288,289],"img",{"alt":290,"src":291},"小鸡跑酷游戏画面截图","\u002Fraw\u002Fchicken-pakour-screenshot.png",{"title":293,"searchDepth":294,"depth":294,"links":295},"",2,[296,306,308,310],{"id":12,"depth":294,"text":297,"children":298},"介绍章节介绍 §",[299,302,304],{"id":37,"depth":300,"text":301},3,"核心机制章节核心机制 §",{"id":77,"depth":300,"text":303},"操作方式章节操作方式 §",{"id":102,"depth":300,"text":305},"游戏特色章节游戏特色 §",{"id":133,"depth":294,"text":307},"道具章节道具 §",{"id":245,"depth":294,"text":309},"游戏技巧章节游戏技巧 §",{"id":276,"depth":294,"text":311},"截图章节截图 §","2025\u002F2\u002F10",[314,315,316],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。",[318],[319,320],"\u002Fraw\u002Fchicken-parkour.sb3","下载：游戏SB3","md",false,[324],[325,326],"\u002Fraw\u002Fchicken-parkour.html","体验游戏",{},true,"\u002Farticles\u002Fchicken-parkour",{"title":5,"description":331},[314,315,316],"chicken-parkour","articles\u002Fchicken-parkour",[335,338,341],[336,337],"lang","scratch3",[339,340],"inspiration","original",[342,343],"content","entertainment","pOpmQH-VDxMZc1_HznLApGGihSJ4tOrPZEHQoxZMsGw",1779597318666]
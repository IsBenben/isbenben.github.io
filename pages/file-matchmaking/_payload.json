ref":105},"#基础规则",[89,107,93],{"className":108},[92],[89,110,98],{"ariaHidden":96,"tabIndex":97},[20,112,113,114,117],{},"舞台一开始会刷新数字 ",[33,115,116],{},"1","，即你操控的数字。你通过方向键操控着数字上下左右移动。",[20,119,120],{},"你的数字如果碰到比它小的数字，就会“吃掉”它，并加上它的数值。但是，如果你的数字碰到比它大的数字，你就输了。",[100,122,123,124],{"id":123,"class":13},"数字生成",[15,125,127,130],{"class":17,"href":126},"#数字生成",[89,128,93],{"className":129},[92],[89,131,98],{"ariaHidden":96,"tabIndex":97},[20,133,134],{},"舞台上会从四面八方随机位置，按一定频率刷新刷新数字。有的数字大，有的数字小了，根据玩家数字大小动态调整。",[20,136,137],{},"数字会在随机位置，一定频率刷新，大小，。",[20,139,140,141,144],{},"数字包含包含简单数字和四则算式，即包含加法、减法、乘法、除法的简单算式（",[33,142,143],{},"+-*\u002F","），需要计算才能吃数字。算式逐步解锁，会随着你的数字越来越大，变得越来越难。",[82,146,147,148],{"id":147,"class":13},"操作方法",[15,149,151,154],{"class":17,"href":150},"#操作方法",[89,152,93],{"className":153},[92],[89,155,98],{"ariaHidden":96,"tabIndex":97},[20,157,158,159,162],{},"鼠标点击“Restart”（重启）开始游戏。使用",[33,160,161],{},"↑↓←→","方向键移动数字。",[82,164,165,166],{"id":165,"class":13},"游戏技巧",[15,167,169,172],{"class":17,"href":168},"#游戏技巧",[89,170,93],{"className":171},[92],[89,173,98],{"ariaHidden":96,"tabIndex":97},[20,175,176],{},"在初期，玩家需要谨慎移动，避免冒险，快速积累初始数值。",[20,178,179],{},"中期，玩家需要主动出击，规划路线，尝试吃掉中等数字。",[20,181,182],{},"对于后期计算，玩家需要提升运算速度，并进行一定估算，才能吃掉正确的数字。",[20,184,185],{},"这个游戏是无尽模式的，挑战你的极限吧！",[82,187,188,189],{"id":188,"class":13},"截图",[15,190,192,195],{"class":17,"href":191},"#截图",[89,193,93],{"className":194},[92],[89,196,98],{"ariaHidden":96,"tabIndex":97},[20,198,199],{},[200,201],"img",{"alt":202,"src":203},"大数吃小数数学游戏画面截图","\u002Fraw\u002Fnumbers-eating-game-screenshot.png",{"title":38,"searchDepth":39,"depth":40,"links":205},[206,213,215,217],{"id":84,"depth":39,"text":207,"children":208},"游戏设定章节 §",[209,211],{"id":102,"depth":40,"text":210},"基础规则章节 §",{"id":123,"depth":40,"text":212},"数字生成章节 §",{"id":147,"depth":39,"text":214},"操作方法章节 §",{"id":165,"depth":39,"text":216},"游戏技巧章节 §",{"id":188,"depth":39,"text":218},"截图章节 §","2025\u002F02\u002F17",[221,222,223],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！",[225],[226,227],"\u002Fraw\u002Fnumbers-eating-game.sb3","下载游戏SB3",[229],[230,231],"\u002Fraw\u002Fnumbers-eating-game.html","体验游戏",{},"\u002Fpages\u002Fnumbers-eating-game",{"title":73,"description":235},[221,222,223],"pages\u002Fnumbers-eating-game",[238,240,242],[62,239],"scratch3",[65,241],"adaptation",[68,69],"i44ZtrCd8y81I-LVIUQWODpgF-l4yRHVbW70Q01M0Ts",{"id":245,"title":246,"body":247,"date":371,"description":372,"downloads":375,"extension":48,"hide":49,"links":379,"meta":384,"navigation":55,"path":385,"seo":386,"stem":388,"tags":389,"__hash__":394},"pages\u002Fpages\u002Fword-solitaire.md","单词接龙",{"type":8,"value":248,"toc":363},[249,254,257,268,297,300,309,318,321,324,331,342,345,348,357],[11,250,246,251],{"id":246,"class":13},[15,252],{"class":17,"href":253},"#单词接龙",[20,255,256],{},"单词接龙是一个经典的文字游戏，玩家需要根据前一个单词的尾字母，找到一个以该字母开头的新单词。这个网页版游戏支持 AI 辅助和单词释义查询。",[82,258,259,260],{"id":259,"class":13},"基本规则",[15,261,263,266],{"class":17,"href":262},"#基本规则",[89,264,93],{"className":265},[92],[89,267,98],{"ariaHidden":96,"tabIndex":97},[269,270,271,279,285,291],"ul",{},[272,273,274,278],"li",{},[275,276,277],"strong",{},"首尾相接","：新单词的首字母需要和前一个单词的尾字母完全相同。",[272,280,281,284],{},[275,282,283],{},"单词有效","：单词必须在游戏字典中，否则无效。",[272,286,287,290],{},[275,288,289],{},"无重复","：同一个单词在一轮游戏中不能重复使用。",[272,292,293,296],{},[275,294,295],{},"大小写敏感","：只有小写字母被接受。",[20,298,299],{},"示例如下：",[301,302,307],"pre",{"className":303,"code":305,"language":306},[304],"language-text","apple->elephant->tiger->rabbit\n  ->monkey（首尾不相接，无效）\n  ->tiger (重复，无效)\n  ->ttt（不在字典中，无效）\n  ->TURKEY（大小写错误，无效）\n  ->turkey（正确接龙）\n","text",[33,308,305],{"__ignoreMap":38},[82,310,147,311],{"id":147,"class":13},[15,312,313,316],{"class":17,"href":150},[89,314,93],{"className":315},[92],[89,317,98],{"ariaHidden":96,"tabIndex":97},[20,319,320],{},"输入框中输入单词即开始。若没有单词可接龙，会自动显示消息。",[20,322,323],{},"在游戏过程中，将鼠标放在单词上，可查看单词的意思。",[20,325,326,327,330],{},"如果不会，可以点击“询问AI”进行 ",[33,328,329],{},"AI"," 辅助，基于输入匹配单词。",[82,332,333,334],{"id":333,"class":13},"游戏特色",[15,335,337,340],{"class":17,"href":336},"#游戏特色",[89,338,93],{"className":339},[92],[89,341,98],{"ariaHidden":96,"tabIndex":97},[20,343,344],{},"词汇库支持约15000词接龙和释义查询，涵盖基础词汇、学术词汇等，自动验证输入的单词是否有效。",[20,346,347],{},"释义涵盖基本释义、词性、常见短语对照，可配合玩家理解、学习单词。",[82,349,188,350],{"id":188,"class":13},[15,351,352,355],{"class":17,"href":191},[89,353,93],{"className":354},[92],[89,356,98],{"ariaHidden":96,"tabIndex":97},[20,358,359],{},[200,360],{"alt":361,"src":362},"单词接龙学习游戏界面","\u002Fraw\u002Fword-solitaire-screenshot.png",{"title":38,"searchDepth":39,"depth":40,"links":364},[365,367,368,370],{"id":259,"depth":39,"text":366},"基本规则章节 §",{"id":147,"depth":39,"text":214},{"id":333,"depth":39,"text":369},"游戏特色章节 §",{"id":188,"depth":39,"text":218},"2025\u002F03\u002F07",[373,374],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。",[376],[377,378],"\u002Fraw\u002Fword-solitaire.html","下载",[380,382],[381,53],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002Fword-solitaire.html",[377,383],"体验",{},"\u002Fpages\u002Fword-solitaire",{"title":246,"description":387},[373,374],"pages\u002Fword-solitaire",[390,392,393],[62,391],"web",[65,66],[68,69],"WhyKIGqBc04pXuzIbYkSifl8lC7QtZ9eNBVB4YDljnk",1782554825433]
[{"data":1,"prerenderedAt":556},["ShallowReactive",2],{"article-\u002Fpages\u002Fnumbers-eating-game":3},{"current":4,"prev":194,"next":507},{"id":5,"title":6,"body":7,"date":162,"description":163,"downloads":167,"extension":171,"hide":172,"links":173,"meta":177,"navigation":178,"path":179,"seo":180,"stem":182,"tags":183,"__hash__":193},"pages\u002Fpages\u002Fnumbers-eating-game.md","大数吃小数游戏",{"type":8,"value":9,"toc":144},"minimark",[10,19,37,49,58,61,72,75,78,85,96,103,114,117,120,123,126,137],[11,12,6,14],"h1",{"id":6,"class":13},"section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#大数吃小数游戏",[20,21,22,23],"h2",{"id":22,"class":13},"游戏设定",[15,24,26,32],{"class":17,"href":25},"#游戏设定",[27,28,31],"span",{"className":29},[30],"visually-hidden","章节",[27,33,36],{"ariaHidden":34,"tabIndex":35},"true",-1," §",[38,39,40,41],"h3",{"id":40,"class":13},"基础规则",[15,42,44,47],{"class":17,"href":43},"#基础规则",[27,45,31],{"className":46},[30],[27,48,36],{"ariaHidden":34,"tabIndex":35},[50,51,52,53,57],"p",{},"舞台一开始会刷新数字 ",[54,55,56],"code",{},"1","，即你操控的数字。你通过方向键操控着数字上下左右移动。",[50,59,60],{},"你的数字如果碰到比它小的数字，就会“吃掉”它，并加上它的数值。但是，如果你的数字碰到比它大的数字，你就输了。",[38,62,63,64],{"id":63,"class":13},"数字生成",[15,65,67,70],{"class":17,"href":66},"#数字生成",[27,68,31],{"className":69},[30],[27,71,36],{"ariaHidden":34,"tabIndex":35},[50,73,74],{},"舞台上会从四面八方随机位置，按一定频率刷新刷新数字。有的数字大，有的数字小了，根据玩家数字大小动态调整。",[50,76,77],{},"数字会在随机位置，一定频率刷新，大小，。",[50,79,80,81,84],{},"数字包含包含简单数字和四则算式，即包含加法、减法、乘法、除法的简单算式（",[54,82,83],{},"+-*\u002F","），需要计算才能吃数字。算式逐步解锁，会随着你的数字越来越大，变得越来越难。",[20,86,87,88],{"id":87,"class":13},"操作方法",[15,89,91,94],{"class":17,"href":90},"#操作方法",[27,92,31],{"className":93},[30],[27,95,36],{"ariaHidden":34,"tabIndex":35},[50,97,98,99,102],{},"鼠标点击“Restart”（重启）开始游戏。使用",[54,100,101],{},"↑↓←→","方向键移动数字。",[20,104,105,106],{"id":105,"class":13},"游戏技巧",[15,107,109,112],{"class":17,"href":108},"#游戏技巧",[27,110,31],{"className":111},[30],[27,113,36],{"ariaHidden":34,"tabIndex":35},[50,115,116],{},"在初期，玩家需要谨慎移动，避免冒险，快速积累初始数值。",[50,118,119],{},"中期，玩家需要主动出击，规划路线，尝试吃掉中等数字。",[50,121,122],{},"对于后期计算，玩家需要提升运算速度，并进行一定估算，才能吃掉正确的数字。",[50,124,125],{},"这个游戏是无尽模式的，挑战你的极限吧！",[20,127,128,129],{"id":128,"class":13},"截图",[15,130,132,135],{"class":17,"href":131},"#截图",[27,133,31],{"className":134},[30],[27,136,36],{"ariaHidden":34,"tabIndex":35},[50,138,139],{},[140,141],"img",{"alt":142,"src":143},"大数吃小数数学游戏画面截图","\u002Fraw\u002Fnumbers-eating-game-screenshot.png",{"title":145,"searchDepth":146,"depth":147,"links":148},"",2,3,[149,156,158,160],{"id":22,"depth":146,"text":150,"children":151},"游戏设定章节 §",[152,154],{"id":40,"depth":147,"text":153},"基础规则章节 §",{"id":63,"depth":147,"text":155},"数字生成章节 §",{"id":87,"depth":146,"text":157},"操作方法章节 §",{"id":105,"depth":146,"text":159},"游戏技巧章节 §",{"id":128,"depth":146,"text":161},"截图章节 §","2025\u002F02\u002F17",[164,165,166],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！",[168],[169,170],"\u002Fraw\u002Fnumbers-eating-game.sb3","下载游戏SB3","md",false,[174],[175,176],"\u002Fraw\u002Fnumbers-eating-game.html","体验游戏",{},true,"\u002Fpages\u002Fnumbers-eating-game",{"title":6,"description":181},[164,165,166],"pages\u002Fnumbers-eating-game",[184,187,190],[185,186],"lang","scratch3",[188,189],"inspiration","adaptation",[191,192],"content","entertainment","i44ZtrCd8y81I-LVIUQWODpgF-l4yRHVbW70Q01M0Ts",{"id":195,"title":196,"body":197,"date":484,"description":485,"downloads":489,"extension":171,"hide":172,"links":493,"meta":496,"navigation":178,"path":497,"seo":498,"stem":500,"tags":501,"__hash__":506},"pages\u002Fpages\u002Fchicken-parkour.md","小鸡跑酷",{"type":8,"value":198,"toc":469},[199,204,215,218,229,258,269,283,294,314,325,328,333,363,368,405,410,425,434,437,454,463],[11,200,196,201],{"id":196,"class":13},[15,202],{"class":17,"href":203},"#小鸡跑酷",[20,205,206,207],{"id":206,"class":13},"介绍",[15,208,210,213],{"class":17,"href":209},"#介绍",[27,211,31],{"className":212},[30],[27,214,36],{"ariaHidden":34,"tabIndex":35},[50,216,217],{},"小鸡跑酷是一款基于Scratch风格的横版跑酷游戏，玩家需要控制一只可爱的小鸡在不断滚动的背景中前进。",[38,219,220,221],{"id":220,"class":13},"核心机制",[15,222,224,227],{"class":17,"href":223},"#核心机制",[27,225,31],{"className":226},[30],[27,228,36],{"ariaHidden":34,"tabIndex":35},[230,231,232,240,246,252],"ul",{},[233,234,235,239],"li",{},[236,237,238],"strong",{},"背景滚动","：通过背景的连续滚动模拟小鸡的向前移动效果",[233,241,242,245],{},[236,243,244],{},"跳跃控制","：玩家按下空格键可以让小鸡跳跃，躲避地面障碍物",[233,247,248,251],{},[236,249,250],{},"重力系统","：游戏内置了重力模拟，小鸡跳跃后会自然下落，需要掌握好跳跃时机",[233,253,254,257],{},[236,255,256],{},"道具系统","：地图右侧会不断随机出现各种道具，碰到道具会获得或失去相应分数",[38,259,260,261],{"id":260,"class":13},"操作方式",[15,262,264,267],{"class":17,"href":263},"#操作方式",[27,265,31],{"className":266},[30],[27,268,36],{"ariaHidden":34,"tabIndex":35},[230,270,271,277],{},[233,272,273,276],{},[236,274,275],{},"空格键","：让小鸡跳跃",[233,278,279,282],{},[236,280,281],{},"点击按钮","：可以开始或结束游戏",[38,284,285,286],{"id":285,"class":13},"游戏特色",[15,287,289,292],{"class":17,"href":288},"#游戏特色",[27,290,31],{"className":291},[30],[27,293,36],{"ariaHidden":34,"tabIndex":35},[230,295,296,302,308],{},[233,297,298,301],{},[236,299,300],{},"Scratch风格","：采用经典的Scratch编程风格，画面简洁可爱",[233,303,304,307],{},[236,305,306],{},"简单易上手","：操作简单，点击即玩",[233,309,310,313],{},[236,311,312],{},"随机性","：道具的出现位置和类型具有随机性，每次游戏体验都不同",[20,315,316,317],{"id":316,"class":13},"道具",[15,318,320,323],{"class":17,"href":319},"#道具",[27,321,31],{"className":322},[30],[27,324,36],{"ariaHidden":34,"tabIndex":35},[50,326,327],{},"游戏中会出现各种道具，玩家需要根据道具类型决定是否收集：",[50,329,330],{},[236,331,332],{},"加分道具：",[230,334,335,345,354],{},[233,336,337,340,341,344],{},[236,338,339],{},"钻石","：",[54,342,343],{},"+20","分 - 珍贵的加分道具，需要跳跃收集",[233,346,347,340,350,353],{},[236,348,349],{},"金币",[54,351,352],{},"+15","分 - 常见的高分道具",[233,355,356,340,359,362],{},[236,357,358],{},"鸡蛋",[54,360,361],{},"+10","分 - 基础的加分道具",[50,364,365],{},[236,366,367],{},"减分道具（需要躲避）：",[230,369,370,379,388,397],{},[233,371,372,340,375,378],{},[236,373,374],{},"毒药",[54,376,377],{},"-20","分 - 危险道具，会大幅减分",[233,380,381,340,384,387],{},[236,382,383],{},"坑",[54,385,386],{},"-15","分 - 地面陷阱，需要跳跃躲避",[233,389,390,340,393,396],{},[236,391,392],{},"刺猬",[54,394,395],{},"-10","分 - 会扎到小鸡受伤减分",[233,398,399,340,402,404],{},[236,400,401],{},"云朵",[54,403,395],{},"分 - 乌云下雨导致减分",[50,406,407],{},[236,408,409],{},"特殊道具：",[230,411,412],{},[233,413,414,417,418,420,421,424],{},[236,415,416],{},"盲盒","：随机",[54,419,386],{},"~",[54,422,423],{},"15","分 - 运气道具，可能加分也可能减分，适合喜欢冒险的玩家",[20,426,105,427],{"id":105,"class":13},[15,428,429,432],{"class":17,"href":108},[27,430,31],{"className":431},[30],[27,433,36],{"ariaHidden":34,"tabIndex":35},[50,435,436],{},"想要获得更高分数，玩家需要掌握以下技巧：",[230,438,439,442,445,448,451],{},[233,440,441],{},"根据道具出现的频率调整跳跃节奏，既不能频繁跳跃浪费体力，也不能错过收集道具的机会",[233,443,444],{},"预判能力，提前观察道具类型，判断是否需要跳跃收集或躲避",[233,446,447],{},"优先收集钻石和金币等高分道具",[233,449,450],{},"坚决躲避毒药和坑等高危障碍",[233,452,453],{},"对于盲盒，根据当前分数决定是否冒险",[20,455,128,456],{"id":128,"class":13},[15,457,458,461],{"class":17,"href":131},[27,459,31],{"className":460},[30],[27,462,36],{"ariaHidden":34,"tabIndex":35},[50,464,465],{},[140,466],{"alt":467,"src":468},"小鸡跑酷游戏画面截图","\u002Fraw\u002Fchicken-pakour-screenshot.png",{"title":145,"searchDepth":146,"depth":147,"links":470},[471,480,482,483],{"id":206,"depth":146,"text":472,"children":473},"介绍章节 §",[474,476,478],{"id":220,"depth":147,"text":475},"核心机制章节 §",{"id":260,"depth":147,"text":477},"操作方式章节 §",{"id":285,"depth":147,"text":479},"游戏特色章节 §",{"id":316,"depth":146,"text":481},"道具章节 §",{"id":105,"depth":146,"text":159},{"id":128,"depth":146,"text":161},"2025\u002F02\u002F10",[486,487,488],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。",[490],[491,492],"\u002Fraw\u002Fchicken-parkour.sb3","下载：游戏SB3",[494],[495,176],"\u002Fraw\u002Fchicken-parkour.html",{},"\u002Fpages\u002Fchicken-parkour",{"title":196,"description":499},[486,487,488],"pages\u002Fchicken-parkour",[502,503,505],[185,186],[188,504],"o
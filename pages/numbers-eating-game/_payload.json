[{"data":1,"prerenderedAt":188},["ShallowReactive",2],{"article-numbers-eating-game":3},{"id":4,"title":5,"body":6,"date":155,"description":156,"downloads":160,"extension":164,"hide":165,"links":166,"meta":170,"navigation":171,"path":172,"seo":173,"slug":175,"stem":176,"tags":177,"__hash__":187},"articles\u002Farticles\u002Fnumbers-eating-game.md","大数吃小数游戏",{"type":7,"value":8,"toc":137},"minimark",[9,30,42,51,54,65,68,71,78,89,96,107,110,113,116,119,130],[10,11,12,14],"h2",{"id":12,"class":13},"游戏设定","section-heading",[15,16,19,25],"a",{"class":17,"href":18},"section-link","#游戏设定",[20,21,24,12],"span",{"className":22},[23],"visually-hidden","章节",[20,26,29],{"ariaHidden":27,"tabIndex":28},"true",-1," §",[31,32,33,34],"h3",{"id":33,"class":13},"基础规则",[15,35,37,40],{"class":17,"href":36},"#基础规则",[20,38,24,33],{"className":39},[23],[20,41,29],{"ariaHidden":27,"tabIndex":28},[43,44,45,46,50],"p",{},"舞台一开始会刷新数字 ",[47,48,49],"code",{},"1","，即你操控的数字。你通过方向键操控着数字上下左右移动。",[43,52,53],{},"你的数字如果碰到比它小的数字，就会“吃掉”它，并加上它的数值。但是，如果你的数字碰到比它大的数字，你就输了。",[31,55,56,57],{"id":56,"class":13},"数字生成",[15,58,60,63],{"class":17,"href":59},"#数字生成",[20,61,24,56],{"className":62},[23],[20,64,29],{"ariaHidden":27,"tabIndex":28},[43,66,67],{},"舞台上会从四面八方随机位置，按一定频率刷新刷新数字。有的数字大，有的数字小了，根据玩家数字大小动态调整。",[43,69,70],{},"数字会在随机位置，一定频率刷新，大小，。",[43,72,73,74,77],{},"数字包含包含简单数字和四则算式，即包含加法、减法、乘法、除法的简单算式（",[47,75,76],{},"+-*\u002F","），需要计算才能吃数字。算式逐步解锁，会随着你的数字越来越大，变得越来越难。",[10,79,80,81],{"id":80,"class":13},"操作方法",[15,82,84,87],{"class":17,"href":83},"#操作方法",[20,85,24,80],{"className":86},[23],[20,88,29],{"ariaHidden":27,"tabIndex":28},[43,90,91,92,95],{},"鼠标点击“Restart”（重启）开始游戏。使用",[47,93,94],{},"↑↓←→","方向键移动数字。",[10,97,98,99],{"id":98,"class":13},"游戏技巧",[15,100,102,105],{"class":17,"href":101},"#游戏技巧",[20,103,24,98],{"className":104},[23],[20,106,29],{"ariaHidden":27,"tabIndex":28},[43,108,109],{},"在初期，玩家需要谨慎移动，避免冒险，快速积累初始数值。",[43,111,112],{},"中期，玩家需要主动出击，规划路线，尝试吃掉中等数字。",[43,114,115],{},"对于后期计算，玩家需要提升运算速度，并进行一定估算，才能吃掉正确的数字。",[43,117,118],{},"这个游戏是无尽模式的，挑战你的极限吧！",[10,120,121,122],{"id":121,"class":13},"截图",[15,123,125,128],{"class":17,"href":124},"#截图",[20,126,24,121],{"className":127},[23],[20,129,29],{"ariaHidden":27,"tabIndex":28},[43,131,132],{},[133,134],"img",{"alt":135,"src":136},"大数吃小数数学游戏画面截图","\u002Fraw\u002Fnumbers-eating-game-screenshot.png",{"title":138,"searchDepth":139,"depth":139,"links":140},"",2,[141,149,151,153],{"id":12,"depth":139,"text":142,"children":143},"游戏设定章节游戏设定 §",[144,147],{"id":33,"depth":145,"text":146},3,"基础规则章节基础规则 §",{"id":56,"depth":145,"text":148},"数字生成章节数字生成 §",{"id":80,"depth":139,"text":150},"操作方法章节操作方法 §",{"id":98,"depth":139,"text":152},"游戏技巧章节游戏技巧 §",{"id":121,"depth":139,"text":154},"截图章节截图 §","2025\u002F2\u002F17",[157,158,159],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！",[161],[162,163],"\u002Fraw\u002Fnumbers-eating-game.sb3","下载游戏SB3","md",false,[167],[168,169],"\u002Fraw\u002Fnumbers-eating-game.html","体验游戏",{},true,"\u002Farticles\u002Fnumbers-eating-game",{"title":5,"description":174},[157,158,159],"numbers-eating-game","articles\u002Fnumbers-eating-game",[178,181,184],[179,180],"lang","scratch3",[182,183],"inspiration","adaptation",[185,186],"content","entertainment","P3seKMBfN7WvEFbre5B_ZplC7XPO9G-SeacPOUGKabE",1778904103979]
[{"data":1,"prerenderedAt":193},["ShallowReactive",2],{"article-\u002Fpages\u002Fnumbers-eating-game":3},{"id":4,"title":5,"body":6,"date":161,"description":162,"downloads":166,"extension":170,"hide":171,"links":172,"meta":176,"navigation":177,"path":178,"seo":179,"stem":181,"tags":182,"__hash__":192},"pages\u002Fpages\u002Fnumbers-eating-game.md","大数吃小数游戏",{"type":7,"value":8,"toc":143},"minimark",[9,18,36,48,57,60,71,74,77,84,95,102,113,116,119,122,125,136],[10,11,5,13],"h1",{"id":5,"class":12},"section-heading",[14,15],"a",{"class":16,"href":17},"section-link","#大数吃小数游戏",[19,20,21,22],"h2",{"id":21,"class":12},"游戏设定",[14,23,25,31],{"class":16,"href":24},"#游戏设定",[26,27,30],"span",{"className":28},[29],"visually-hidden","章节",[26,32,35],{"ariaHidden":33,"tabIndex":34},"true",-1," §",[37,38,39,40],"h3",{"id":39,"class":12},"基础规则",[14,41,43,46],{"class":16,"href":42},"#基础规则",[26,44,30],{"className":45},[29],[26,47,35],{"ariaHidden":33,"tabIndex":34},[49,50,51,52,56],"p",{},"舞台一开始会刷新数字 ",[53,54,55],"code",{},"1","，即你操控的数字。你通过方向键操控着数字上下左右移动。",[49,58,59],{},"你的数字如果碰到比它小的数字，就会“吃掉”它，并加上它的数值。但是，如果你的数字碰到比它大的数字，你就输了。",[37,61,62,63],{"id":62,"class":12},"数字生成",[14,64,66,69],{"class":16,"href":65},"#数字生成",[26,67,30],{"className":68},[29],[26,70,35],{"ariaHidden":33,"tabIndex":34},[49,72,73],{},"舞台上会从四面八方随机位置，按一定频率刷新刷新数字。有的数字大，有的数字小了，根据玩家数字大小动态调整。",[49,75,76],{},"数字会在随机位置，一定频率刷新，大小，。",[49,78,79,80,83],{},"数字包含包含简单数字和四则算式，即包含加法、减法、乘法、除法的简单算式（",[53,81,82],{},"+-*\u002F","），需要计算才能吃数字。算式逐步解锁，会随着你的数字越来越大，变得越来越难。",[19,85,86,87],{"id":86,"class":12},"操作方法",[14,88,90,93],{"class":16,"href":89},"#操作方法",[26,91,30],{"className":92},[29],[26,94,35],{"ariaHidden":33,"tabIndex":34},[49,96,97,98,101],{},"鼠标点击“Restart”（重启）开始游戏。使用",[53,99,100],{},"↑↓←→","方向键移动数字。",[19,103,104,105],{"id":104,"class":12},"游戏技巧",[14,106,108,111],{"class":16,"href":107},"#游戏技巧",[26,109,30],{"className":110},[29],[26,112,35],{"ariaHidden":33,"tabIndex":34},[49,114,115],{},"在初期，玩家需要谨慎移动，避免冒险，快速积累初始数值。",[49,117,118],{},"中期，玩家需要主动出击，规划路线，尝试吃掉中等数字。",[49,120,121],{},"对于后期计算，玩家需要提升运算速度，并进行一定估算，才能吃掉正确的数字。",[49,123,124],{},"这个游戏是无尽模式的，挑战你的极限吧！",[19,126,127,128],{"id":127,"class":12},"截图",[14,129,131,134],{"class":16,"href":130},"#截图",[26,132,30],{"className":133},[29],[26,135,35],{"ariaHidden":33,"tabIndex":34},[49,137,138],{},[139,140],"img",{"alt":141,"src":142},"大数吃小数数学游戏画面截图","\u002Fraw\u002Fnumbers-eating-game-screenshot.png",{"title":144,"searchDepth":145,"depth":146,"links":147},"",2,3,[148,155,157,159],{"id":21,"depth":145,"text":149,"children":150},"游戏设定章节 §",[151,153],{"id":39,"depth":146,"text":152},"基础规则章节 §",{"id":62,"depth":146,"text":154},"数字生成章节 §",{"id":86,"depth":145,"text":156},"操作方法章节 §",{"id":104,"depth":145,"text":158},"游戏技巧章节 §",{"id":127,"depth":145,"text":160},"截图章节 §","2025\u002F2\u002F17",[163,164,165],"你通过↑↓←→方向键操控着数字1。舞台上随机刷新数字。","这个数字碰到比它小的数字就会吃掉它，并加上它的数值。","游戏后期还会解锁+-*\u002F和更大的数字！挑战极限！",[167],[168,169],"\u002Fraw\u002Fnumbers-eating-game.sb3","下载游戏SB3","md",false,[173],[174,175],"\u002Fraw\u002Fnumbers-eating-game.html","体验游戏",{},true,"\u002Fpages\u002Fnumbers-eating-game",{"title":5,"description":180},[163,164,165],"pages\u002Fnumbers-eating-game",[183,186,189],[184,185],"lang","scratch3",[187,188],"inspiration","adaptation",[190,191],"content","entertainment","tVFX7_Cey8tDCws81msoxxIk5h2BVfRwU3IeGHXerAM",1781182081889]
[{"data":1,"prerenderedAt":796},["ShallowReactive",2],{"article-\u002Fpages\u002Flife-game":3},{"current":4,"prev":242,"next":534},{"id":5,"title":6,"body":7,"date":204,"description":205,"downloads":209,"extension":216,"hide":217,"links":218,"meta":225,"navigation":226,"path":227,"seo":228,"stem":230,"tags":231,"__hash__":241},"pages\u002Fpages\u002Flife-game.md","Scratch生命游戏",{"type":8,"value":9,"toc":191},"minimark",[10,20,38,42,50,62,65,124,136,146,149,160,167,178,185],[11,12,6,15],"h1",{"id":13,"class":14},"scratch生命游戏","section-heading",[16,17],"a",{"class":18,"href":19},"section-link","#scratch生命游戏",[21,22,23,24],"h2",{"id":23,"class":14},"生命游戏介绍",[16,25,27,33],{"class":18,"href":26},"#生命游戏介绍",[28,29,32],"span",{"className":30},[31],"visually-hidden","章节",[28,34,37],{"ariaHidden":35,"tabIndex":36},"true",-1," §",[39,40,41],"p",{},"生命游戏由英国数学家康威于1970年发明。它在一个二维方格世界中模拟细胞的生死状态，细胞的存活与否取决于周围相邻细胞的数量。具体规则包括：如果一个细胞周围活细胞过少，它会死亡；如果活细胞过多，它也会死亡；只有在适当的邻居数量下，细胞才能存活。",[39,43,44,45,49],{},"本程序模拟了生命游戏的一种规则：",[46,47,48],"code",{},"B3\u002FS23","。意思是，若细胞周围有3个细胞，则会繁殖新细胞；而若细胞周围有2或3个细胞，则会保持当前状态。需使用TurboWarp运行，或点击快捷体验。",[21,51,53,54],{"id":52,"class":14},"操作方法新版本","操作方法（新版本）",[16,55,57,60],{"class":18,"href":56},"#操作方法新版本",[28,58,32],{"className":59},[31],[28,61,37],{"ariaHidden":35,"tabIndex":36},[39,63,64],{},"新版本是自制的无限地图生命游戏。关键算法包括哈希等。",[66,67,68,76,82,88,94,100,106,112,118],"ul",{},[69,70,71,75],"li",{},[72,73,74],"strong",{},"工具栏：","包含多个功能，鼠标单击舞台最下方开启，再次单击上方关闭。",[69,77,78,81],{},[72,79,80],{},"添加细胞：","鼠标操作，移动到合适位置，拖拽添加多个细胞。",[69,83,84,87],{},[72,85,86],{},"删除细胞：","在工具栏中点击\"画笔\"第一项，后与添加细胞相同。",[69,89,90,93],{},[72,91,92],{},"清空细胞：","在工具栏中点击\"清空\"，注意清空操作不可撤回。",[69,95,96,99],{},[72,97,98],{},"粗细调整：","在工具栏中点击\"画笔\"第二项，有1x1到3x3三种粗细选择。",[69,101,102,105],{},[72,103,104],{},"位移：","键盘WASD，分别对应上左下右移动。",[69,107,108,111],{},[72,109,110],{},"缩放：","鼠标滚轮，滚动可动态调整缩放。",[69,113,114,117],{},[72,115,116],{},"重置移缩：","在工具栏中点击\"回家\"即可。",[69,119,120,123],{},[72,121,122],{},"模拟：","在工具栏中点击\"播放\"切换模拟运行状态，模拟规则见上。",[21,125,127,128],{"id":126,"class":14},"附加说明旧版本","附加说明（旧版本）",[16,129,131,134],{"class":18,"href":130},"#附加说明旧版本",[28,132,32],{"className":133},[31],[28,135,37],{"ariaHidden":35,"tabIndex":36},[39,137,138,139,145],{},"旧版本生命游戏主要参考",[16,140,144],{"href":141,"rel":142},"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1aB4y1W7cK",[143],"nofollow","编程侯老师","的教程视频制作。",[39,147,148],{},"仅需使用鼠标操作：",[66,150,151,154,157],{},[69,152,153],{},"左侧为地图相关设置，如随机地图，清空地图，和4种预设的地图。",[69,155,156],{},"右上侧为模拟状态。单击下一代模拟一次，长按快速模拟。下面可显示自上次清空，模拟的总代数。",[69,158,159],{},"右下侧为控制细胞，可实现基本的添加、删除细胞。",[39,161,162,163,166],{},"旧版本制作于 ",[46,164,165],{},"2022\u002F12\u002F22","。该版本提供有限的地图，且存在一定bug。暂不提供在线体验链接。",[21,168,169,170],{"id":169,"class":14},"截图",[16,171,173,176],{"class":18,"href":172},"#截图",[28,174,32],{"className":175},[31],[28,177,37],{"ariaHidden":35,"tabIndex":36},[39,179,180],{},[181,182],"img",{"alt":183,"src":184},"在Scratch无限生命游戏模拟高斯帕滑翔枪","\u002Fraw\u002Finfinity-life-game-screenshot.png",[39,186,187],{},[181,188],{"alt":189,"src":190},"在Scratch生命游戏中模拟简单飞船","\u002Fraw\u002Flife-game-screenshot.png",{"title":192,"searchDepth":193,"depth":194,"links":195},"",2,3,[196,198,200,202],{"id":23,"depth":193,"text":197},"生命游戏介绍章节 §",{"id":52,"depth":193,"text":199},"操作方法（新版本）章节 §",{"id":126,"depth":193,"text":201},"附加说明（旧版本）章节 §",{"id":169,"depth":193,"text":203},"截图章节 §","2025\u002F07\u002F20",[206,207,208],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。",[210,213],[211,212],"\u002Fraw\u002Finfinity-life-game.sb3","下载：新版本",[214,215],"\u002Fraw\u002Flife-game.sb3","下载：旧版本","md",false,[219,222],[220,221],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1ingezAEem\u002F","演示视频（新版本）",[223,224],"\u002Fraw\u002Finfinity-life-game.html","体验：新版本",{},true,"\u002Fpages\u002Flife-game",{"title":6,"description":229},[206,207,208],"pages\u002Flife-game",[232,235,238],[233,234],"lang","scratch3",[236,237],"inspiration","adaptation",[239,240],"content","art","T1fcYeSq4jCC4fwzefXxF3VDHsNP6qYtZOdOdmOCAh0",{"id":243,"title":244,"body":245,"date":511,"description":512,"downloads":515,"extension":216,"hide":217,"links":519,"meta":523,"navigation":226,"path":524,"seo":525,"stem":527,"tags":528,"__hash__":533},"pages\u002Fpages\u002Fanimated-calculator.md","动画计算器",{"type":8,"value":246,"toc":500},[247,252,263,326,337,407,418,425,452,463,485,494],[11,248,244,249],{"id":244,"class":14},[16,250],{"class":18,"href":251},"#动画计算器",[21,253,254,255],{"id":254,"class":14},"运算能力",[16,256,258,261],{"class":18,"href":257},"#运算能力",[28,259,32],{"className":260},[31],[28,262,37],{"ariaHidden":35,"tabIndex":36},[66,264,265,275,293,303,313],{},[69,266,267,270,271,274],{},[72,268,269],{},"基础运算","：支持 ",[46,272,273],{},"+-*\u002F"," 四则运算，遵循标准优先级（先乘除后加减）。",[69,276,277,280,281,284,285,288,289,292],{},[72,278,279],{},"幂运算","：使用 ",[46,282,283],{},"^"," 符号表示乘方，优先级高于乘除，右结合（如 ",[46,286,287],{},"2^3^2"," = ",[46,290,291],{},"2^(3^2)","）。",[69,294,295,298,299,302],{},[72,296,297],{},"括号支持","：允许任意嵌套的 ",[46,300,301],{},"()"," 括号，改变运算顺序。",[69,304,305,308,309,312],{},[72,306,307],{},"负数处理","：支持负号直接输入（如 ",[46,310,311],{},"5+-3"," 解析为 5 + (-3)），也支持负数作为表达式起始。",[69,314,315,318,319,322,323,292],{},[72,316,317],{},"小数缩写","：小数点前后可省略 0（如输入 ",[46,320,321],{},".5"," 自动补全为 ",[46,324,325],{},"0.5",[21,327,328,329],{"id":328,"class":14},"交互体验",[16,330,332,335],{"class":18,"href":331},"#交互体验",[28,333,32],{"className":334},[31],[28,336,37],{"ariaHidden":35,"tabIndex":36},[66,338,339,380,401],{},[69,340,341,344,345],{},[72,342,343],{},"按键输入","：\n",[66,346,347,377],{},[69,348,349,350,353,354,357,358,361,362,364,365,368,369,372,373,376],{},"提供数字键 ",[46,351,352],{},"0-9","、小数点 ",[46,355,356],{},".","、运算符 ",[46,359,360],{},"+-*\u002F^","、括号 ",[46,363,301],{},"、退格 ",[46,366,367],{},"\u003C","、清空 ",[46,370,371],{},"AC","、等于 ",[46,374,375],{},"=","。",[69,378,379],{},"支持按键连输，退格键长按可连续快速删除；数字和运算符长按可重复输入。",[69,381,382,344,385],{},[72,383,384],{},"光标移动",[66,386,387,398],{},[69,388,389,390,393,394,397],{},"支持 ",[46,391,392],{},"←"," ",[46,395,396],{},"→"," 移动光标，可在表达式任意位置插入\u002F删除。",[69,399,400],{},"光标移动带有非线性缓动动画，视觉反馈柔和。",[69,402,403,406],{},[72,404,405],{},"流畅动效","：所有按键按下时有缩放反馈；光标移动具有缓动效果。",[21,408,409,410],{"id":409,"class":14},"核心算法实现",[16,411,413,416],{"class":18,"href":412},"#核心算法实现",[28,414,32],{"className":415},[31],[28,417,37],{"ariaHidden":35,"tabIndex":36},[39,419,420,421,424],{},"解析策略采用",[72,422,423],{},"递归下降 + 结果栈","解析表达式字符串。",[426,427,428,434,440,446],"ol",{},[69,429,430,433],{},[72,431,432],{},"词法分析","：将输入字符串拆解为Token（数字、运算符、括号、负号标记）。",[69,435,436,439],{},[72,437,438],{},"数值计算","：树形遍历Token，执行运算。遇到除零、NaN、无穷大等异常时，停止递归并抛出错误。",[69,441,442,445],{},[72,443,444],{},"递归回溯","：若计算过程中某节点失败，则向上回溯，将整个表达式标记为无效，并清空栈顶中间结果。",[69,447,448,451],{},[72,449,450],{},"最终输出","：成功解析且无错误时，栈顶即为最终计算结果；否则反馈错误信息。",[21,453,454,455],{"id":454,"class":14},"错误处理与用户反馈",[16,456,458,461],{"class":18,"href":457},"#错误处理与用户反馈",[28,459,32],{"className":460},[31],[28,462,37],{"ariaHidden":35,"tabIndex":36},[66,464,465,471,477],{},[69,466,467,470],{},[72,468,469],{},"实时检查","：输入时动态显示错误消息。",[69,472,473,476],{},[72,474,475],{},"计算错误提示","：语法错误如括号不匹配、Token解析错误，数字格式错误分别显示不同消息。",[69,478,479,484],{},[72,480,481],{},[46,482,483],{},"NaN","：针对常见除0，Infinity加减除等运算错误自动识别。",[21,486,169,487],{"id":169,"class":14},[16,488,489,492],{"class":18,"href":172},[28,490,32],{"className":491},[31],[28,493,37],{"ariaHidden":35,"tabIndex":36},[39,495,496],{},[181,497],{"alt":498,"src":499},"使用Scratch动画计算器计算嵌套表达式","\u002Fraw\u002Fanimated-calculator-screenshot.png",{"title":192,"searchDepth":193,"depth":194,"links":501},[502,504,506,508,510],{"id":254,"depth":193,"text":503},"运算能力章节 §",{"id":328,"depth":193,"text":505},"交互体验章节 §",{"id":409,"depth":193,"text":507},"核心算法实现章节 §",{"id":454,"depth":193,"text":509},"错误处理与用户反馈章节 §",{"id":169,"depth":193,"text":203},"2025\u002F04\u002F29",[513,514],"支持多种运算格式，负数，小数。用户操作有非线性的流畅动效。支持识别常见语法错误，计算错误。","纯Scratch实现，利用到栈，递归等技巧，实时显示运算结果。",[516],[517,518],"\u002Fraw\u002Fanimated-calculator.sb3","下载",[520],[521,522],"\u002Fraw\u002Fanimated-calculator.html","体验",{},"\u002Fpages\u002Fanimated-calculator",{"title":244,"description":526},[513,514],"pages\u002Fanimated-calculator",[529,530,531],[233,234],[236,237],[239,532],"tool","Vf-LhRBOJhRGajg7_lnDJgHeZS5oQOfaP9kmOaSD55k",{"id":535,"title":536,"body":537,"date":760,"description":761,"downloads":764,"extension":216,"hide":217,"links":765,"meta":783,"navigation":226,"path":784,"seo":785,"stem":787,"tags":788,"__hash__":795},"pages\u002Fpages\u002Floop-jam.md","2^1024 Loops",{"type":8,"value":538,"toc":751},[539,545,556,580,583,589,596,603,618,621,624,635,638,673,676,685,691,697,703,715,718],[11,540,536,542],{"id":541,"class":14},"_21024-loops",[16,543],{"class":18,"href":544},"#21024-loops",[21,546,547,548],{"id":547,"class":14},"游戏介绍",[16,549,551,554],{"class":18,"href":550},"#游戏介绍",[28,552,32],{"className":553},[31],[28,555,37],{"ariaHidden":35,"tabIndex":36},[39,557,558,560,561,566,567,572,573,576,577,292],{},[46,559,536],{}," 是由",[16,562,565],{"href":563,"rel":564},"https:\u002F\u002Fgithub.com\u002FMrRedShark77",[143],"MrRedShark77","在",[16,568,571],{"href":569,"rel":570},"https:\u002F\u002Fgamemakerstoolkit.com\u002F",[143],"GMTK Game Jam 2025","上制作的游戏。游戏的目标是通过编程，达到 ",[46,574,575],{},"2^1024","（约 ",[46,578,579],{},"1.8x10^308",[39,581,582],{},"通过鼠标操作，移动各种代码，拼接复杂的程序。说明见下图：",[39,584,585],{},[181,586],{"alt":587,"src":588},"2^1024 Loops编程增量游戏代码操作说明示意图","https:\u002F\u002Fisbenben.github.io\u002Floop-jam-cn\u002Ftextures\u002Fhelp.png",[39,590,591,592,595],{},"单击\"运行（Run）\"按钮可以运行代码，一次运行成为一个\"",[46,593,594],{},"loop","\"。会实时展现当前运行状态，再按一次可以加速（Fast）运行一整轮代码。",[39,597,598,599,602],{},"游戏有一个个目标（goal）：让",[46,600,601],{},"P","变量达到一个值。达到的值随游戏进程而增大。",[39,604,605,606,609,610,613,614,617],{},"在完成目标后，可以从",[46,607,608],{},"6","项奖励（Reward）中选择最多",[46,611,612],{},"3","项奖励。奖励有",[46,615,616],{},"5","个等级，获得概率递减。若找不到自己想要的奖励，可以使用 3 次\"重掷（Reroll）\"机会，生成新的 6 项奖励。选择奖励代码后，可以在后续的 loop 中使用。",[39,619,620],{},"在达到 2^1024 后，还可以选择开启无尽模式（Endless Mode）。无尽模式顾名思义，没有真正的结束，但是你可以无限挑战自己的 P，冲向属于你的极限。",[39,622,623],{},"游戏还有一些成就（Achievement）等着你去挑战！",[21,625,626,627],{"id":626,"class":14},"插件介绍",[16,628,630,633],{"class":18,"href":629},"#插件介绍",[28,631,32],{"className":632},[31],[28,634,37],{"ariaHidden":35,"tabIndex":36},[39,636,637],{},"插件由我制作，提供五个可自由开关的功能：",[66,639,640,649,655,661,667],{},[69,641,642,645,646,376],{},[72,643,644],{},"使用弃用的奖励算法：","打开原作者注释掉的奖励算法。代码片段：",[46,647,648],{},"j === 2 ? 1 \u002F Math.max(200, 1000 \u002F player.nextP.add(9).log10().cbrt()) :",[69,650,651,654],{},[72,652,653],{},"现代化样式：","启用现代化样式，包括弹框动画，图标修复，滚动条样式，圆角槽位等杂项修改。",[69,656,657,660],{},[72,658,659],{},"无限重掷：","有无限次\"重掷（Reroll）\"机会。",[69,662,663,666],{},[72,664,665],{},"获得无限块：","用于测试，启用后无限获得奖励块。",[69,668,669,672],{},[72,670,671],{},"排序物品栏：","自动排序物品栏。数字，运算符，变量等均可自动排序。",[39,674,675],{},"插件的设置会保存在玩家数据中，默认启用现代化样式和排序物品栏。",[21,677,169,678],{"id":169,"class":14},[16,679,680,683],{"class":18,"href":172},[28,681,32],{"className":682},[31],[28,684,37],{"ariaHidden":35,"tabIndex":36},[39,686,687],{},[181,688],{"alt":689,"src":690},"2^1024 Loops编程增量游戏主菜单截图","\u002Fraw\u002Floop-jam-main-menu.png",[39,692,693],{},[181,694],{"alt":695,"src":696},"2^1024 Loops编程增量游戏选择奖励界面截图","\u002Fraw\u002Floop-jam-choosing-rewards.png",[39,698,699],{},[181,700],{"alt":701,"src":702},"2^1024 Loops编程增量游戏成就界面截图","\u002Fraw\u002Floop-jam-achivements.png",[21,704,706,707],{"id":705,"class":14},"license","License",[16,708,710,713],{"class":18,"href":709},"#license",[28,711,32],{"className":712},[31],[28,714,37],{"ariaHidden":35,"tabIndex":36},[39,716,717],{},"源代码改编以 MIT License 许可。",[39,719,720,721,725,726,730,731,735,736,740,741,745,746,750],{},"外部库引用：Lodash.js (",[16,722,706],{"href":723,"rel":724},"https:\u002F\u002Fgithub.com\u002Flodash\u002Flodash\u002Fblob\u002Fmain\u002FLICENSE",[143],") | Vue.js (",[16,727,706],{"href":728,"rel":729},"https:\u002F\u002Fgithub.com\u002Fvuejs\u002Fvue\u002Fblob\u002Fmain\u002FLICENSE",[143],") | Noto San
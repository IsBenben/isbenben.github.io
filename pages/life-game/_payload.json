[{"data":1,"prerenderedAt":234},["ShallowReactive",2],{"article-life-game":3},{"id":4,"title":5,"body":6,"date":195,"description":196,"downloads":200,"extension":207,"hide":208,"links":209,"meta":216,"navigation":217,"path":218,"seo":219,"slug":221,"stem":222,"tags":223,"__hash__":233},"articles\u002Farticles\u002Flife-game.md","Scratch 生命游戏",{"type":7,"value":8,"toc":183},"minimark",[9,30,34,42,54,57,116,128,138,141,152,159,170,177],[10,11,12,14],"h2",{"id":12,"class":13},"生命游戏介绍","section-heading",[15,16,19,25],"a",{"class":17,"href":18},"section-link","#生命游戏介绍",[20,21,24,12],"span",{"className":22},[23],"visually-hidden","章节",[20,26,29],{"ariaHidden":27,"tabIndex":28},"true",-1," §",[31,32,33],"p",{},"生命游戏由英国数学家康威于1970年发明。它在一个二维方格世界中模拟细胞的生死状态，细胞的存活与否取决于周围相邻细胞的数量。具体规则包括：如果一个细胞周围活细胞过少，它会死亡；如果活细胞过多，它也会死亡；只有在适当的邻居数量下，细胞才能存活。",[31,35,36,37,41],{},"本程序模拟了生命游戏的一种规则：",[38,39,40],"code",{},"B3\u002FS23","。意思是，若细胞周围有3个细胞，则会繁殖新细胞；而若细胞周围有2或3个细胞，则会保持当前状态。需使用TurboWarp运行，或点击快捷体验。",[10,43,45,46],{"id":44,"class":13},"操作方法新版本","操作方法（新版本）",[15,47,49,52],{"class":17,"href":48},"#操作方法新版本",[20,50,24,45],{"className":51},[23],[20,53,29],{"ariaHidden":27,"tabIndex":28},[31,55,56],{},"新版本是自制的无限地图生命游戏。关键算法包括哈希等。",[58,59,60,68,74,80,86,92,98,104,110],"ul",{},[61,62,63,67],"li",{},[64,65,66],"strong",{},"工具栏：","包含多个功能，鼠标单击舞台最下方开启，再次单击上方关闭。",[61,69,70,73],{},[64,71,72],{},"添加细胞：","鼠标操作，移动到合适位置，拖拽添加多个细胞。",[61,75,76,79],{},[64,77,78],{},"删除细胞：","在工具栏中点击\"画笔\"第一项，后与添加细胞相同。",[61,81,82,85],{},[64,83,84],{},"清空细胞：","在工具栏中点击\"清空\"，注意清空操作不可撤回。",[61,87,88,91],{},[64,89,90],{},"粗细调整：","在工具栏中点击\"画笔\"第二项，有1x1到3x3三种粗细选择。",[61,93,94,97],{},[64,95,96],{},"位移：","键盘WASD，分别对应上左下右移动。",[61,99,100,103],{},[64,101,102],{},"缩放：","鼠标滚轮，滚动可动态调整缩放。",[61,105,106,109],{},[64,107,108],{},"重置移缩：","在工具栏中点击\"回家\"即可。",[61,111,112,115],{},[64,113,114],{},"模拟：","在工具栏中点击\"播放\"切换模拟运行状态，模拟规则见上。",[10,117,119,120],{"id":118,"class":13},"附加说明旧版本","附加说明（旧版本）",[15,121,123,126],{"class":17,"href":122},"#附加说明旧版本",[20,124,24,119],{"className":125},[23],[20,127,29],{"ariaHidden":27,"tabIndex":28},[31,129,130,131,137],{},"旧版本生命游戏主要参考",[15,132,136],{"href":133,"rel":134},"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1aB4y1W7cK",[135],"nofollow","编程侯老师","的教程视频制作。",[31,139,140],{},"仅需使用鼠标操作：",[58,142,143,146,149],{},[61,144,145],{},"左侧为地图相关设置，如随机地图，清空地图，和4种预设的地图。",[61,147,148],{},"右上侧为模拟状态。单击下一代模拟一次，长按快速模拟。下面可显示自上次清空，模拟的总代数。",[61,150,151],{},"右下侧为控制细胞，可实现基本的添加、删除细胞。",[31,153,154,155,158],{},"旧版本制作于 ",[38,156,157],{},"2022\u002F12\u002F22","。该版本提供有限的地图，且存在一定bug。暂不提供在线体验链接。",[10,160,161,162],{"id":161,"class":13},"截图",[15,163,165,168],{"class":17,"href":164},"#截图",[20,166,24,161],{"className":167},[23],[20,169,29],{"ariaHidden":27,"tabIndex":28},[31,171,172],{},[173,174],"img",{"alt":175,"src":176},"在Scratch无限生命游戏模拟高斯帕滑翔枪","\u002Fraw\u002Finfinity-life-game-screenshot.png",[31,178,179],{},[173,180],{"alt":181,"src":182},"在Scratch生命游戏中模拟简单飞船","\u002Fraw\u002Flife-game-screenshot.png",{"title":184,"searchDepth":185,"depth":185,"links":186},"",2,[187,189,191,193],{"id":12,"depth":185,"text":188},"生命游戏介绍章节生命游戏介绍 §",{"id":44,"depth":185,"text":190},"操作方法（新版本）章节操作方法（新版本） §",{"id":118,"depth":185,"text":192},"附加说明（旧版本）章节附加说明（旧版本） §",{"id":161,"depth":185,"text":194},"截图章节截图 §","2025\u002F7\u002F20",[197,198,199],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。",[201,204],[202,203],"\u002Fraw\u002Finfinity-life-game.sb3","下载：新版本",[205,206],"\u002Fraw\u002Flife-game.sb3","下载：旧版本","md",false,[210,213],[211,212],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1ingezAEem\u002F","演示视频（新版本）",[214,215],"\u002Fraw\u002Finfinity-life-game.html","体验：新版本",{},true,"\u002Farticles\u002Flife-game",{"title":5,"description":220},[197,198,199],"life-game","articles\u002Flife-game",[224,227,230],[225,226],"lang","scratch3",[228,229],"inspiration","adaptation",[231,232],"content","art","zojo2XZD4pHDyKKJcP8fB2hm5TwvKlcuQdc-bHxHQPM",1778906720450]
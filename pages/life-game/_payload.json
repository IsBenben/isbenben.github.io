[{"data":1,"prerenderedAt":241},["ShallowReactive",2],{"article-\u002Fpages\u002Flife-game":3},{"id":4,"title":5,"body":6,"date":203,"description":204,"downloads":208,"extension":215,"hide":216,"links":217,"meta":224,"navigation":225,"path":226,"seo":227,"stem":229,"tags":230,"__hash__":240},"pages\u002Fpages\u002Flife-game.md","Scratch生命游戏",{"type":7,"value":8,"toc":190},"minimark",[9,19,37,41,49,61,64,123,135,145,148,159,166,177,184],[10,11,5,14],"h1",{"id":12,"class":13},"scratch生命游戏","section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#scratch生命游戏",[20,21,22,23],"h2",{"id":22,"class":13},"生命游戏介绍",[15,24,26,32],{"class":17,"href":25},"#生命游戏介绍",[27,28,31],"span",{"className":29},[30],"visually-hidden","章节",[27,33,36],{"ariaHidden":34,"tabIndex":35},"true",-1," §",[38,39,40],"p",{},"生命游戏由英国数学家康威于1970年发明。它在一个二维方格世界中模拟细胞的生死状态，细胞的存活与否取决于周围相邻细胞的数量。具体规则包括：如果一个细胞周围活细胞过少，它会死亡；如果活细胞过多，它也会死亡；只有在适当的邻居数量下，细胞才能存活。",[38,42,43,44,48],{},"本程序模拟了生命游戏的一种规则：",[45,46,47],"code",{},"B3\u002FS23","。意思是，若细胞周围有3个细胞，则会繁殖新细胞；而若细胞周围有2或3个细胞，则会保持当前状态。需使用TurboWarp运行，或点击快捷体验。",[20,50,52,53],{"id":51,"class":13},"操作方法新版本","操作方法（新版本）",[15,54,56,59],{"class":17,"href":55},"#操作方法新版本",[27,57,31],{"className":58},[30],[27,60,36],{"ariaHidden":34,"tabIndex":35},[38,62,63],{},"新版本是自制的无限地图生命游戏。关键算法包括哈希等。",[65,66,67,75,81,87,93,99,105,111,117],"ul",{},[68,69,70,74],"li",{},[71,72,73],"strong",{},"工具栏：","包含多个功能，鼠标单击舞台最下方开启，再次单击上方关闭。",[68,76,77,80],{},[71,78,79],{},"添加细胞：","鼠标操作，移动到合适位置，拖拽添加多个细胞。",[68,82,83,86],{},[71,84,85],{},"删除细胞：","在工具栏中点击\"画笔\"第一项，后与添加细胞相同。",[68,88,89,92],{},[71,90,91],{},"清空细胞：","在工具栏中点击\"清空\"，注意清空操作不可撤回。",[68,94,95,98],{},[71,96,97],{},"粗细调整：","在工具栏中点击\"画笔\"第二项，有1x1到3x3三种粗细选择。",[68,100,101,104],{},[71,102,103],{},"位移：","键盘WASD，分别对应上左下右移动。",[68,106,107,110],{},[71,108,109],{},"缩放：","鼠标滚轮，滚动可动态调整缩放。",[68,112,113,116],{},[71,114,115],{},"重置移缩：","在工具栏中点击\"回家\"即可。",[68,118,119,122],{},[71,120,121],{},"模拟：","在工具栏中点击\"播放\"切换模拟运行状态，模拟规则见上。",[20,124,126,127],{"id":125,"class":13},"附加说明旧版本","附加说明（旧版本）",[15,128,130,133],{"class":17,"href":129},"#附加说明旧版本",[27,131,31],{"className":132},[30],[27,134,36],{"ariaHidden":34,"tabIndex":35},[38,136,137,138,144],{},"旧版本生命游戏主要参考",[15,139,143],{"href":140,"rel":141},"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1aB4y1W7cK",[142],"nofollow","编程侯老师","的教程视频制作。",[38,146,147],{},"仅需使用鼠标操作：",[65,149,150,153,156],{},[68,151,152],{},"左侧为地图相关设置，如随机地图，清空地图，和4种预设的地图。",[68,154,155],{},"右上侧为模拟状态。单击下一代模拟一次，长按快速模拟。下面可显示自上次清空，模拟的总代数。",[68,157,158],{},"右下侧为控制细胞，可实现基本的添加、删除细胞。",[38,160,161,162,165],{},"旧版本制作于 ",[45,163,164],{},"2022\u002F12\u002F22","。该版本提供有限的地图，且存在一定bug。暂不提供在线体验链接。",[20,167,168,169],{"id":168,"class":13},"截图",[15,170,172,175],{"class":17,"href":171},"#截图",[27,173,31],{"className":174},[30],[27,176,36],{"ariaHidden":34,"tabIndex":35},[38,178,179],{},[180,181],"img",{"alt":182,"src":183},"在Scratch无限生命游戏模拟高斯帕滑翔枪","\u002Fraw\u002Finfinity-life-game-screenshot.png",[38,185,186],{},[180,187],{"alt":188,"src":189},"在Scratch生命游戏中模拟简单飞船","\u002Fraw\u002Flife-game-screenshot.png",{"title":191,"searchDepth":192,"depth":193,"links":194},"",2,3,[195,197,199,201],{"id":22,"depth":192,"text":196},"生命游戏介绍章节 §",{"id":51,"depth":192,"text":198},"操作方法（新版本）章节 §",{"id":125,"depth":192,"text":200},"附加说明（旧版本）章节 §",{"id":168,"depth":192,"text":202},"截图章节 §","2025\u002F7\u002F20",[205,206,207],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。",[209,212],[210,211],"\u002Fraw\u002Finfinity-life-game.sb3","下载：新版本",[213,214],"\u002Fraw\u002Flife-game.sb3","下载：旧版本","md",false,[218,221],[219,220],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1ingezAEem\u002F","演示视频（新版本）",[222,223],"\u002Fraw\u002Finfinity-life-game.html","体验：新版本",{},true,"\u002Fpages\u002Flife-game",{"title":5,"description":228},[205,206,207],"pages\u002Flife-game",[231,234,237],[232,233],"lang","scratch3",[235,236],"inspiration","adaptation",[238,239],"content","art","EJYxiahnIR66Y7YjKzgvzdZt51xHw6RXhJlInVSPe9Q",1781179807384]
ub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002F%E6%89%BE%E8%A7%84%E5%BE%8B.py","源代码",{},true,"\u002Fpages\u002Ffind-patterns",{"title":6,"description":120},[101,102],"pages\u002Ffind-patterns",[123,126,129],[124,125],"lang","python3",[127,128],"inspiration","original",[130,131],"content","tool","YSt2-EhqcRAxzGrN1zkNfo-j_-FbGVPcVtjxsGOyeds",{"id":134,"title":135,"body":136,"date":264,"description":265,"downloads":268,"extension":107,"hide":108,"links":272,"meta":276,"navigation":117,"path":277,"seo":278,"stem":280,"tags":281,"__hash__":288},"pages\u002Fpages\u002Fcut-fruit.md","切水果",{"type":8,"value":137,"toc":256},[138,143,152,155,158,161,172,175,204,215,229,238,244,250],[11,139,135,140],{"id":135,"class":14},[16,141],{"class":18,"href":142},"#切水果",[21,144,23,145],{"id":23,"class":14},[16,146,147,150],{"class":18,"href":26},[28,148,32],{"className":149},[31],[28,151,37],{"ariaHidden":35,"tabIndex":36},[39,153,154],{},"五种水果从天而降：西瓜🍉、苹果🍎、香蕉🍌、草莓🍓、橘子🍊。",[39,156,157],{},"持刀按空格挥舞，每切中一个水果获得1金币，没切到的水果会继续存储在舞台上。",[39,159,160],{},"无规定时间内，可自由规划升级，升满所有升级并额外获取1500金币通关。",[21,162,163,164],{"id":163,"class":14},"升级系统",[16,165,167,170],{"class":18,"href":166},"#升级系统",[28,168,32],{"className":169},[31],[28,171,37],{"ariaHidden":35,"tabIndex":36},[39,173,174],{},"升级通过金币解锁，点击右下角商店即可进入界面。",[176,177,178,186,192,198],"ul",{},[179,180,181,185],"li",{},[182,183,184],"strong",{},"放大刀","：增加切割范围，更易连切。可升级8次，每次100金币。",[179,187,188,191],{},[182,189,190],{},"加快速度","：水果刷新速度，水果出现更快，金币获取更快。可升级11次，每次100金币。",[179,193,194,197],{},[182,195,196],{},"增加数量","：水果数量上限，屏幕同时存在更多水果。可升级13次，每次100金币。",[179,199,200,203],{},[182,201,202],{},"通关游戏","：解锁最终结局动画。可升级1次，需要其他升级全部升满和额外1500金币。",[21,205,206,207],{"id":206,"class":14},"特色亮点",[16,208,210,213],{"class":18,"href":209},"#特色亮点",[28,211,32],{"className":212},[31],[28,214,37],{"ariaHidden":35,"tabIndex":36},[176,216,217,220,223,226],{},[179,218,219],{},"累积切碎上千水果，在升级的加持下越切越爽，最终通关，成为水果大师！",[179,221,222],{},"小猫主角可爱卡通，配合简洁切割动效。",[179,224,225],{},"升级后视觉效果增强（刀刃变大、水果飞溅特效）。",[179,227,228],{},"支持简单易上手的纯键盘操作，休闲解压。",[21,230,75,231],{"id":75,"class":14},[16,232,233,236],{"class":18,"href":78},[28,234,32],{"className":235},[31],[28,237,37],{"ariaHidden":35,"tabIndex":36},[39,239,240],{},[87,241],{"alt":242,"src":243},"切水果休闲游戏开局画面和操作说明","\u002Fraw\u002Fcut-fruit-init.png",[39,245,246],{},[87,247],{"alt":248,"src":249},"切水果休闲游戏商店升级列表","\u002Fraw\u002Fcut-fruit-shop.png",[39,251,252],{},[87,253],{"alt":254,"src":255},"切水果休闲游戏后期切大量水果","\u002Fraw\u002Fcut-fruit-end.png",{"title":69,"searchDepth":92,"depth":93,"links":257},[258,259,261,263],{"id":23,"depth":92,"text":96},{"id":163,"depth":92,"text":260},"升级系统章节 §",{"id":206,"depth":92,"text":262},"特色亮点章节 §",{"id":75,"depth":92,"text":98},"2025\u002F01\u002F24",[266,267],"Scratch休闲游戏，键盘操作简单易上手，切水果感受舒适爽感，多种升级可用。","在升级的加持下，切碎上千水果，通关游戏！",[269],[270,271],"\u002Fraw\u002Fcut-fruit.sb3","下载",[273],[274,275],"\u002Fraw\u002Fcut-fruit.html","体验",{},"\u002Fpages\u002Fcut-fruit",{"title":135,"description":279},[266,267],"pages\u002Fcut-fruit",[282,284,286],[124,283],"scratch3",[127,285],"adaptation",[130,287],"entertainment","a00JNFhoFfzgaoZprokerCbednmg6Xoi9CAoZbFu40A",{"id":290,"title":291,"body":292,"date":470,"description":471,"downloads":475,"extension":107,"hide":108,"links":479,"meta":486,"navigation":117,"path":487,"seo":488,"stem":490,"tags":491,"__hash__":495},"pages\u002Fpages\u002Foh-my-dear-js.md","Oh my dear JavaScript",{"type":8,"value":293,"toc":465},[294,300,309,312,319,408,416,430,437,444,455,461],[11,295,291,297],{"id":296,"class":14},"oh-my-dear-javascript",[16,298],{"class":18,"href":299},"#oh-my-dear-javascript",[21,301,23,302],{"id":23,"class":14},[16,303,304,307],{"class":18,"href":26},[28,305,32],{"className":306},[31],[28,308,37],{"ariaHidden":35,"tabIndex":36},[39,310,311],{},"这个游戏是一个Scratch消消乐游戏，改编了nice.js——js真值表消消乐。",[39,313,314,315,318],{},"在JavaScript中，",[46,316,317],{},"=="," 相等是再正常不过的运算符：",[61,320,324],{"className":321,"code":322,"language":323,"meta":69,"styl
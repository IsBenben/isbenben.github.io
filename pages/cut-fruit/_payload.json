[{"data":1,"prerenderedAt":182},["ShallowReactive",2],{"article-cut-fruit":3},{"id":4,"title":5,"body":6,"date":150,"description":151,"downloads":154,"extension":158,"hide":159,"links":160,"meta":164,"navigation":165,"path":166,"seo":167,"slug":169,"stem":170,"tags":171,"__hash__":181},"articles\u002Farticles\u002Fcut-fruit.md","切水果",{"type":7,"value":8,"toc":138},"minimark",[9,30,34,37,40,51,54,83,94,108,119,126,132],[10,11,12,14],"h2",{"id":12,"class":13},"介绍","section-heading",[15,16,19,25],"a",{"class":17,"href":18},"section-link","#介绍",[20,21,24,12],"span",{"className":22},[23],"visually-hidden","章节",[20,26,29],{"ariaHidden":27,"tabIndex":28},"true",-1," §",[31,32,33],"p",{},"五种水果从天而降：西瓜🍉、苹果🍎、香蕉🍌、草莓🍓、橘子🍊。",[31,35,36],{},"持刀按空格挥舞，每切中一个水果获得1金币，没切到的水果会继续存储在舞台上。",[31,38,39],{},"无规定时间内，可自由规划升级，升满所有升级并额外获取1500金币通关。",[10,41,42,43],{"id":42,"class":13},"升级系统",[15,44,46,49],{"class":17,"href":45},"#升级系统",[20,47,24,42],{"className":48},[23],[20,50,29],{"ariaHidden":27,"tabIndex":28},[31,52,53],{},"升级通过金币解锁，点击右下角商店即可进入界面。",[55,56,57,65,71,77],"ul",{},[58,59,60,64],"li",{},[61,62,63],"strong",{},"放大刀","：增加切割范围，更易连切。可升级8次，每次100金币。",[58,66,67,70],{},[61,68,69],{},"水果刷新速度","：水果出现更快，金币获取更快。可升级11次，每次100金币。",[58,72,73,76],{},[61,74,75],{},"水果数量上限","：屏幕同时存在更多水果。可升级13次，每次100金币。",[58,78,79,82],{},[61,80,81],{},"通关游戏","：解锁最终结局动画。可升级1次，需要其他升级全部升满和额外1500金币。",[10,84,85,86],{"id":85,"class":13},"特色亮点",[15,87,89,92],{"class":17,"href":88},"#特色亮点",[20,90,24,85],{"className":91},[23],[20,93,29],{"ariaHidden":27,"tabIndex":28},[55,95,96,99,102,105],{},[58,97,98],{},"累积切碎上千水果，在升级的加持下越切越爽，最终通关，成为水果大师！",[58,100,101],{},"小猫主角可爱卡通，配合简洁切割动效。",[58,103,104],{},"升级后视觉效果增强（刀刃变大、水果飞溅特效）。",[58,106,107],{},"支持简单易上手的纯键盘操作，休闲解压。",[10,109,110,111],{"id":110,"class":13},"截图",[15,112,114,117],{"class":17,"href":113},"#截图",[20,115,24,110],{"className":116},[23],[20,118,29],{"ariaHidden":27,"tabIndex":28},[31,120,121],{},[122,123],"img",{"alt":124,"src":125},"切水果休闲游戏开局画面和操作说明","\u002Fraw\u002Fcut-fruit-init.png",[31,127,128],{},[122,129],{"alt":130,"src":131},"切水果休闲游戏商店升级列表","\u002Fraw\u002Fcut-fruit-shop.png",[31,133,134],{},[122,135],{"alt":136,"src":137},"切水果休闲游戏后期切大量水果","\u002Fraw\u002Fcut-fruit-end.png",{"title":139,"searchDepth":140,"depth":140,"links":141},"",2,[142,144,146,148],{"id":12,"depth":140,"text":143},"介绍章节介绍 §",{"id":42,"depth":140,"text":145},"升级系统章节升级系统 §",{"id":85,"depth":140,"text":147},"特色亮点章节特色亮点 §",{"id":110,"depth":140,"text":149},"截图章节截图 §","2025\u002F1\u002F24",[152,153],"Scratch休闲游戏，键盘操作简单易上手，切水果感受舒适爽感，多种升级可用。","在升级的加持下，切碎上千水果，通关游戏！",[155],[156,157],"\u002Fraw\u002Fcut-fruit.sb3","下载","md",false,[161],[162,163],"\u002Fraw\u002Fcut-fruit.html","体验",{},true,"\u002Farticles\u002Fcut-fruit",{"title":5,"description":168},[152,153],"cut-fruit","articles\u002Fcut-fruit",[172,175,178],[173,174],"lang","scratch3",[176,177],"inspiration","adaptation",[179,180],"content","entertainment","nDRe2yB8jPkSl7od6T1-3fmFxWl5Izv2wS8gsBRUs_Q",1779597318669]
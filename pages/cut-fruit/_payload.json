[{"data":1,"prerenderedAt":427},["ShallowReactive",2],{"article-\u002Fpages\u002Fcut-fruit":3},{"current":4,"prev":189,"next":273},{"id":5,"title":6,"body":7,"date":158,"description":159,"downloads":162,"extension":166,"hide":167,"links":168,"meta":172,"navigation":173,"path":174,"seo":175,"stem":177,"tags":178,"__hash__":188},"pages\u002Fpages\u002Fcut-fruit.md","切水果",{"type":8,"value":9,"toc":145},"minimark",[10,19,37,41,44,47,58,61,90,101,115,126,133,139],[11,12,6,14],"h1",{"id":6,"class":13},"section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#切水果",[20,21,22,23],"h2",{"id":22,"class":13},"介绍",[15,24,26,32],{"class":17,"href":25},"#介绍",[27,28,31],"span",{"className":29},[30],"visually-hidden","章节",[27,33,36],{"ariaHidden":34,"tabIndex":35},"true",-1," §",[38,39,40],"p",{},"五种水果从天而降：西瓜🍉、苹果🍎、香蕉🍌、草莓🍓、橘子🍊。",[38,42,43],{},"持刀按空格挥舞，每切中一个水果获得1金币，没切到的水果会继续存储在舞台上。",[38,45,46],{},"无规定时间内，可自由规划升级，升满所有升级并额外获取1500金币通关。",[20,48,49,50],{"id":49,"class":13},"升级系统",[15,51,53,56],{"class":17,"href":52},"#升级系统",[27,54,31],{"className":55},[30],[27,57,36],{"ariaHidden":34,"tabIndex":35},[38,59,60],{},"升级通过金币解锁，点击右下角商店即可进入界面。",[62,63,64,72,78,84],"ul",{},[65,66,67,71],"li",{},[68,69,70],"strong",{},"放大刀","：增加切割范围，更易连切。可升级8次，每次100金币。",[65,73,74,77],{},[68,75,76],{},"加快速度","：水果刷新速度，水果出现更快，金币获取更快。可升级11次，每次100金币。",[65,79,80,83],{},[68,81,82],{},"增加数量","：水果数量上限，屏幕同时存在更多水果。可升级13次，每次100金币。",[65,85,86,89],{},[68,87,88],{},"通关游戏","：解锁最终结局动画。可升级1次，需要其他升级全部升满和额外1500金币。",[20,91,92,93],{"id":92,"class":13},"特色亮点",[15,94,96,99],{"class":17,"href":95},"#特色亮点",[27,97,31],{"className":98},[30],[27,100,36],{"ariaHidden":34,"tabIndex":35},[62,102,103,106,109,112],{},[65,104,105],{},"累积切碎上千水果，在升级的加持下越切越爽，最终通关，成为水果大师！",[65,107,108],{},"小猫主角可爱卡通，配合简洁切割动效。",[65,110,111],{},"升级后视觉效果增强（刀刃变大、水果飞溅特效）。",[65,113,114],{},"支持简单易上手的纯键盘操作，休闲解压。",[20,116,117,118],{"id":117,"class":13},"截图",[15,119,121,124],{"class":17,"href":120},"#截图",[27,122,31],{"className":123},[30],[27,125,36],{"ariaHidden":34,"
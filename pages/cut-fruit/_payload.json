[{"data":1,"prerenderedAt":188},["ShallowReactive",2],{"article-\u002Fpages\u002Fcut-fruit":3},{"id":4,"title":5,"body":6,"date":157,"description":158,"downloads":161,"extension":165,"hide":166,"links":167,"meta":171,"navigation":172,"path":173,"seo":174,"stem":176,"tags":177,"__hash__":187},"pages\u002Fpages\u002Fcut-fruit.md","切水果",{"type":7,"value":8,"toc":144},"minimark",[9,18,36,40,43,46,57,60,89,100,114,125,132,138],[10,11,5,13],"h1",{"id":5,"class":12},"section-heading",[14,15],"a",{"class":16,"href":17},"section-link","#切水果",[19,20,21,22],"h2",{"id":21,"class":12},"介绍",[14,23,25,31],{"class":16,"href":24},"#介绍",[26,27,30],"span",{"className":28},[29],"visually-hidden","章节",[26,32,35],{"ariaHidden":33,"tabIndex":34},"true",-1," §",[37,38,39],"p",{},"五种水果从天而降：西瓜🍉、苹果🍎、香蕉🍌、草莓🍓、橘子🍊。",[37,41,42],{},"持刀按空格挥舞，每切中一个水果获得1金币，没切到的水果会继续存储在舞台上。",[37,44,45],{},"无规定时间内，可自由规划升级，升满所有升级并额外获取1500金币通关。",[19,47,48,49],{"id":48,"class":12},"升级系统",[14,50,52,55],{"class":16,"href":51},"#升级系统",[26,53,30],{"className":54},[29],[26,56,35],{"ariaHidden":33,"tabIndex":34},[37,58,59],{},"升级通过金币解锁，点击右下角商店即可进入界面。",[61,62,63,71,77,83],"ul",{},[64,65,66,70],"li",{},[67,68,69],"strong",{},"放大刀","：增加切割范围，更易连切。可升级8次，每次100金币。",[64,72,73,76],{},[67,74,75],{},"水果刷新速度","：水果出现更快，金币获取更快。可升级11次，每次100金币。",[64,78,79,82],{},[67,80,81],{},"水果数量上限","：屏幕同时存在更多水果。可升级13次，每次100金币。",[64,84,85,88],{},[67,86,87],{},"通关游戏","：解锁最终结局动画。可升级1次，需要其他升级全部升满和额外1500金币。",[19,90,91,92],{"id":91,"class":12},"特色亮点",[14,93,95,98],{"class":16,"href":94},"#特色亮点",[26,96,30],{"className":97},[29],[26,99,35],{"ariaHidden":33,"tabIndex":34},[61,101,102,105,108,111],{},[64,103,104],{},"累积切碎上千水果，在升级的加持下越切越爽，最终通关，成为水果大师！",[64,106,107],{},"小猫主角可爱卡通，配合简洁切割动效。",[64,109,110],{},"升级后视觉效果增强（刀刃变大、水果飞溅特效）。",[64,112,113],{},"支持简单易上手的纯键盘操作，休闲解压。",[19,115,116,117],{"id":116,"class":12},"截图",[14,118,120,123],{"class":16,"href":119},"#截图",[26,121,30],{"className":122},[29],[26,124,35],{"ariaHidden":33,"tabIndex":34},[37,126,127],{},[128,129],"img",{"alt":130,"src":131},"切水果休闲游戏开局画面和操作说明","\u002Fraw\u002Fcut-fruit-init.png",[37,133,134],{},[128,135],{"alt":136,"src":137},"切水果休闲游戏商店升级列表","\u002Fraw\u002Fcut-fruit-shop.png",[37,139,140],{},[128,141],{"alt":142,"src":143},"切水果休闲游戏后期切大量水果","\u002Fraw\u002Fcut-fruit-end.png",{"title":145,"searchDepth":146,"depth":147,"links":148},"",2,3,[149,151,153,155],{"id":21,"depth":146,"text":150},"介绍章节 §",{"id":48,"depth":146,"text":152},"升级系统章节 §",{"id":91,"depth":146,"text":154},"特色亮点章节 §",{"id":116,"depth":146,"text":156},"截图章节 §","2025\u002F1\u002F24",[159,160],"Scratch休闲游戏，键盘操作简单易上手，切水果感受舒适爽感，多种升级可用。","在升级的加持下，切碎上千水果，通关游戏！",[162],[163,164],"\u002Fraw\u002Fcut-fruit.sb3","下载","md",false,[168],[169,170],"\u002Fraw\u002Fcut-fruit.html","体验",{},true,"\u002Fpages\u002Fcut-fruit",{"title":5,"description":175},[159,160],"pages\u002Fcut-fruit",[178,181,184],[179,180],"lang","scratch3",[182,183],"inspiration","adaptation",[185,186],"content","entertainment","UDX5I5IArKWIoPqMqRiusmtS2NZtjgyIIXZUKfciTc4",1781181638561]
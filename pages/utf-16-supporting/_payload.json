[{"data":1,"prerenderedAt":181},["ShallowReactive",2],{"article-\u002Fpages\u002Futf-16-supporting":3},{"id":4,"title":5,"body":6,"date":146,"description":147,"downloads":151,"extension":155,"hide":156,"links":157,"meta":164,"navigation":165,"path":166,"seo":167,"stem":169,"tags":170,"__hash__":180},"pages\u002Fpages\u002Futf-16-supporting.md","Scratch支持UTF-16",{"type":7,"value":8,"toc":134},"minimark",[9,19,37,53,57,68,79,98,109,112,123,130],[10,11,5,14],"h1",{"id":12,"class":13},"scratch支持utf-16","section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#scratch支持utf-16",[20,21,22,23],"h2",{"id":22,"class":13},"复现过程",[15,24,26,32],{"class":17,"href":25},"#复现过程",[27,28,31],"span",{"className":29},[30],"visually-hidden","章节",[27,33,36],{"ariaHidden":34,"tabIndex":35},"true",-1," §",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-plain shiki shiki-themes dracula","😊😇🥰😍🤩\n","plain","",[45,46,47],"code",{"__ignoreMap":43},[27,48,51],{"class":49,"line":50},"line",1,[27,52,41],{},[54,55,56],"p",{},"如该表情字符串。如果使用基本的字符串转列表，会将这些表情符号转换成乱码。",[20,58,59,60],{"id":59,"class":13},"问题原因",[15,61,63,66],{"class":17,"href":62},"#问题原因",[27,64,31],{"className":65},[30],[27,67,36],{"ariaHidden":34,"tabIndex":35},[54,69,70,71,74,75,78],{},"这主要是因为 ",[45,72,73],{},"UTF-16"," 字符串错误地被 ",[45,76,77],{},"UCS-2"," 读取。",[80,81,82,91],"ul",{},[83,84,85,86,90],"li",{},"UTF-16是一个",[87,88,89],"strong",{},"变长表示","，一个Unicode字符可能由1个或2个16位长的码元表示。2个16位长的码元被称为一个代理对，第一个码元为UTF-16标志位。",[83,92,93,94,97],{},"UCS-2是一个",[87,95,96],{},"固定表示","，每个Unicode字符由2个字节表示。\n则UTF-16中由2个16位长的码元表示的字符，在UCS-2中读取会变成两个乱码字符。",[20,99,100,101],{"id":100,"class":13},"解决方法",[15,102,104,107],{"class":17,"href":103},"#解决方法",[27,105,31],{"className":106},[30],[27,108,36],{"ariaHidden":34,"tabIndex":35},[54,110,111],{},"手动处理字符串。当遇到UTF-16标志位，将两个码元合并为一个字符加入列表，否则直接将一个码元加入列表。然后列表中就是正确的字符列表。这样可以通过列表实现正确的字符操作，并同时支持UTF-16中用一个码元表示的字符和代理对。",[20,113,114,115],{"id":114,"class":13},"截图",[15,116,118,121],{"class":17,"href":117},"#截图",[27,119,31],{"className":120},[30],[27,122,36],{"ariaHidden":34,"tabIndex":35},[54,124,125],{},[126,127],"img",{"alt":128,"src":129},"Scratch支持UTF-16解决方案截图","\u002Fraw\u002Futf-16-supporting-solution.png",[131,132,133],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":43,"searchDepth":135,"depth":136,"links":137},2,3,[138,140,142,144],{"id":22,"depth":135,"text":139},"复现过程章节 §",{"id":59,"depth":135,"text":141},"问题原因章节 §",{"id":100,"depth":135,"text":143},"解决方法章节 §",{"id":114,"depth":135,"text":145},"截图章节 §","2025\u002F2\u002F17",[148,149,150],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。",[152],[153,154],"\u002Fraw\u002Futf-16-supporting.sb3","下载示例程序","md",false,[158,161],[159,160],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002FUTF-16支持.sb3","查看示例程序",[162,163],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1iawdejEnG","演示视频",{},true,"\u002Fpages\u002Futf-16-supporting",{"title":5,"description":168},[148,149,150],"pages\u002Futf-16-supporting",[171,174,177],[172,173],"lang","scratch3",[175,176],"inspiration","original",[178,179],"content","learning","wd_fBnXwxO80NyZMX7kCOmAE92uYfhP1yRjW8JTei4g",1782302454687]
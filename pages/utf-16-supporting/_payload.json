[{"data":1,"prerenderedAt":546},["ShallowReactive",2],{"article-\u002Fpages\u002Futf-16-supporting":3},{"current":4,"prev":182,"next":497},{"id":5,"title":6,"body":7,"date":147,"description":148,"downloads":152,"extension":156,"hide":157,"links":158,"meta":165,"navigation":166,"path":167,"seo":168,"stem":170,"tags":171,"__hash__":181},"pages\u002Fpages\u002Futf-16-supporting.md","Scratch支持UTF-16",{"type":8,"value":9,"toc":135},"minimark",[10,20,38,54,58,69,80,99,110,113,124,131],[11,12,6,15],"h1",{"id":13,"class":14},"scratch支持utf-16","section-heading",[16,17],"a",{"class":18,"href":19},"section-link","#scratch支持utf-16",[21,22,23,24],"h2",{"id":23,"class":14},"复现过程",[16,25,27,33],{"class":18,"href":26},"#复现过程",[28,29,32],"span",{"className":30},[31],"visually-hidden","章节",[28,34,37],{"ariaHidden":35,"tabIndex":36},"true",-1," §",[39,40,45],"pre",{"className":41,"code":42,"language":43,"meta":44,"style":44},"language-plain shiki shiki-themes one-dark-pro one-dark-pro one-light","😊😇🥰😍🤩\n","plain","",[46,47,48],"code",{"__ignoreMap":44},[28,49,52],{"class":50,"line":51},"line",1,[28,53,42],{},[55,56,57],"p",{},"如该表情字符串。如果使用基本的字符串转列表，会将这些表情符号转换成乱码。",[21,59,60,61],{"id":60,"class":14},"问题原因",[16,62,64,67],{"class":18,"href":63},"#问题原因",[28,65,32],{"className":66},[31],[28,68,37],{"ariaHidden":35,"tabIndex":36},[55,70,71,72,75,76,79],{},"这主要是因为 ",[46,73,74],{},"UTF-16"," 字符串错误地被 ",[46,77,78],{},"UCS-2"," 读取。",[81,82,83,92],"ul",{},[84,85,86,87,91],"li",{},"UTF-16是一个",[88,89,90],"strong",{},"变长表示","，一个Unicode字符可能由1个或2个16位长的码元表示。2个16位长的码元被称为一个代理对，第一个码元为UTF-16标志位。",[84,93,94,95,98],{},"UCS-2是一个",[88,96,97],{},"固定表示","，每个Unicode字符由2个字节表示。\n则UTF-16中由2个16位长的码元表示的字符，在UCS-2中读取会变成两个乱码字符。",[21,100,101,102],{"id":101,"class":14},"解决方法",[16,103,105,108],{"class":18,"href":104},"#解决方法",[28,106,32],{"className":107},[31],[28,109,37],{"ariaHidden":35,"tabIndex":36},[55,111,112],{},"手动处理字符串。当遇到UTF-16标志位，将两个码元合并为一个字符加入列表，否则直接将一个码元加入列表。然后列表中就是正确的字符列表。这样可以通过列表实现正确的字符操作，并同时支持UTF-16中用一个码元表示的字符和代理对。",[21,114,115,116],{"id":115,"class":14},"截图",[16,117,119,122],{"class":18,"href":118},"#截图",[28,120,32],{"className":121},[31],[28,123,37],{"ariaHidden":35,"tabIndex":36},[55,125,126],{},[127,128],"img",{"alt":129,"src":130},"Scratch支持UTF-16解决方案截图","\u002Fraw\u002Futf-16-supporting-solution.png",[132,133,134],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}",{"title":44,"searchDepth":136,"depth":137,"links":138},2,3,[139,141,143,145],{"id":23,"depth":136,"text":140},"复现过程章节 §",{"id":60,"depth":136,"text":142},"问题原因章节 §",{"id":101,"depth":136,"text":144},"解决方法章节 §",{"id":115,"depth":136,"text":146},"截图章节 §","2025\u002F02\u002F17",[149,150,151],"Scratch将UTF-16错误地由UCS-2读取。","而Scratch不支持直接获取包含特殊表情字符的长度，或某个字符。","本示例展示如何手动处理字符串，解决该问题。",[153],[154,155],"\u002Fraw\u002Futf-16-supporting.sb3","下载示例程序","md",false,[159,162],[160,161],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002FUTF-16支持.sb3","查看示例程序",[163,164],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1iawdejEnG","演示视频",{},true,"\u002Fpages\u002Futf-16-supporting",{"title":6,"description":169},[149,150,151],"pages\u002Futf-16-supporting",[172,175,178],[173,174],"lang","scratch3",[176,177],"inspiration","original",[179,180],"content","learning","HnDnxgYt6-VFDKuc0kdjgu2z65hd2CIIvOKZ-VCEvqA",{"id":183,"title":184,"body":185,"date":473,"description":474,"downloads":478,"extension":156,"hide":157,"links":482,"meta":486,"navigation":166,"path":487,"seo":488,"stem":490,"tags":491,"__hash__":496},"pages\u002Fpages\u002Fchicken-parkour.md","小鸡跑酷",{"type":8,"value":186,"toc":457},[187,192,203,206,218,244,255,269,280,300,311,314,319,349,354,391,396,411,422,425,442,451],[11,188,184,189],{"id":184,"class":14},[16,190],{"class":18,"href":191},"#小鸡跑酷",[21,193,194,195],{"id":194,"class":14},"介绍",[16,196,198,201],{"class":18,"href":197},"#介绍",[28,199,32],{"className":200},[31],[28,202,37],{"ariaHidden":35,"tabIndex":36},[55,204,205],{},"小鸡跑酷是一款基于Scratch风格的横版跑酷游戏，玩家需要控制一只可爱的小鸡在不断滚动的背景中前进。",[207,208,209,210],"h3",{"id":209,"class":14},"核心机制",[16,211,213,216],{"class":18,"href":212},"#核心机制",[28,214,32],{"className":215},[31],[28,217,37],{"ariaHidden":35,"tabIndex":36},[81,219,220,226,232,238],{},[84,221,222,225],{},[88,223,224],{},"背景滚动","：通过背景的连续滚动模拟小鸡的向前移动效果",[84,227,228,231],{},[88,229,230],{},"跳跃控制","：玩家按下空格键可以让小鸡跳跃，躲避地面障碍物",[84,233,234,237],{},[88,235,236],{},"重力系统","：游戏内置了重力模拟，小鸡跳跃后会自然下落，需要掌握好跳跃时机",[84,239,240,243],{},[88,241,242],{},"道具系统","：地图右侧会不断随机出现各种道具，碰到道具会获得或失去相应分数",[207,245,246,247],{"id":246,"class":14},"操作方式",[16,248,250,253],{"class":18,"href":249},"#操作方式",[28,251,32],{"className":252},[31],[28,254,37],{"ariaHidden":35,"tabIndex":36},[81,256,257,263],{},[84,258,259,262],{},[88,260,261],{},"空格键","：让小鸡跳跃",[84,264,265,268],{},[88,266,267],{},"点击按钮","：可以开始或结束游戏",[207,270,271,272],{"id":271,"class":14},"游戏特色",[16,273,275,278],{"class":18,"href":274},"#游戏特色",[28,276,32],{"className":277},[31],[28,279,37],{"ariaHidden":35,"tabIndex":36},[81,281,282,288,294],{},[84,283,284,287],{},[88,285,286],{},"Scratch风格","：采用经典的Scratch编程风格，画面简洁可爱",[84,289,290,293],{},[88,291,292],{},"简单易上手","：操作简单，点击即玩",[84,295,296,299],{},[88,297,298],{},"随机性","：道具的出现位置和类型具有随机性，每次游戏体验都不同",[21,301,302,303],{"id":302,"class":14},"道具",[16,304,306,309],{"class":18,"href":305},"#道具",[28,307,32],{"className":308},[31],[28,310,37],{"ariaHidden":35,"tabIndex":36},[55,312,313],{},"游戏中会出现各种道具，玩家需要根据道具类型决定是否收集：",[55,315,316],{},[88,317,318],{},"加分道具：",[81,320,321,331,340],{},[84,322,323,326,327,330],{},[88,324,325],{},"钻石","：",[46,328,329],{},"+20","分 - 珍贵的加分道具，需要跳跃收集",[84,332,333,326,336,339],{},[88,334,335],{},"金币",[46,337,338],{},"+15","分 - 常见的高分道具",[84,341,342,326,345,348],{},[88,343,344],{},"鸡蛋",[46,346,347],{},"+10","分 - 基础的加分道具",[55,350,351],{},[88,352,353],{},"减分道具（需要躲避）：",[81,355,356,365,374,383],{},[84,357,358,326,361,364],{},[88,359,360],{},"毒药",[46,362,363],{},"-20","分 - 危险道具，会大幅减分",[84,366,367,326,370,373],{},[88,368,369],{},"坑",[46,371,372],{},"-15","分 - 地面陷阱，需要跳跃躲避",[84,375,376,326,379,382],{},[88,377,378],{},"刺猬",[46,380,381],{},"-10","分 - 会扎到小鸡受伤减分",[84,384,385,326,388,390],{},[88,386,387],{},"云朵",[46,389,381],{},"分 - 乌云下雨导致减分",[55,392,393],{},[88,394,395],{},"特殊道具：",[81,397,398],{},[84,399,400,403,404,406,407,410],{},[88,401,402],{},"盲盒","：随机",[46,405,372],{},"~",[46,408,409],{},"15","分 - 运气道具，可能加分也可能减分，适合喜欢冒险的玩家",[21,412,413,414],{"id":413,"class":14},"游戏技巧",[16,415,417,420],{"class":18,"href":416},"#游戏技巧",[28,418,32],{"className":419},[31],[28,421,37],{"ariaHidden":35,"tabIndex":36},[55,423,424],{},"想要获得更高分数，玩家需要掌握以下技巧：",[81,426,427,430,433,436,439],{},[84,428,429],{},"根据道具出现的频率调整跳跃节奏，既不能频繁跳跃浪费体力，也不能错过收集道具的机会",[84,431,432],{},"预判能力，提前观察道具类型，判断是否需要跳跃收集或躲避",[84,434,435],{},"优先收集钻石和金币等高分道具",[84,437,438],{},"坚决躲避毒药和坑等高危障碍",[84,440,441],{},"对于盲盒，根据当前分数决定是否冒险",[21,443,115,444],{"id":115,"class":14},[16,445,446,449],{"class":18,"href":118},[28,447,32],{"className":448},[31],[28,450,37],{"ariaHidden":35,"tabIndex":36},[55,452,453],{},[127,454],{"alt":455,"src":456},"小鸡跑酷游戏画面截图","\u002Fraw\u002Fchicken-pakour-screenshot.png",{"title":44,"searchDepth":136,"depth":137,"links":458},[459,468,470,472],{"id":194,"depth":136,"text":460,"children":461},"介绍章节 §",[462,464,466],{"id":209,"depth":137,"text":463},"核心机制章节 §",{"id":246,"depth":137,"text":465},"操作方式章节 §",{"id":271,"depth":137,"text":467},"游戏特色章节 §",{"id":302,"depth":136,"text":469},"道具章节 §",{"id":413,"depth":136,"text":471},"游戏技巧章节 §",{"id":115,"depth":136,"text":146},"2025\u002F02\u002F10",[475,476,477],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。",[479],[480,481],"\u002Fraw\u002Fchicken-parkour.sb3","下载：游戏SB3",[483],[484,485],"\u002Fraw\u002Fchicken-parkour.html","体验游戏",{},"\u002Fpages\u002Fchicken-parkour",{"title":184,"description":489},[475,476,477],"pages\u002Fchicken-parkour",[492,493,494],[173,174],[176,177],[179,495],"entertainment","EdYW76_2qu1lQrwSV-3CcYYYbIi80bPBsLSHHTo26yU",{"id":498,"title":499,"body":500,"date":525,"description":526,"downloads":527,"extension":156,"hide":157,"links":531,"meta":535,"navigation":166,"path":536,"seo":537,"stem":539,"tags":540,"__hash__":545},"pages\u002Fpages\u002Ffile-matchmaking.md","文件消消乐",{"type":8,"value":501,"toc":523},[502,507,510,513],[11,503,499,504],{"id":499,"class":14},[16,505],{"class":18,"href":506},"#文件消消乐",[55,508,509],{},"这个程序会帮你创建很多文件，删除的文件会被重新创建。",[55,511,512],{},"删除的越多得分越多。",[55,514,515],{},[516,517,518,519,522],"del",{},"绝对不会告诉任何人：按 ",[46,520,521],{},"Alt+F4"," 可以关闭窗口。",{"title":44,"searchDepth":136,"depth":137,"links":524},[],"2025\u002F03\u002F01",[509,512],[528],[529,530],"\u002Fraw\u002Ffile-matchmaking.py","下载：Python程序",[
[{"data":1,"prerenderedAt":298},["ShallowReactive",2],{"article-\u002Fpages\u002Floop-jam":3},{"id":4,"title":5,"body":6,"date":256,"description":257,"downloads":260,"extension":261,"hide":262,"links":263,"meta":281,"navigation":282,"path":283,"seo":284,"stem":286,"tags":287,"__hash__":297},"pages\u002Fpages\u002Floop-jam.md","2^1024 Loops",{"type":7,"value":8,"toc":243},"minimark",[9,19,37,65,68,75,82,89,104,107,110,121,124,163,166,177,183,189,195,207,210],[10,11,5,14],"h1",{"id":12,"class":13},"_21024-loops","section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#21024-loops",[20,21,22,23],"h2",{"id":22,"class":13},"游戏介绍",[15,24,26,32],{"class":17,"href":25},"#游戏介绍",[27,28,31],"span",{"className":29},[30],"visually-hidden","章节",[27,33,36],{"ariaHidden":34,"tabIndex":35},"true",-1," §",[38,39,40,43,44,50,51,56,57,60,61,64],"p",{},[41,42,5],"code",{}," 是由",[15,45,49],{"href":46,"rel":47},"https:\u002F\u002Fgithub.com\u002FMrRedShark77",[48],"nofollow","MrRedShark77","在",[15,52,55],{"href":53,"rel":54},"https:\u002F\u002Fgamemakerstoolkit.com\u002F",[48],"GMTK Game Jam 2025","上制作的游戏。游戏的目标是通过编程，达到 ",[41,58,59],{},"2^1024","（约 ",[41,62,63],{},"1.8x10^308","）。",[38,66,67],{},"通过鼠标操作，移动各种代码，拼接复杂的程序。说明见下图：",[38,69,70],{},[71,72],"img",{"alt":73,"src":74},"2^1024 Loops编程增量游戏代码操作说明示意图","https:\u002F\u002Fisbenben.github.io\u002Floop-jam-cn\u002Ftextures\u002Fhelp.png",[38,76,77,78,81],{},"单击\"运行（Run）\"按钮可以运行代码，一次运行成为一个\"",[41,79,80],{},"loop","\"。会实时展现当前运行状态，再按一次可以加速（Fast）运行一整轮代码。",[38,83,84,85,88],{},"游戏有一个个目标（goal）：让",[41,86,87],{},"P","变量达到一个值。达到的值随游戏进程而增大。",[38,90,91,92,95,96,99,100,103],{},"在完成目标后，可以从",[41,93,94],{},"6","项奖励（Reward）中选择最多",[41,97,98],{},"3","项奖励。奖励有",[41,101,102],{},"5","个等级，获得概率递减。若找不到自己想要的奖励，可以使用 3 次\"重掷（Reroll）\"机会，生成新的 6 项奖励。选择奖励代码后，可以在后续的 loop 中使用。",[38,105,106],{},"在达到 2^1024 后，还可以选择开启无尽模式（Endless Mode）。无尽模式顾名思义，没有真正的结束，但是你可以无限挑战自己的 P，冲向属于你的极限。",[38,108,109],{},"游戏还有一些成就（Achievement）等着你去挑战！",[20,111,112,113],{"id":112,"class":13},"插件介绍",[15,114,116,119],{"class":17,"href":115},"#插件介绍",[27,117,31],{"className":118},[30],[27,120,36],{"ariaHidden":34,"tabIndex":35},[38,122,123],{},"插件由我制作，提供五个可自由开关的功能：",[125,126,127,139,145,151,157],"ul",{},[128,129,130,134,135,138],"li",{},[131,132,133],"strong",{},"使用弃用的奖励算法：","打开原作者注释掉的奖励算法。代码片段：",[41,136,137],{},"j === 2 ? 1 \u002F Math.max(200, 1000 \u002F player.nextP.add(9).log10().cbrt()) :","。",[128,140,141,144],{},[131,142,143],{},"现代化样式：","启用现代化样式，包括弹框动画，图标修复，滚动条样式，圆角槽位等杂项修改。",[128,146,147,150],{},[131,148,149],{},"无限重掷：","有无限次\"重掷（Reroll）\"机会。",[128,152,153,156],{},[131,154,155],{},"获得无限块：","用于测试，启用后无限获得奖励块。",[128,158,159,162],{},[131,160,161],{},"排序物品栏：","自动排序物品栏。数字，运算符，变量等均可自动排序。",[38,164,165],{},"插件的设置会保存在玩家数据中，默认启用现代化样式和排序物品栏。",[20,167,168,169],{"id":168,"class":13},"截图",[15,170,172,175],{"class":17,"href":171},"#截图",[27,173,31],{"className":174},[30],[27,176,36],{"ariaHidden":34,"tabIndex":35},[38,178,179],{},[71,180],{"alt":181,"src":182},"2^1024 Loops编程增量游戏主菜单截图","\u002Fraw\u002Floop-jam-main-menu.png",[38,184,185],{},[71,186],{"alt":187,"src":188},"2^1024 Loops编程增量游戏选择奖励界面截图","\u002Fraw\u002Floop-jam-choosing-rewards.png",[38,190,191],{},[71,192],{"alt":193,"src":194},"2^1024 Loops编程增量游戏成就界面截图","\u002Fraw\u002Floop-jam-achivements.png",[20,196,198,199],{"id":197,"class":13},"license","License",[15,200,202,205],{"class":17,"href":201},"#license",[27,203,31],{"className":204},[30],[27,206,36],{"ariaHidden":34,"tabIndex":35},[38,208,209],{},"源代码改编以 MIT License 许可。",[38,211,212,213,217,218,222,223,227,228,232,233,237,238,242],{},"外部库引用：Lodash.js (",[15,214,198],{"href":215,"rel":216},"https:\u002F\u002Fgithub.com\u002Flodash\u002Flodash\u002Fblob\u002Fmain\u002FLICENSE",[48],") | Vue.js (",[15,219,198],{"href":220,"rel":221},"https:\u002F\u002Fgithub.com\u002Fvuejs\u002Fvue\u002Fblob\u002Fmain\u002FLICENSE",[48],") | Noto Sans SC (",[15,224,198],{"href":225,"rel":226},"https:\u002F\u002Fgithub.com\u002Fnotofonts\u002Fnoto-fonts\u002Fblob\u002Fmain\
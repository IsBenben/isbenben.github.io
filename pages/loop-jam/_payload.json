[{"data":1,"prerenderedAt":291},["ShallowReactive",2],{"article-loop-jam":3},{"id":4,"title":5,"body":6,"date":248,"description":249,"downloads":252,"extension":253,"hide":254,"links":255,"meta":273,"navigation":274,"path":275,"seo":276,"slug":278,"stem":279,"tags":280,"__hash__":290},"articles\u002Farticles\u002Floop-jam.md","2^1024 Loops",{"type":7,"value":8,"toc":236},"minimark",[9,30,58,61,68,75,82,97,100,103,114,117,156,159,170,176,182,188,200,203],[10,11,12,14],"h2",{"id":12,"class":13},"游戏介绍","section-heading",[15,16,19,25],"a",{"class":17,"href":18},"section-link","#游戏介绍",[20,21,24,12],"span",{"className":22},[23],"visually-hidden","章节",[20,26,29],{"ariaHidden":27,"tabIndex":28},"true",-1," §",[31,32,33,36,37,43,44,49,50,53,54,57],"p",{},[34,35,5],"code",{}," 是由",[15,38,42],{"href":39,"rel":40},"https:\u002F\u002Fgithub.com\u002FMrRedShark77",[41],"nofollow","MrRedShark77","在",[15,45,48],{"href":46,"rel":47},"https:\u002F\u002Fgamemakerstoolkit.com\u002F",[41],"GMTK Game Jam 2025","上制作的游戏。游戏的目标是通过编程，达到 ",[34,51,52],{},"2^1024","（约 ",[34,55,56],{},"1.8x10^308","）。",[31,59,60],{},"通过鼠标操作，移动各种代码，拼接复杂的程序。说明见下图：",[31,62,63],{},[64,65],"img",{"alt":66,"src":67},"2^1024 Loops编程增量游戏代码操作说明示意图","https:\u002F\u002Fisbenben.github.io\u002Floop-jam-cn\u002Ftextures\u002Fhelp.png",[31,69,70,71,74],{},"单击\"运行（Run）\"按钮可以运行代码，一次运行成为一个\"",[34,72,73],{},"loop","\"。会实时展现当前运行状态，再按一次可以加速（Fast）运行一整轮代码。",[31,76,77,78,81],{},"游戏有一个个目标（goal）：让",[34,79,80],{},"P","变量达到一个值。达到的值随游戏进程而增大。",[31,83,84,85,88,89,92,93,96],{},"在完成目标后，可以从",[34,86,87],{},"6","项奖励（Reward）中选择最多",[34,90,91],{},"3","项奖励。奖励有",[34,94,95],{},"5","个等级，获得概率递减。若找不到自己想要的奖励，可以使用 3 次\"重掷（Reroll）\"机会，生成新的 6 项奖励。选择奖励代码后，可以在后续的 loop 中使用。",[31,98,99],{},"在达到 2^1024 后，还可以选择开启无尽模式（Endless Mode）。无尽模式顾名思义，没有真正的结束，但是你可以无限挑战自己的 P，冲向属于你的极限。",[31,101,102],{},"游戏还有一些成就（Achievement）等着你去挑战！",[10,104,105,106],{"id":105,"class":13},"插件介绍",[15,107,109,112],{"class":17,"href":108},"#插件介绍",[20,110,24,105],{"className":111},[23],[20,113,29],{"ariaHidden":27,"tabIndex":28},[31,115,116],{},"插件由我制作，提供五个可自由开关的功能：",[118,119,120,132,138,144,150],"ul",{},[121,122,123,127,128,131],"li",{},[124,125,126],"strong",{},"使用弃用的奖励算法：","打开原作者注释掉的奖励算法。代码片段：",[34,129,130],{},"j === 2 ? 1 \u002F Math.max(200, 1000 \u002F player.nextP.add(9).log10().cbrt()) :","。",[121,133,134,137],{},[124,135,136],{},"现代化样式：","启用现代化样式，包括弹框动画，图标修复，滚动条样式，圆角槽位等杂项修改。",[121,139,140,143],{},[124,141,142],{},"无限重掷：","有无限次\"重掷（Reroll）\"机会。",[121,145,146,149],{},[124,147,148],{},"获得无限块：","用于测试，启用后无限获得奖励块。",[121,151,152,155],{},[124,153,154],{},"排序物品栏：","自动排序物品栏。数字，运算符，变量等均可自动排序。",[31,157,158],{},"插件的设置会保存在玩家数据中，默认启用现代化样式和排序物品栏。",[10,160,161,162],{"id":161,"class":13},"截图",[15,163,165,168],{"class":17,"href":164},"#截图",[20,166,24,161],{"className":167},[23],[20,169,29],{"ariaHidden":27,"tabIndex":28},[31,171,172],{},[64,173],{"alt":174,"src":175},"2^1024 Loops编程增量游戏主菜单截图","\u002Fraw\u002Floop-jam-main-menu.png",[31,177,178],{},[64,179],{"alt":180,"src":181},"2^1024 Loops编程增量游戏选择奖励界面截图","\u002Fraw\u002Floop-jam-choosing-rewards.png",[31,183,184],{},[64,185],{"alt":186,"src":187},"2^1024 Loops编程增量游戏成就界面截图","\u002Fraw\u002Floop-jam-achivements.png",[10,189,191,192],{"id":190,"class":13},"license","License",[15,193,195,198],{"class":17,"href":194},"#license",[20,196,24,191],{"className":197},[23],[20,199,29],{"ariaHidden":27,"tabIndex":28},[31,201,202],{},"源代码改编以 MIT License 许可。",[31,204,205,206,210,211,215,216,220,221,225,226,230,231,235],{},"外部库引用：Lodash.js (",[15,207,191],{"href":208,"rel":209},"https:\u002F\u002Fgithub.com\u002Flodash\u002Flodash\u002Fblob\u002Fmain\u002FLICENSE",[41],") | Vue.js (",[15,212,191],{"href":213,"rel":214},"https:\u002F\u002Fgithub.com\u002Fvuejs\u002Fvue\u002Fblob\u002Fmain\u002FLICENSE",[41],") | Noto Sans SC (",[15,217,191],{"href":218,"rel":219},"https:\u002F\u002Fgithub.com\u002Fnotofonts\u002Fnoto-fonts\u002Fblob\u002Fmain\u002FLICENSE",[41],") | Google Sans Code (",[15,222,191],{"href":223,"rel":224},"https:\u002F\u
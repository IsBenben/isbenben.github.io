[{"data":1,"prerenderedAt":600},["ShallowReactive",2],{"article-\u002Fpages\u002Floop-jam":3},{"current":4,"prev":299,"next":506},{"id":5,"title":6,"body":7,"date":257,"description":258,"downloads":261,"extension":262,"hide":263,"links":264,"meta":282,"navigation":283,"path":284,"seo":285,"stem":287,"tags":288,"__hash__":298},"pages\u002Fpages\u002Floop-jam.md","2^1024 Loops",{"type":8,"value":9,"toc":244},"minimark",[10,20,38,66,69,76,83,90,105,108,111,122,125,164,167,178,184,190,196,208,211],[11,12,6,15],"h1",{"id":13,"class":14},"_21024-loops","section-heading",[16,17],"a",{"class":18,"href":19},"section-link","#21024-loops",[21,22,23,24],"h2",{"id":23,"class":14},"游戏介绍",[16,25,27,33],{"class":18,"href":26},"#游戏介绍",[28,29,32],"span",{"className":30},[31],"visually-hidden","章节",[28,34,37],{"ariaHidden":35,"tabIndex":36},"true",-1," §",[39,40,41,44,45,51,52,57,58,61,62,65],"p",{},[42,43,6],"code",{}," 是由",[16,46,50],{"href":47,"rel":48},"https:\u002F\u002Fgithub.com\u002FMrRedShark77",[49],"nofollow","MrRedShark77","在",[16,53,56],{"href":54,"rel":55},"https:\u002F\u002Fgamemakerstoolkit.com\u002F",[49],"GMTK Game Jam 2025","上制作的游戏。游戏的目标是通过编程，达到 ",[42,59,60],{},"2^1024","（约 ",[42,63,64],{},"1.8x10^308","）。",[39,67,68],{},"通过鼠标操作，移动各种代码，拼接复杂的程序。说明见下图：",[39,70,71],{},[72,73],"img",{"alt":74,"src":75},"2^1024 Loops编程增量游戏代码操作说明示意图","https:\u002F\u002Fisbenben.github.io\u002Floop-jam-cn\u002Ftextures\u002Fhelp.png",[39,77,78,79,82],{},"单击\"运行（Run）\"按钮可以运行代码，一次运行成为一个\"",[42,80,81],{},"loop","\"。会实时展现当前运行状态，再按一次可以加速（Fast）运行一整轮代码。",[39,84,85,86,89],{},"游戏有一个个目标（goal）：让",[42,87,88],{},"P","变量达到一个值。达到的值随游戏进程而增大。",[39,91,92,93,96,97,100,101,104],{},"在完成目标后，可以从",[42,94,95],{},"6","项奖励（Reward）中选择最多",[42,98,99],{},"3","项奖励。奖励有",[42,102,103],{},"5","个等级，获得概率递减。若找不到自己想要的奖励，可以使用 3 次\"重掷（Reroll）\"机会，生成新的 6 项奖励。选择奖励代码后，可以在后续的 loop 中使用。",[39,106,107],{},"在达到 2^1024 后，还可以选择开启无尽模式（Endless Mode）。无尽模式顾名思义，没有真正的结束，但是你可以无限挑战自己的 P，冲向属于你的极限。",[39,109,110],{},"游戏还有一些成就（Achievement）等着你去挑战！",[21,112,113,114],{"id":113,"class":14},"插件介绍",[16,115,117,120],{"class":18,"href":116},"#插件介绍",[28,118,32],{"className":119},[31],[28,121,37],{"ariaHidden":35,"tabIndex":36},[39,123,124],{},"插件由我制作，提供五个可自由开关的功能：",[126,127,128,140,146,152,158],"ul",{},[129,130,131,135,136,139],"li",{},[132,133,134],"strong",{},"使用弃用的奖励算法：","打开原作者注释掉的奖励算法。代码片段：",[42,137,138],{},"j === 2 ? 1 \u002F Math.max(200, 1000 \u002F player.nextP.add(9).log10().cbrt()) :","。",[129,141,142,145],{},[132,143,144],{},"现代化样式：","启用现代化样式，包括弹框动画，图标修复，滚动条样式，圆角槽位等杂项修改。",[129,147,148,151],{},[132,149,150],{},"无限重掷：","有无限次\"重掷（Reroll）\"机会。",[129,153,154,157],{},[132,155,156],{},"获得无限块：","用于测试，启用后无限获得奖励块。",[129,159,160,163],{},[132,161,162],{},"排序物品栏：","自动排序物品栏。数字，运算符，变量等均可自动排序。",[39,165,166],{},"插件的设置会保存在玩家数据中，默认启用现代化样式和排序物品栏。",[21,168,169,170],{"id":169,"class":14},"截图",[16,171,173,176],{"class":18,"href":172},"#截图",[28,174,32],{"className":175},[31],[28,177,37],{"ariaHidden":35,"tabIndex":36},[39,179,180],{},[72,181],{"alt":182,"src":183},"2^1024 Loops编程增量游戏主菜单截图","\u002Fraw\u002Floop-jam-main-menu.png",[39,185,186],{},[72,187],{"alt":188,"src":189},"2^1024 Loops编程增量游戏选择奖励界面截图","\u002Fraw\u002Floop-jam-choosing-rewards.png",[39,191,192],{},[72,193],{"alt":194,"src":195},"2^1024 Loops编程增量游戏成就界面截图","\u002Fraw\u002Floop-jam-achivements.png",[21,197,199,200],{"id":198,"class":14},"license","License",[16,201,203,206],{"class":18,"href":202},"#license",[28,204,32],{"className":205},[31],[28,207,37],{"ariaHidden":35,"tabIndex":36},[39,209,210],{},"源代码改编以 MIT License 许可。",[39,212,213,214,218,219,223,224,228,229,233,234,238,239,243],{},"外部库引用：Lodash.js (",[16,215,199],{"href":216,"rel":217},"https:\u002F\u002Fgithub.com\u002Flodash\u002Flodash\u002Fblob\u002Fmain\u002FLICENSE",[49],") | Vue.js (",[16,220,199],{"href":221,"rel":222},"https:\u002F\u002Fgithub.com\u002Fvuejs\u002Fvue\u002Fblob\u002Fmain\u002FLICENSE",[49],") | Noto Sans SC (",[16,225,199],{"href":226,"rel":227},"https:\u002F\u002Fgithub.com\u002Fnotofonts\u002Fnoto-fonts\u002Fblob\u002Fmain\u002FLICENSE",[49],") | Google Sans Code (",[16,230,199],{"href":231,"rel":232},"https:\u002F\u002Fgithub.com\u002Fgooglefonts\u002Fgooglesans-code\u002Fblob\u002Fmain\u002FOFL.txt",[49],") | Roboto Mono (",[16,235,199],{"href":236,"rel":237},"https:\u002F\u002Fgithub.com\u002Fgooglefonts\u002FRobotoMono\u002Fblob\u002Fmain\u002FOFL.txt",[49],") | break_eternity.js (",[16,240,199],{"href":241,"rel":242},"https:\u002F\u002Fgithub.com\u002FPatashu\u002Fbreak_eternity.js\u002Fblob\u002Fmaster\u002FLICENSE",[49],")",{"title":245,"searchDepth":246,"depth":247,"links":248},"",2,3,[249,251,253,255],{"id":23,"depth":246,"text":250},"游戏介绍章节 §",{"id":113,"depth":246,"text":252},"插件介绍章节 §",{"id":169,"depth":246,"text":254},"截图章节 §",{"id":198,"depth":246,"text":256},"License章节 §","2025\u002F08\u002F14",[259,260],"2^1024 Loops 是由 MrRedShark77 在 GMTK Game Jam 2025 上制作的游戏。游戏的目标是通过编程，达到 2^1024（约 1.8x10^308）。","本文章提供游戏相关教程和攻略。",[],"md",false,[265,268,271,274,277,280],[266,267],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1vhbkzPEJv\u002F","隐藏成就攻略",[269,270],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002Floop-jam-cn","关联仓库（汉化插件版）",[272,273],"https:\u002F\u002Fmrredshark77.github.io\u002Floop-jam\u002F","关联仓库（英文原版）",[275,276],"https:\u002F\u002Fisbenben.github.io\u002Floop-jam-cn","体验：汉化插件版",[278,279],"https:\u002F\u002Fhtml-classic.itch.zone\u002Fhtml\u002F14534996\u002Findex.html","体验：英文原版（链接1）",[272,281],"体验：英文原版（链接2）",{},true,"\u002Fpages\u002Floop-jam",{"title":6,"description":286},[259,260],"pages\u002Floop-jam",[289,292,295],[290,291],"lang","web",[293,294],"inspiration","localization",[296,297],"content","entertainment","zJ5LUvvrfnzF4GLoDZEAqCthQAp8D97BUv6RVyjy0gA",{"id":300,"title":301,"body":302,"date":474,"description":475,"downloads":479,"extension":262,"hide":263,"links":486,"meta":493,"navigation":283,"path":494,"seo":495,"stem":497,"tags":498,"__hash__":505},"pages\u002Fpages\u002Flife-game.md","Scratch生命游戏",{"type":8,"value":303,"toc":465},[304,310,321,324,331,343,346,402,414,423,426,437,444,453,459],[11,305,301,307],{"id":306,"class":14},"scratch生命游戏",[16,308],{"class":18,"href":309},"#scratch生命游戏",[21,311,312,313],{"id":312,"class":14},"生命游戏介绍",[16,314,316,319],{"class":18,"href":315},"#生命游戏介绍",[28,317,32],{"className":318},[31],[28,320,37],{"ariaHidden":35,"tabIndex":36},[39,322,323],{},"生命游戏由英国数学家康威于1970年发明。它在一个二维方格世界中模拟细胞的生死状态，细胞的存活与否取决于周围相邻细胞的数量。具体规则包括：如果一个细胞周围活细胞过少，它会死亡；如果活细胞过多，它也会死亡；只有在适当的邻居数量下，细胞才能存活。",[39,325,326,327,330],{},"本程序模拟了生命游戏的一种规则：",[42,328,329],{},"B3\u002FS23","。意思是，若细胞周围有3个细胞，则会繁殖新细胞；而若细胞周围有2或3个细胞，则会保持当前状态。需使用TurboWarp运行，或点击快捷体验。",[21,332,334,335],{"id":333,"class":14},"操作方法新版本","操作方法（新版本）",[16,336,338,341],{"class":18,"href":337},"#操作方法新版本",[28,339,32],{"className":340},[31],[28,342,37],{"ariaHidden":35,"tabIndex":36},[39,344,345],{},"新版本是自制的无限地图生命游戏。关键算法包括哈希等。",[126,347,348,354,360,366,372,378,384,390,396],{},[129,349,350,353],{},[132,351,352],{},"工具栏：","包含多个功能，鼠标单击舞台最下方开启，再次单击上方关闭。",[129,355,356,359],{},[132,357,358],{},"添加细胞：","鼠标操作，移动到合适位置，拖拽添加多个细胞。",[129,361,362,365],{},[132,363,364],{},"删除细胞：","在工具栏中点击\"画笔\"第一项，后与添加细胞相同。",[129,367,368,371],{},[132,369,370],{},"清空细胞：","在工具栏中点击\"清空\"，注意清空操作不可撤回。",[129,373,374,377],{},[132,375,376],{},"粗细调整：","在工具栏中点击\"画笔\"第二项，有1x1到3x3三种粗细选择。",[129,379,380,383],{},[132,381,382],{},"位移：","键盘WASD，分别对应上左下右移动。",[129,385,386,389],{},[132,387,388],{},"缩放：","鼠标滚轮，滚动可动态调整缩放。",[129,391,392,395],{},[132,393,394],{},"重置移缩：","在工具栏中点击\"回家\"即可。",[129,397,398,401],{},[132,399,400],{},"模拟：","在工具栏中点击\"播放\"切换模拟运行状态，模拟规则见上。",[21,403,405,406],{"id":404,"class":14},"附加说明旧版本","附加说明（旧版本）",[16,407,409,412],{"class":18,"href":408},"#附加说明旧版本",[28,410,32],{"className":411},[31],[28,413,37],{"ariaHidden":35,"tabIndex":36},[39,415,416,417,422],{},"旧版本生命游戏主要参考",[16,418,421],{"href":419,"rel":420},"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1aB4y1W7cK",[49],"编程侯老师","的教程视频制作。",[39,424,425],{},"仅需使用鼠标操作：",[126,427,428,431,434],{},[129,429,430],{},"左侧为地图相关设置，如随机地图，清空地图，和4种预设的地图。",[129,432,433],{},"右上侧为模拟状态。单击下一代模拟一次，长按快速模拟。下面可显示自上次清空，模拟的总代数。",[129,435,436],{},"右下侧为控制细胞，可实现基本的添加、删除细胞。",[39,438,439,440,443],{},"旧版本制作于 ",[42,441,442],{},"2022\u002F12\u002F22","。该版本提供有限的地图，且存在一定bug。暂不提供在线体验链接。",[21,445,169,446],{"id":169,"class":14},[16,447,448,451],{"class":18,"href":172},[28,449,32],{"className":450},[31],[28,452,37],{"ariaHidden":35,"tabIndex":36},[39,454,455],{},[72,456],{"alt":457,"src":458},"在Scratch无限生命游戏模拟高斯帕滑翔枪","\u002Fraw\u002Finfinity-life-game-screenshot.png",[39,460,461],{},[72,462],{"alt":463,"src":464},"在Scratch生命游戏中模拟简单飞船","\u002Fraw\u002Flife-game-screenshot.png",{"title":245,"searchDepth":246,"depth":247,"links":466},[467,469,471,473],{"id":312,"depth":246,"text":468},"生命游戏介绍章节 §",{"id":333,"depth":246,"text":470},"操作方法（新版本）章节 §",{"id":404,"depth":246,"text":472},"附加说明（旧版本）章节 §",{"id":169,"depth":246,"text":254},"2025\u002F07\u002F20",[476,477,478],"本程序模拟了生命游戏的一种规则：B3\u002FS23，即康威生命游戏的初始版本。","新版本是自制的无限地图生命游戏，操作简单。","旧版本参考教程视频，提供有限的地图。",[480,483],[481,482],"\u002Fraw\u002Finfinity-life-game.sb3","下载：新版本",[484,485],"\u002Fraw\u002Flife-game.sb3","下载：旧版本",[487,490],[488,489],"https:\u002F\u002Fwww.bilibili.com\u002Fvideo\u002FBV1ingezAEem\u002F","演示视频（新版本）",[491,492],"\u002Fraw\u002Finfinity-life-game.html","体验：新版本",{},"\u002Fpages\u002Flife-game",{"title":301,"description":496},[476,477,478],"pages\u002Flife-game",[499,501,503],[290,500],"scratch3",[293,502],"adaptation",[296,504],"art","T1fcYeSq4jCC4fwzefXxF3VDHsNP6qYtZOdOdmOCAh0",{"id":507,"title":508,"body":509,"date":578,"description":579,"downloads":582,"extension":262,"hide":263,"links":583,"meta":587,"navigation":283,"path":588,"seo":589,"stem":591,"tags":592,"__hash__":599},"pages\u002Fpages\u002Fdisable-ore-smelting.md","禁用矿石烧炼",{"type":8,"value":510,"toc":572},[511,516,527,530,533,552,555,566],[11,512,508,513],{"id":508,"class":14},[16,514],{"class":18,"href":515},"#禁用矿石烧炼",[21,517,518,519],{"id":518,"class":14},"介绍",[16,520,522,525],{"class":18,"href":521},"#介绍",[28,523,32],{"className":524},[31],[28,526,37],{"ariaHidden":35,"tabIndex":36},[39,528,529],{},"该数据包会禁用部分会浪费的矿石烧炼配方，同时保留不会浪费的、必需的烧炼配方。",[39,531,532],{},"禁用配方的矿物种类列表：",[126,534,535,544],{},[129,536,537,543],{},[132,538,539,542],{},[42,540,541],{},"1.13+","：","煤炭、铜、钻石、绿宝石、青金石、红石",[129,545,546,551],{},[132,547,548,542],{},[42,549,550],{},"1.18+","主世界金、铁",[39,553,554],{},"该数据包支持1.13+的主流版本。",[21,556,557,558],{"id":557,"class":14},"画廊",[16,559,561,564],{"class":18,"href":560},"#画廊",[28,562,32],{"className":563},[31],[28,565,37],{"ariaHidden":35,"tabIndex":36},[39,567,568],{},[72,569],{"alt":570,"src":571},"MC使用禁用矿石烧炼数据包游戏内效果截图","https:\u002F\u002Fcdn-alt.modrinth.com\u002Fdata\u002F5NTQdowV\u002Fimages\u002Ff10fdec145d9a9d733944b2a1e4d100d9be1b3ee.png",{"title":245,"searchDepth":246,"depth":247,"links":573},[574,576],{"id":518,"depth":246,"text":575},"介绍章节 §",{"id":557,"depth":246,"text":577},"画廊章节 §","2025\u002F08\u002F25",[580,581],"该数据包会禁用部分会浪费的矿石烧炼配方。","支持1.13+的主流版本，在Modrinth上发布。",[],[584],[585,586],"https:\u002F\u002Fmodrinth.com\u002Fdatapack\u002Fdisable-ores-smelting","数据包首页",{},"\u002Fpages\u002Fdisable-ore-smelting",{"title":508,"description":590},[580,581],"pages\u002Fdisable-ore-smelting",[593,595,597],[290,594],"minecraft",[293,596],"original",[296,598],"tool","YHY8rDkJzvdJjiAbh8VZZdjbYQO-r7fLxKiq6lBApss",1782556477587]
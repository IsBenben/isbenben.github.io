[{"data":1,"prerenderedAt":325},["ShallowReactive",2],{"article-\u002Fpages\u002Fepf-limit-remover":3},{"id":4,"title":5,"body":6,"date":294,"description":295,"downloads":298,"extension":299,"hide":300,"links":301,"meta":308,"navigation":309,"path":310,"seo":311,"stem":313,"tags":314,"__hash__":324},"pages\u002Fpages\u002Fepf-limit-remover.md","EPFLimitRemover",{"type":7,"value":8,"toc":284},"minimark",[9,19,48,63,81,100,111,114,137,148,155,189,200,203,214,221,235,253,256,280],[10,11,5,14],"h1",{"id":12,"class":13},"epflimitremover","section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#epflimitremover",[20,21,22,32,40],"p",{},[15,23,27],{"href":24,"rel":25},"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FEPFLimitRemover\u002Fblob\u002Fmain\u002FLICENSE",[26],"nofollow",[28,29],"img",{"alt":30,"src":31},"license","https:\u002F\u002Fimg.shields.io\u002Fgithub\u002Flicense\u002FIsBenben\u002FEPFLimitRemover",[15,33,36],{"href":34,"rel":35},"https:\u002F\u002Fneoforged.net\u002F",[26],[28,37],{"alt":38,"src":39},"NeoForge","https:\u002F\u002Fimg.shields.io\u002Fbadge\u002FNeoForge-21.11.42+-orange",[15,41,44],{"href":42,"rel":43},"https:\u002F\u002Fminecraft.net\u002F",[26],[28,45],{"alt":46,"src":47},"Minecraft","https:\u002F\u002Fimg.shields.io\u002Fbadge\u002FMinecraft-1.21.x-brightgreen",[20,49,50,51,54,55,58,59,62],{},"EPFLimitRemover是一个可配置的",[52,53,46],"code",{},"模组，用于修改原版魔咒保护系数（",[52,56,57],{},"EPF","）的上限。原版EPF上限固定为",[52,60,61],{},"20","，而本模组允许你根据需要调整该值，从而改变盔甲保护机制的计算结果。",[64,65,66,67],"h2",{"id":66,"class":13},"功能特性",[15,68,70,76],{"class":17,"href":69},"#功能特性",[71,72,75],"span",{"className":73},[74],"visually-hidden","章节",[71,77,80],{"ariaHidden":78,"tabIndex":79},"true",-1," §",[82,83,84,88,91,94,97],"ul",{},[85,86,87],"li",{},"自由配置魔咒保护系数的上限（默认25，原版为20），支持范围为0.0~25.0。",[85,89,90],{},"兼容Minecraft 1.21~1.21.11全系列版本。",[85,92,93],{},"修改配置文件后自动生效，无需重启游戏。",[85,95,96],{},"通过轻量级Mixin注入原版战斗规则类，无侵入式修改。",[85,98,99],{},"源码完全开放，可自由使用、修改和分发。",[64,101,102,103],{"id":102,"class":13},"安装方式",[15,104,106,109],{"class":17,"href":105},"#安装方式",[71,107,75],{"className":108},[74],[71,110,80],{"ariaHidden":78,"tabIndex":79},[20,112,113],{},"模组支持NeoForge 21.11.42+（MC版本见功能特性）。",[115,116,117,120,127,134],"ol",{},[85,118,119],{},"下载适用于你的Minecraft版本的模组JAR文件。",[85,121,122,123,126],{},"确保已安装对应版本的",[15,124,38],{"href":34,"rel":125},[26],"。",[85,128,129,130,133],{},"将JAR文件放入",[52,131,132],{},".minecraft\u002Fmods\u002F","目录。",[85,135,136],{},"启动游戏，模组会自动加载。",[64,138,139,140],{"id":139,"class":13},"配置说明",[15,141,143,146],{"class":17,"href":142},"#配置说明",[71,144,75],{"className":145},[74],[71,147,80],{"ariaHidden":78,"tabIndex":79},[20,149,150,151,154],{},"配置文件位于",[52,152,153],{},".minecraft\u002Fconfig\u002Fepflimitremover-common.toml","（首次运行游戏后自动生成）。",[156,157,162],"pre",{"className":158,"code":159,"language":160,"meta":161,"style":161},"language-toml shiki shiki-themes dracula","#魔咒保护系数(EPF)上限，原版为20\n# Default: 25.0\n# Range: 0.0 ~ 25.0\nepfLimit = 25.0\n","toml","",[52,163,164,171,177,183],{"__ignoreMap":161},[71,165,168],{"class":166,"line":167},"line",1,[71,169,170],{},"#魔咒保护系数(EPF)上限，原版为20\n",[71,172,174],{"class":166,"line":173},2,[71,175,176],{},"# Default: 25.0\n",[71,178,180],{"class":166,"line":179},3,[71,181,182],{},"# Range: 0.0 ~ 25.0\n",[71,184,186],{"class":166,"line":185},4,[71,187,188],{},"epfLimit = 25.0\n",[20,190,191,192,195,196,199],{},"本模组使用",[52,193,194],{},"epfLimit","配置EPF上限。设置为",[52,197,198],{},"20.0","可还原原版行为。调低该值会削弱魔咒保护效果，调高则增强。",[20,201,202],{},"修改配置文件后，模组会自动重载配置并立即生效，无需重启游戏。",[64,204,205,206],{"id":205,"class":13},"技术细节",[15,207,209,212],{"class":17,"href":208},"#技术细节",[71,210,75],{"className":211},[74],[71,213,80],{"ariaHidden":78,"tabIndex":79},[20,215,216,217,220],{},"Minecraft原版通过",[52,218,219],{},"CombatRules","类的以下两个方法计算伤害减免：",[82,222,223,229],{},[85,224,225,228],{},[52,226,227],{},"getDamageAfterAbsorb","：计算护甲和盔甲韧性之后的伤害。",[85,230,231,234],{},[52,232,233],{},"getDamageAfterMagicAbsorb","：计算魔咒保护（如保护、弹射物保护等）之后的伤害。",[20,236,237,238,241,242,245,246,249,250,252],{},"这两个方法内部均使用",[52,239,240],{},"Mth.clamp(epf, 0.0F, 20.0F)","将EPF限制在",[52,243,244],{},"[0, 20]","区间。本模组通过Mixin修改该",[52,247,248],{},"clamp","调用的最大值参数，将其替换为配置文件中的",[52,251,194],{},"值。",[20,254,255],{},"本模组通过如下代码修改该行为：",[82,257,258,264,270],{},[85,259,260,263],{},[52,261,262],{},"EpfLimitRemover.java","：模组主类，负责注册配置文件。",[85,265,266,269],{},[52,267,268],{},"Config.java","：使用NeoForge配置API定义配置项，并监听配置重载事件。",[85,271,272,275,276,279],{},[52,273,274],{},"CombatRulesMixin.java","：Mixin注入类，修改两处",[52,277,278],{},"Mth.clamp","的最大值参数。",[281,282,283],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":161,"searchDepth":173,"depth":179,"links":285},[286,288,290,292],{"id":66,"depth":173,"text":287},"功能特性章节 §",{"id":102,"depth":173,"text":289},"安装方式章节 §",{"id":139,"depth":173,"text":291},"配置说明章节 §",{"id":205,"depth":173,"text":293},"技术细节章节 §","2026\u002F5\u002F30",[296,297],"EPFLimitRemover是一个可配置的Minecraft模组，用于修改原版魔咒保护系数EPF的上限。","兼容Minecraft 1.21~1.21.11全系列版本。通过轻量级Mixin注入原版游戏。",[],"md",false,[302,305],[303,304],"https:\u002F\u002Fgithub.com\u002FCHJWOS\u002FEPFLimitRemover\u002F","原始项目",[306,307],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FEPFLimitRemover\u002F","关联仓库",{},true,"\u002Fpages\u002Fepf-limit-remover",{"title":5,"description":312},[296,297],"pages\u002Fepf-limit-remover",[315,318,321],[316,317],"lang","minecraft",[319,320],"inspiration","adaptation",[322,323],"content","tool","npQP5WdvfvtPJX_KIRFuDoIW2BANAQIn1er03pu1V0M",1781182081670]
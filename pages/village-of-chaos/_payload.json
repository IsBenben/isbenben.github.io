},[107,114,115],{},"资源管理","：管理木材、食物、石头三种基础资源",[73,118,119,122],{},[107,120,121],{},"职业系统","：村民可以从事伐木工人、渔夫、矿工、铁匠、教授等职业",[73,124,125,128],{},[107,126,127],{},"建筑升级","：升级建筑可以提高生产效率和容纳更多村民",[73,130,131,134],{},[107,132,133],{},"混乱机制","：建筑升级会增加混乱值，影响生产效率",[73,136,137,140],{},[107,138,139],{},"教程系统","：游戏通过弹窗教程引导玩家了解各项功能",[73,142,143,146],{},[107,144,145],{},"存档系统","：支持自动保存和手动保存，每5分钟自动保存一次",[55,148,149,150],{"id":149,"class":13},"技术栈",[15,151,153,156],{"class":17,"href":152},"#技术栈",[27,154,31],{"className":155},[30],[27,157,36],{"ariaHidden":34,"tabIndex":35},[70,159,160,166,172,178,184],{},[73,161,162,165],{},[107,163,164],{},"纯 JavaScript","：不依赖任何框架，使用原生 JavaScript 实现",[73,167,168,171],{},[107,169,170],{},"HTML5","：使用语义化 HTML 标签",[73,173,174,177],{},[107,175,176],{},"CSS3","：使用现代 CSS 进行样式设计",[73,179,180,183],{},[107,181,182],{},"PWA 支持","：支持作为渐进式 Web 应用安装",[73,185,186,189],{},[107,187,188],{},"响应式设计","：适配桌面和移动设备",[20,191,192,193],{"id":192,"class":13},"游戏玩法",[15,194,196,199],{"class":17,"href":195},"#游戏玩法",[27,197,31],{"className":198},[30],[27,200,36],{"ariaHidden":34,"tabIndex":35},[55,202,203,204],{"id":203,"class":13},"基础操作",[15,205,207,210],{"class":17,"href":206},"#基础操作",[27,208,31],{"className":209},[30],[27,211,36],{"ariaHidden":34,"tabIndex":35},[213,214,215,221,227,233,239],"ol",{},[73,216,217,220],{},[107,218,219],{},"收集资源","：点击\"采集木材\"和\"采集食物\"按钮手动收集资源",[73,222,223,226],{},[107,224,225],{},"邀请村民","：使用食物邀请村民加入村庄",[73,228,229,232],{},[107,230,231],{},"分配工作","：在\"分配\"标签页中分配村民到不同的工作岗位",[73,234,235,238],{},[107,236,237],{},"升级建筑","：在\"制造\"标签页中使用资源升级建筑",[73,240,241,244],{},[107,242,243],{},"研究科技","：在\"研究\"标签页中解锁高级功能",[55,246,121,247],{"id":121,"class":13},[15,248,250,253],{"class":17,"href":249},"#职业系统",[27,251,31],{"className":252},[30],[27,254,36],{"ariaHidden":34,"tabIndex":35},[38,256,257],{},"每个建筑都有三种角色：",[70,259,260,266,272],{},[73,261,262,265],{},[107,263,264],{},"村民","：基础工人，产生基础资源",[73,267,268,271],{},[107,269,270],{},"导师","：提高村民的工作效率",[73,273,274,277],{},[
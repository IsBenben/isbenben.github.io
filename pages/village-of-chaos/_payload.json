指定单词",[74,1133,1134,1080,1137],{},[108,1135,1136],{},"视觉反馈",[71,1138,1139,1142],{},[74,1140,1141],{},"正确字母按键变绿，错误字母按键变红，无效重复按键忽略",[74,1143,1144],{},"单词区域以下划线展示未猜字母，已猜字母直接显示",[74,1146,1147,1150],{},[108,1148,1149],{},"日志系统","：所有操作（游戏开始、按键结果、分享等）都记录在侧边日志区，带时间戳。",[74,1152,1153,1156],{},[108,1154,1155],{},"新游戏","：可随时重置随机单词（内置约5000个英文单词库）或通过分享链接开始新游戏。",[21,1158,150,1159],{"id":150,"class":14},[16,1160,1161,1164],{"class":18,"href":153},[28,1162,32],{"className":1163},[31],[28,1165,37],{"ariaHidden":35,"tabIndex":36},[71,1167,1168,1174,1180],{},[74,1169,1170,1173],{},[108,1171,1172],{},"HTML5 \u002F CSS3","：响应式Grid布局（两栏 → 单栏自适应）",[74,1175,1176,1179],{},[108,1177,1178],{},"jQuery 4.0.0","：DOM操作、事件绑定、动画帧优化",[74,1181,1182,1185],{},[108,1183,1184],{},"原生 JavaScript","：核心游戏逻辑、日期格式化、Base64编解码",[21,1187,1188,1189],{"id":1188,"class":14},"快速开始",[16,1190,1192,1195],{"class":18,"href":1191},"#快速开始",[28,1193,32],{"className":1194},[31],[28,1196,37],{"ariaHidden":35,"tabIndex":36},[56,1198,1199,1200],{"id":1199,"class":14},"下载项目",[16,1201,1203,1206],{"class":18,"href":1202},"#下载项目",[28,1204,32],{"className":1205},[31],[28,1207,37],{"ariaHidden":35,"tabIndex":36},[39,1209,1210,1211,1214],{},"将提供的",[328,1212,1213],{},"index.html","保存到本地（或部署到 Web 服务器）。",[56,1216,1217,1218],{"id":1217,"class":14},"运行游戏",[16,1219,1221,1224],{"class":18,"href":1220},"#运行游戏",[28,1222,32],{"className":1223},[31],[28,1225,37],{"ariaHidden":35,"tabIndex":36},[39,1227,1228,1229,1231],{},"直接用浏览器打开",[328,1230,1213],{},"即可开始游戏（无需任何构建步骤）。",[39,1233,1234],{},"游戏代码已内嵌所有样式、脚本和单词库，单文件即可运行。",[56,1236,1237,1238],{"id":1237,"class":14},"游戏规则",[16,1239,1241,1244],{"class":18,"href":1240},"#游戏规则",[28,1242,32],{"className":1243},[31],[28,1245,37],{"ariaHidden":35,"tabIndex":36},[71,1247,1248,1255,1278,1281],{},[74,1249,1250,1251,1254],{},"页面上方展示待猜单词（以下划线",[328,1252,1253],{},"_","表示未猜字母）。",[74,1256,1257,1258],{},"点击虚拟键盘上的字母（或直接按物理键盘字母键）猜测。\n",[71,1259,1260,1266,1272],{},[74,1261,1262,1265],{},[108,1263,1264],{},"正确猜测","：单词中所有相同字母位置会揭示，该按键变为绿色。",[74,1267,1268,1271],{},[108,1269,1270],{},"错误猜测","：按键变为红色，无字母匹配。",[74,1273,1274,1277],{},[108,1275,1276],{},"重复猜测","：已猜过的字母（无论对错）再次点击无效，计入“无效按键”。",[74,1279,1280],{},"猜出所有字母后游戏胜利，计时停止。",[74,1282,1283],{},"可通过“新游戏”按钮重置随机单词，“显示答案”直接揭示单词并结束游戏。",[56,1285,1286,1287],{"id":1286,"class":14},"分享单词",[16,1288,1290,1293],{"class":18,"href":1289},"#分享单词",[28,1291,32],{"className":1292},[31],[28,1294,37],{"ariaHidden":35,"tabIndex":36},[39,1296,1297],{},"点击“分享”按钮，游戏会生成当前单词的Base64编码，并打印一条包含完整链接的日志。该链接可直接复制发送给朋友，对方打开后会自动加载相同的单词（无需手动输入）。",[21,1299,1300,1301],{"id":1300,"class":14},"项目结构",[16,1302,1304,1307],{"class":18,"href":1303},"#项目结构",[28,1305,32],{"className":1306},[31],[28,1308,37],{"ariaHidden":35,"tabIndex":36},[321,1310,1313],{"className":1311,"code":1312,"language":409,"meta":326},[407],"index.html    单文件应用，包含：\n├── \u003Cstyle>    全部CSS样式（布局、键盘、按钮等）\n├── \u003Cbody>    DOM结构（单词区、信息面板、日志区、控制按钮、虚拟键盘）\n└── \u003Cscript>    所有游戏逻辑：\n    ├── 工具函数（数组填充、随机选择、日期格式化等）\n    ├── 虚拟键盘生成与渲染\n    ├── 单词库（内置约5000个常见英语单词）\n    ├── 游戏状态管理（guess数组、按键统计、计时）\n    ├── 统计面板自动刷新（使用requestAnimationFrame）\n    ├── 事件绑定（键盘点击、物理按键、按钮操作）\n    └── 分享链接解析与Base64解码\n",[328,1314,1312],{"__ignoreMap":326},[21,1316,1317,1318],{"id":1317,"class":14},"核心代码说明",[16,1319,1321,1324],{"class":18,"href":1320},"#核心代码说明",[28,1322,32],{"className":1323},[31],[28,1325,37],{"ariaHidden":35,"tabIndex":36},[56,1327,1328,1329],{"id":1328,"class":14},"单词库",[16,1330,1332,1335],{"class":18,"href":1331},"#单词库",[28,1333,32],{"className":1334},[31],[28,1336,37],{"ariaHidden":35,"tabIndex":36},[39,1338,1339,1340,1343],{},"变量",[328,1341,1342],{},"words","存储了约5000个英文单词（以逗号分隔的字符串）。新游戏时随机选取单词库中的单词。",[56,1345,1346,1347],{"id":1346,"class":14},"统计面板更新",[16,1348,1350,1353],{"class":18,"href":1349},"#统计面板更新",[28,1351,32],{"className":1352},[31],[28,1354,37],{"ariaHidden":35,"tabIndex":36},[39,1356,1357,1360,1361,1364],{},[328,1358,1359],{},"renderInfo","函数使用闭包缓存所有DOM元素，通过数据对象一次性更新。",[328,1362,1363],{},"updateInfo()","会每帧调用该函数，计算用时、速率、百分比等，并刷新面板。",[56,1366,1367,1368],{"id":1367,"class":14},"分享链接原理",[16,1369,1371,1374],{"class":18,"href":1370},"#分享链接原理",[28,1372,32],{"className":1373},[31],[28,1375,37],{"ariaHidden":35,"tabIndex":36},[39,1377,1378,1379,1382,1383,1386,1387,1390,1391,1394],{},"点击“分享”时，",[328,1380,1381],{},"btoa(wordRaw)","将原始单词编码为Base64，拼接成",[328,1384,1385],{},"?w=xxx","形式的 URL。页面加载时，读取",[328,1388,1389],{},"window.location.search","，若存在",[328,1392,1393],{},"w","参数，尝试Base64解码后作为初始单词。",[21,1396,1397,1398],{"id":1397,"class":14},"自定义配置",[16,1399,1401,1404],{"class":18,"href":1400},"#自定义配置",[28,1402,32],{"className":1403},[31],[28,1405,37],{"ariaHidden":35,"tabIndex":36},[56,1407,1408,1409],{"id":1408,"class":14},"修改单词库",[16,1410,1412,1415],{"class":18,"href":1411},"#修改单词库",[28,1413,32],{"className":1414},[31],[28,1416,37],{"ariaHidden":35,"tabIndex":36},[39,1418,1419,1420,1422],{},"直接编辑代码中",[328,1421,1342],{},"数组，增加或替换为自己的单词列表。",[56,1424,1425,1426],{"id":1425,"class":14},"调整键盘布局",[16,1427,1429,1432],{"class":18,"href":1428},"#调整键盘布局",[28,1430,32],{"className":1431},[31],[28,1433,37],{"ariaHidden":35,"tabIndex":36},[39,1435,1436,1437,1440],{},"修改",[328,1438,1439],{},"rows","数组，例如：",[321,1442,1446],{"className":1443,"code":1444,"language":1445,"meta":326,"style":326},"language-js shiki shiki-themes one-dark-pro one-dark-pro one-light","var rows = [\"qwertyuiop\", \"asdfghjkl\", \"zxcvbnm,\"]; \u002F\u002F 逗号代表空按键，仅用作布局\n","js",[328,1447,1448],{"__ignoreMap":326},[28,1449,1450,1453,1457,1459,1462,1465,1468,1471,1473,1476,1479],{"class":332,"line":333},[28,1451,1452],{"class":431},"var",[28,1454,1456],{"class":1455},"s7S6e"," rows",[28,1458,440],{"class":439},[28,1460,1461],{"class":340}," [",[28,1463,1464],{"class":449},"\"qwertyuiop\"",[28,1466,1467],{"class":340},", ",[28,1469,1470],{"class":449},"\"asdfghjkl\"",[28,1472,1467],{"class":340},[28,1474,1475],{"class":449},"\"zxcvbnm,\"",[28,1477,1478],{"class":340},"]; ",[28,1480,1481],{"class":424},"\u002F\u002F 逗号代表空按键，仅用作布局\n",[21,1483,1484,1485],{"id":1484,"class":14},"兼容性",[16,1486,1488,1491],{"class":18,"href":1487},"#兼容性",[28,1489,32],{"className":1490},[31],[28,1492,37],{"ariaHidden":35,"tabIndex":36},[71,1494,1495,1501,1507],{},[74,1496,1497,1500],{},[108,1498,1499],{},"桌面浏览器","：Chrome, Firefox, Edge, Safari",[74,1502,1503,1506],{},[108,1504,1505],{},"移动端","：iOS Safari, Android Chrome",[74,1508,1509,1512],{},[108,1510,1511],{},"IE兼容","：游戏核心逻辑基于ES5，但部分功能在IE中不支持，推荐使用现代浏览器。",[21,1514,1515,1516],{"id":1515,"class":14},"注意事项",[16,1517,1519,1522],{"class":18,"href":1518},"#注意事项",[28,1520,32],{"className":1521},[31],[28,1523,37],{"ariaHidden":35,"tabIndex":36},[71,1525,1526,1529,1532],{},[74,1527,1528],{},"物理键盘输入会自动转为小写匹配，单词中的字母比较时不区分大小写。",[74,1530,1531],{},"游戏开始时，非字母字符（如标点、空格）会被自动视为“已猜”，不计入需要猜测的字母数。",[74,1533,1534],{},"“显示答案”按钮会直接揭示所有字母，游戏标记为胜利，不再接受新输入。",[790,1536,1537],{},"html pre.shiki code .sXQNX, html code.shiki .sXQNX{--shiki-default:#C678DD;--shiki-dark:#C678DD;--shiki-light:#A626A4}html pre.shiki code .s7S6e, html code.shiki .s7S6e{--shiki-default:#E06C75;--shiki-dark:#E06C75;--shiki-light:#383A42}html pre.shiki code .ssHZq, html code.shiki .ssHZq{--shiki-default:#56B6C2;--shiki-dark:#56B6C2;--shiki-light:#0184BC}html pre.shiki code .sAxZK, html code.shiki .sAxZK{--shiki-default:#ABB2BF;--shiki-dark:#ABB2BF;--shiki-light:#383A42}html pre.shiki code .sAySN, html code.shiki .sAySN{--shiki-default:#98C379;--shiki-dark:#98C379;--shiki-light:#50A14F}html pre.shiki code .sT61s, html code.shiki .sT61s{--shiki-default:#7F848E;--shiki-default-font-style:italic;--shiki-dark:#7F848E;--shiki-dark-font-style:italic;--shiki-light:#A0A1A7;--shiki-light-font-style:italic}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);fo
戏可以自动进行，玩家可以随时回来查看进度",[74,113,114,117],{},[108,115,116],{},"资源管理","：管理木材、食物、石头三种基础资源",[74,119,120,123],{},[108,121,122],{},"职业系统","：村民可以从事伐木工人、渔夫、矿工、铁匠、教授等职业",[74,125,126,129],{},[108,127,128],{},"建筑升级","：升级建筑可以提高生产效率和容纳更多村民",[74,131,132,135],{},[108,133,134],{},"混乱机制","：建筑升级会增加混乱值，影响生产效率",[74,137,138,141],{},[108,139,140],{},"教程系统","：游戏通过弹窗教程引导玩家了解各项功能",[74,143,144,147],{},[108,145,146],{},"存档系统","：支持自动保存和手动保存，每5分钟自动保存一次",[56,149,150,151],{"id":150,"class":14},"技术栈",[16,152,154,157],{"class":18,"href":153},"#技术栈",[28,155,32],{"className":156},[31],[28,158,37],{"ariaHidden":35,"tabIndex":36},[71,160,161,167,173,179,185],{},[74,162,163,166],{},[108,164,165],{},"纯 JavaScript","：不依赖任何框架，使用原生 JavaScript 实现",[74,168,169,172],{},[108,170,171],{},"HTML5","：使用语义化 HTML 标签",[74,174,175,178],{},[108,176,177],{},"CSS3","：使用现代 CSS 进行样式设计",[74,180,181,184],{},[108,182,183],{},"PWA 支持","：支持作为渐进式 Web 应用安装",[74,186,187,190],{},[108,188,189],{},"响应式设计","：适配桌面和移动设备",[21,192,193,194],{"id":193,"class":14},"游戏玩法",[16,195,197,200],{"class":18,"href":196},"#游戏玩法",[28,198,32],{"className":199},[31],[28,201,37],{"ariaHidden":35,"tabIndex":36},[56,203,204,205],{"id":204,"class":14},"基础操作",[16,206,208,211],{"class":18,"href":207},"#基础操作",[28,209,32],{"className":210},[31],[28,212,37],{"ariaHidden":35,"tabIndex":36},[214,215,216,222,228,234,240],"ol",{},[74,217,218,221],{},[108,219,220],{},"收集资源","：点击\"采集木材\"和\"采集食物\"按钮手动收集资源",[74,223,224,227],{},[108,225,226],{},"邀请村民","：使用食物邀请村民加入村庄",[74,229,230,233],{},[108,231,232],{},"分配工作","：在\"分配\"标签页中分配村民到不同的工作岗位",[74,235,236,239],{},[108,237,238],{},"升级建筑","：在\"制造\"标签页中使用资源升级建筑",[74,241,242,245],{},[108,243,244],{},"研究科技","：在\"研究\"标签页中解锁高级功能",[56,247,122,248],{"id":122,"class":14},[16,249,251,254],{"class":18,"href":250},"#职业系统",[28,252,32],{"className":253},[31],[28,255,37],{"ariaHidden":35,"tabIndex":36},[39,257,258],{},"每个建筑都有三种角色：",[71,260,261,267,273],{},[74,262,263,266],{},[108,264,265],{},"村民","：基础工人，产生基础资源",[74,268,269,272],{},[108,270,271],{},"导师","：提高村民的工作效率",[74,274,275,278],{},[108,276,277],{},"经理","：提高导师的效率",[56,280,134,281],{"id":134,"class":14},[16,282,284,287],{"class":18,"href":283},"#混乱机制",[28,285,32],{"className":286},[31],[28,288,37],{"ariaHidden":35,"tabIndex":36},[39,290,291],{},"建筑升级会增加混乱值，混乱值越高，生产效率越低。需要平衡建筑等级和混乱值。",[56,293,58,295],{"id":294,"class":14},"游戏目标-1",[16,296,298,301],{"class":18,"href":297},"#游戏目标-1",[28,299,32],{"className":300},[31],[28,302,37],{"ariaHidden":35,"tabIndex":36},[39,304,305],{},"摧毁巨石，达到游戏胜利条件。",[56,307,308,309],{"id":308,"class":14},"调试模式",[16,310,312,315],{"class":18,"href":311},"#调试模式",[28,313,32],{"className":314},[31],[28,316,37],{"ariaHidden":35,"tabIndex":36},[39,318,319],{},"在浏览器控制台中执行以下代码可以快速获得资源：",[321,322,327],"pre",{"className":323,"code":324,"language":325,"meta":326,"style":326},"language-javascript shiki shiki-themes one-dark-pro one-dark-pro one-light","game.cheat();\n","javascript","",[328,329,330],"code",{"__ignoreMap":326},[28,331,334,338,342,346],{"class":332,"line":333},"line",1,[28,335,337],{"class":336},"s6EWR","game",[28,339,341],{"class":340},"sAxZK",".",[28,343,345],{"class":344},"sK8D8","cheat",[28,347,348],{"class":340},"();\n",[21,350,351,352],{"id":351,"class":14},"本地化实现",[16,353,355,358],{"class":18,"href":354},"#本地化实现",[28,356,32],{"className":357},[31],[28,359,37],{"ariaHidden":35,"tabIndex":36},[56,361,362,363],{"id":362,"class":14},"支持的语言",[16,364,366,369],{"class":18,"href":365},"#支持的语言",[28,367,32],{"className":368},[31],[28,370,37],{"ariaHidden":35,"tabIndex":36},[71,372,373,379,385],{},[74,374,375,378],{},[108,376,377],{},"英语 (en-US)","：原始语言",[74,380,381,384],{},[108,382,383],{},"简体中文 (zh-CN)","：本地化版本",[74,386,387,384],{},[108,388,389],{},"繁体中文 (zh-TW)",[56,391,392,393],{"id":392,"class":14},"本地化架构",[16,394,396,399],{"class":18,"href":395},"#本地化架构",[28,397,32],{"className":398},[31],[28,400,37],{"ariaHidden":35,"tabIndex":36},[39,402,403],{},"游戏使用自定义的 i18n（国际化）系统，基于以下文件结构：",[321,405,410],{"className":406,"code":408,"languag
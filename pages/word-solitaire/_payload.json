[{"data":1,"prerenderedAt":181},["ShallowReactive",2],{"article-word-solitaire":3},{"id":4,"title":5,"body":6,"date":147,"description":148,"downloads":151,"extension":155,"hide":156,"links":157,"meta":163,"navigation":164,"path":165,"seo":166,"slug":168,"stem":169,"tags":170,"__hash__":180},"articles\u002Farticles\u002Fword-solitaire.md","单词接龙",{"type":7,"value":8,"toc":136},"minimark",[9,13,34,63,66,77,88,91,94,101,112,115,118,129],[10,11,12],"p",{},"单词接龙是一个经典的文字游戏，玩家需要根据前一个单词的尾字母，找到一个以该字母开头的新单词。这个网页版游戏支持 AI 辅助和单词释义查询。",[14,15,16,18],"h2",{"id":16,"class":17},"基本规则","section-heading",[19,20,23,29],"a",{"class":21,"href":22},"section-link","#基本规则",[24,25,28,16],"span",{"className":26},[27],"visually-hidden","章节",[24,30,33],{"ariaHidden":31,"tabIndex":32},"true",-1," §",[35,36,37,45,51,57],"ul",{},[38,39,40,44],"li",{},[41,42,43],"strong",{},"首尾相接","：新单词的首字母需要和前一个单词的尾字母完全相同。",[38,46,47,50],{},[41,48,49],{},"单词有效","：单词必须在游戏字典中，否则无效。",[38,52,53,56],{},[41,54,55],{},"无重复","：同一个单词在一轮游戏中不能重复使用。",[38,58,59,62],{},[41,60,61],{},"大小写敏感","：只有小写字母被接受。",[10,64,65],{},"示例如下：",[67,68,73],"pre",{"className":69,"code":71,"language":72},[70],"language-text","apple->elephant->tiger->rabbit\n  ->monkey（首尾不相接，无效）\n  ->tiger (重复，无效)\n  ->ttt（不在字典中，无效）\n  ->TURKEY（大小写错误，无效）\n  ->turkey（正确接龙）\n","text",[74,75,71],"code",{"__ignoreMap":76},"",[14,78,79,80],{"id":79,"class":17},"操作方法",[19,81,83,86],{"class":21,"href":82},"#操作方法",[24,84,28,79],{"className":85},[27],[24,87,33],{"ariaHidden":31,"tabIndex":32},[10,89,90],{},"输入框中输入单词即开始。若没有单词可接龙，会自动显示消息。",[10,92,93],{},"在游戏过程中，将鼠标放在单词上，可查看单词的意思。",[10,95,96,97,100],{},"如果不会，可以点击“询问AI”进行 ",[74,98,99],{},"AI"," 辅助，基于输入匹配单词。",[14,102,103,104],{"id":103,"class":17},"游戏特色",[19,105,107,110],{"class":21,"href":106},"#游戏特色",[24,108,28,103],{"className":109},[27],[24,111,33],{"ariaHidden":31,"tabIndex":32},[10,113,114],{},"词汇库支持约15000词接龙和释义查询，涵盖基础词汇、学术词汇等，自动验证输入的单词是否有效。",[10,116,117],{},"释义涵盖基本释义、词性、常见短语对照，可配合玩家理解、学习单词。",[14,119,120,121],{"id":120,"class":17},"截图",[19,122,124,127],{"class":21,"href":123},"#截图",[24,125,28,120],{"className":126},[27],[24,128,33],{"ariaHidden":31,"tabIndex":32},[10,130,131],{},[132,133],"img",{"alt":134,"src":135},"单词接龙学习游戏界面","\u002Fraw\u002Fword-solitaire-screenshot.png",{"title":76,"searchDepth":137,"depth":137,"links":138},2,[139,141,143,145],{"id":16,"depth":137,"text":140},"基本规则章节基本规则 §",{"id":79,"depth":137,"text":142},"操作方法章节操作方法 §",{"id":103,"depth":137,"text":144},"游戏特色章节游戏特色 §",{"id":120,"depth":137,"text":146},"截图章节截图 §","2025\u002F3\u002F7",[149,150],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。",[152],[153,154],"\u002Fraw\u002Fword-solitaire.html","下载","md",false,[158,161],[159,160],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002Fword-solitaire.html","源代码",[153,162],"体验",{},true,"\u002Farticles\u002Fword-solitaire",{"title":5,"description":167},[149,150],"word-solitaire","articles\u002Fword-solitaire",[171,174,177],[172,173],"lang","web",[175,176],"inspiration","original",[178,179],"content","entertainment","g6GLTlX36utuS75PE3MEFPWi_ZEWJHV2qxzRJGkY204",1779597318614]
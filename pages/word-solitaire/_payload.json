[{"data":1,"prerenderedAt":187},["ShallowReactive",2],{"article-\u002Fpages\u002Fword-solitaire":3},{"id":4,"title":5,"body":6,"date":154,"description":155,"downloads":158,"extension":162,"hide":163,"links":164,"meta":170,"navigation":171,"path":172,"seo":173,"stem":175,"tags":176,"__hash__":186},"pages\u002Fpages\u002Fword-solitaire.md","单词接龙",{"type":7,"value":8,"toc":142},"minimark",[9,18,22,40,69,72,83,94,97,100,107,118,121,124,135],[10,11,5,13],"h1",{"id":5,"class":12},"section-heading",[14,15],"a",{"class":16,"href":17},"section-link","#单词接龙",[19,20,21],"p",{},"单词接龙是一个经典的文字游戏，玩家需要根据前一个单词的尾字母，找到一个以该字母开头的新单词。这个网页版游戏支持 AI 辅助和单词释义查询。",[23,24,25,26],"h2",{"id":25,"class":12},"基本规则",[14,27,29,35],{"class":16,"href":28},"#基本规则",[30,31,34],"span",{"className":32},[33],"visually-hidden","章节",[30,36,39],{"ariaHidden":37,"tabIndex":38},"true",-1," §",[41,42,43,51,57,63],"ul",{},[44,45,46,50],"li",{},[47,48,49],"strong",{},"首尾相接","：新单词的首字母需要和前一个单词的尾字母完全相同。",[44,52,53,56],{},[47,54,55],{},"单词有效","：单词必须在游戏字典中，否则无效。",[44,58,59,62],{},[47,60,61],{},"无重复","：同一个单词在一轮游戏中不能重复使用。",[44,64,65,68],{},[47,66,67],{},"大小写敏感","：只有小写字母被接受。",[19,70,71],{},"示例如下：",[73,74,79],"pre",{"className":75,"code":77,"language":78},[76],"language-text","apple->elephant->tiger->rabbit\n  ->monkey（首尾不相接，无效）\n  ->tiger (重复，无效)\n  ->ttt（不在字典中，无效）\n  ->TURKEY（大小写错误，无效）\n  ->turkey（正确接龙）\n","text",[80,81,77],"code",{"__ignoreMap":82},"",[23,84,85,86],{"id":85,"class":12},"操作方法",[14,87,89,92],{"class":16,"href":88},"#操作方法",[30,90,34],{"className":91},[33],[30,93,39],{"ariaHidden":37,"tabIndex":38},[19,95,96],{},"输入框中输入单词即开始。若没有单词可接龙，会自动显示消息。",[19,98,99],{},"在游戏过程中，将鼠标放在单词上，可查看单词的意思。",[19,101,102,103,106],{},"如果不会，可以点击“询问AI”进行 ",[80,104,105],{},"AI"," 辅助，基于输入匹配单词。",[23,108,109,110],{"id":109,"class":12},"游戏特色",[14,111,113,116],{"class":16,"href":112},"#游戏特色",[30,114,34],{"className":115},[33],[30,117,39],{"ariaHidden":37,"tabIndex":38},[19,119,120],{},"词汇库支持约15000词接龙和释义查询，涵盖基础词汇、学术词汇等，自动验证输入的单词是否有效。",[19,122,123],{},"释义涵盖基本释义、词性、常见短语对照，可配合玩家理解、学习单词。",[23,125,126,127],{"id":126,"class":12},"截图",[14,128,130,133],{"class":16,"href":129},"#截图",[30,131,34],{"className":132},[33],[30,134,39],{"ariaHidden":37,"tabIndex":38},[19,136,137],{},[138,139],"img",{"alt":140,"src":141},"单词接龙学习游戏界面","\u002Fraw\u002Fword-solitaire-screenshot.png",{"title":82,"searchDepth":143,"depth":144,"links":145},2,3,[146,148,150,152],{"id":25,"depth":143,"text":147},"基本规则章节 §",{"id":85,"depth":143,"text":149},"操作方法章节 §",{"id":109,"depth":143,"text":151},"游戏特色章节 §",{"id":126,"depth":143,"text":153},"截图章节 §","2025\u002F3\u002F7",[156,157],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。",[159],[160,161],"\u002Fraw\u002Fword-solitaire.html","下载","md",false,[165,168],[166,167],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002Fword-solitaire.html","源代码",[160,169],"体验",{},true,"\u002Fpages\u002Fword-solitaire",{"title":5,"description":174},[156,157],"pages\u002Fword-solitaire",[177,180,183],[178,179],"lang","web",[181,182],"inspiration","original",[184,185],"content","entertainment","6TVwHrXR0lnf3BXJuvuY7-9yORuMM-sN8AxysoGWfhE",1781179807514]
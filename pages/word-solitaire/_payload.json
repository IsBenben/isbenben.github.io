[{"data":1,"prerenderedAt":528},["ShallowReactive",2],{"article-\u002Fpages\u002Fword-solitaire":3},{"current":4,"prev":188,"next":236},{"id":5,"title":6,"body":7,"date":155,"description":156,"downloads":159,"extension":163,"hide":164,"links":165,"meta":171,"navigation":172,"path":173,"seo":174,"stem":176,"tags":177,"__hash__":187},"pages\u002Fpages\u002Fword-solitaire.md","单词接龙",{"type":8,"value":9,"toc":143},"minimark",[10,19,23,41,70,73,84,95,98,101,108,119,122,125,136],[11,12,6,14],"h1",{"id":6,"class":13},"section-heading",[15,16],"a",{"class":17,"href":18},"section-link","#单词接龙",[20,21,22],"p",{},"单词接龙是一个经典的文字游戏，玩家需要根据前一个单词的尾字母，找到一个以该字母开头的新单词。这个网页版游戏支持 AI 辅助和单词释义查询。",[24,25,26,27],"h2",{"id":26,"class":13},"基本规则",[15,28,30,36],{"class":17,"href":29},"#基本规则",[31,32,35],"span",{"className":33},[34],"visually-hidden","章节",[31,37,40],{"ariaHidden":38,"tabIndex":39},"true",-1," §",[42,43,44,52,58,64],"ul",{},[45,46,47,51],"li",{},[48,49,50],"strong",{},"首尾相接","：新单词的首字母需要和前一个单词的尾字母完全相同。",[45,53,54,57],{},[48,55,56],{},"单词有效","：单词必须在游戏字典中，否则无效。",[45,59,60,63],{},[48,61,62],{},"无重复","：同一个单词在一轮游戏中不能重复使用。",[45,65,66,69],{},[48,67,68],{},"大小写敏感","：只有小写字母被接受。",[20,71,72],{},"示例如下：",[74,75,80],"pre",{"className":76,"code":78,"language":79},[77],"language-text","apple->elephant->tiger->rabbit\n  ->monkey（首尾不相接，无效）\n  ->tiger (重复，无效)\n  ->ttt（不在字典中，无效）\n  ->TURKEY（大小写错误，无效）\n  ->turkey（正确接龙）\n","text",[81,82,78],"code",{"__ignoreMap":83},"",[24,85,86,87],{"id":86,"class":13},"操作方法",[15,88,90,93],{"class":17,"href":89},"#操作方法",[31,91,35],{"className":92},[34],[31,94,40],{"ariaHidden":38,"tabIndex":39},[20,96,97],{},"输入框中输入单词即开始。若没有单词可接龙，会自动显示消息。",[20,99,100],{},"在游戏过程中，将鼠标放在单词上，可查看单词的意思。",[20,102,103,104,107],{},"如果不会，可以点击“询问AI”进行 ",[81,105,106],{},"AI"," 辅助，基于输入匹配单词。",[24,109,110,111],{"id":110,"class":13},"游戏特色",[15,112,114,117],{"class":17,"href":113},"#游戏特色",[31,115,35],{"className":116},[34],[31,118,40],{"ariaHidden":38,"tabIndex":39},[20,120,121],{},"词汇库支持约15000词接龙和释义查询，涵盖基础词汇、学术词汇等，自动验证输入的单词是否有效。",[20,123,124],{},"释义涵盖基本释义、词性、常见短语对照，可配合玩家理解、学习单词。",[24,126,127,128],{"id":127,"class":13},"截图",[15,129,131,134],{"class":17,"href":130},"#截图",[31,132,35],{"className":133},[34],[31,135,40],{"ariaHidden":38,"tabIndex":39},[20,137,138],{},[139,140],"img",{"alt":141,"src":142},"单词接龙学习游戏界面","\u002Fraw\u002Fword-solitaire-screenshot.png",{"title":83,"searchDepth":144,"depth":145,"links":146},2,3,[147,149,151,153],{"id":26,"depth":144,"text":148},"基本规则章节 §",{"id":86,"depth":144,"text":150},"操作方法章节 §",{"id":110,"depth":144,"text":152},"游戏特色章节 §",{"id":127,"depth":144,"text":154},"截图章节 §","2025\u002F03\u002F07",[157,158],"单词接龙是一个经典的文字游戏，只要新单词的首字母和前一个单词的尾字母相同，就可以接上。","这个网页版游戏支持不会时AI辅助和释义查询。",[160],[161,162],"\u002Fraw\u002Fword-solitaire.html","下载","md",false,[166,169],[167,168],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002Fword-solitaire.html","源代码",[161,170],"体验",{},true,"\u002Fpages\u002Fword-solitaire",{"title":6,"description":175},[157,158],"pages\u002Fword-solitaire",[178,181,184],[179,180],"lang","web",[182,183],"inspiration","original",[185,186],"content","entertainment","WhyKIGqBc04pXuzIbYkSifl8lC7QtZ9eNBVB4YDljnk",{"id":189,"title":190,"body":191,"date":216,"description":217,"downloads":218,"extension":163,"hide":164,"links":222,"meta":225,"navigation":172,"path":226,"seo":227,"stem":229,"tags":230,"__hash__":235},"pages\u002Fpages\u002Ffile-matchmaking.md","文件消消乐",{"type":8,"value":192,"toc":214},[193,198,201,204],[11,194,190,195],{"id":190,"class":13},[15,196],{"class":17,"href":197},"#文件消消乐",[20,199,200],{},"这个程序会帮你创建很多文件，删除的文件会被重新创建。",[20,202,203],{},"删除的越多得分越多。",[20,205,206],{},[207,208,209,210,213],"del",{},"绝对不会告诉任何人：按 ",[81,211,212],{},"Alt+F4"," 可以关闭窗口。",{"title":83,"searchDepth":144,"depth":145,"links":215},[],"2025\u002F03\u002F01",[200,203],[219],[220,221],"\u002Fraw\u002Ffile-matchmaking.py","下载：Python程序",[223],[224,168],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002Ffile-matchmaking.py",{},"\u002Fpages\u002Ffile-matchmaking",{"title":190,"description":228},[200,203],"pages\u002Ffile-matchmaking",[231,233,234],[179,232],"python3",[182,183],[185,186],"XpLvMbQGHTNauKiJ6mcWcX5KxfwgTx6iw-4vvGwyq0U",{"id":237,"title":238,"body":239,"date":505,"description":506,"downloads":509,"extension":163,"hide":164,"links":512,"meta":515,"navigation":172,"path":516,"seo":517,"stem":519,"tags":520,"__hash__":527},"pages\u002Fpages\u002Fanimated-calculator.md","动画计算器",{"type":8,"value":240,"toc":494},[241,246,257,320,331,401,412,419,446,457,479,488],[11,242,238,243],{"id":238,"class":13},[15,244],{"class":17,"href":245},"#动画计算器",[24,247,248,249],{"id":248,"class":13},"运算能力",[15,250,252,255],{"class":17,"href":251},"#运算能力",[31,253,35],{"className":254},[34],[31,256,40],{"ariaHidden":38,"tabIndex":39},[42,258,259,269,287,297,307],{},[45,260,261,264,265,268],{},[48,262,263],{},"基础运算","：支持 ",[81,266,267],{},"+-*\u002F"," 四则运算，遵循标准优先级（先乘除后加减）。",[45,270,271,274,275,278,279,282,283,286],{},[48,272,273],{},"幂运算","：使用 ",[81,276,277],{},"^"," 符号表示乘方，优先级高于乘除，右结合（如 ",[81,280,281],{},"2^3^2"," = ",[81,284,285],{},"2^(3^2)","）。",[45,288,289,292,293,296],{},[48,290,291],{},"括号支持","：允许任意嵌套的 ",[81,294,295],{},"()"," 括号，改变运算顺序。",[45,298,299,302,303,306],{},[48,300,301],{},"负数处理","：支持负号直接输入（如 ",[81,304,305],{},"5+-3"," 解析为 5 + (-3)），也支持负数作为表达式起始。",[45,308,309,312,313,316,317,286],{},[48,310,311],{},"小数缩写","：小数点前后可省略 0（如输入 ",[81,314,315],{},".5"," 自动补全为 ",[81,318,319],{},"0.5",[24,321,322,323],{"id":322,"class":13},"交互体验",[15,324,326,329],{"class":17,"href":325},"#交互体验",[31,327,35],{"className":328},[34],[31,330,40],{"ariaHidden":38,"tabIndex":39},[42,332,333,374,395],{},[45,334,335,338,339],{},[48,336,337],{},"按键输入","：\n",[42,340,341,371],{},[45,342,343,344,347,348,351,352,355,356,358,359,362,363,366,367,370],{},"提供数字键 ",[81,345,346],{},"0-9","、小数点 ",[81,349,350],{},".","、运算符 ",[81,353,354],{},"+-*\u002F^","、括号 ",[81,357,295],{},"、退格 ",[81,360,361],{},"\u003C","、清空 ",[81,364,365],{},"AC","、等于 ",[81,368,369],{},"=","。",[45,372,373],{},"支持按键连输，退格键长按可连续快速删除；数字和运算符长按可重复输入。",[45,375,376,338,379],{},[48,377,378],{},"光标移动",[42,380,381,392],{},[45,382,383,384,387,388,391],{},"支持 ",[81,385,386],{},"←"," ",[81,389,390],{},"→"," 移动光标，可在表达式任意位置插入\u002F删除。",[45,393,394],{},"光标移动带有非线性缓动动画，视觉反馈柔和。",[45,396,397,400],{},[48,398,399],{},"流畅动效","：所有按键按下时有缩放反馈；光标移动具有缓动效果。",[24,402,403,404],{"id":403,"class":13},"核心算法实现",[15,405,407,410],{"class":17,"href":406},"#核心算法实现",[31,408,35],{"className":409},[34],[31,411,40],{"ariaHidden":38,"tabIndex":39},[20,413,414,415,418],{},"解析策略采用",[48,416,417],{},"递归下降 + 结果栈","解析表达式字符串。",[420,421,422,428,434,440],"ol",{},[45,423,424,427],{},[48,425,426],{},"词法分析","：将输入字符串拆解为Token（数字、运算符、括号、负号标记）。",[45,429,430,433],{},[48,431,432],{},"数值计算","：树形遍历Token，执行运算。遇到除零、NaN、无穷大等异常时，停止递归并抛出错误。",[45,435,436,439],{},[48,437,438],{},"递归回溯","：若计算过程中某节点失败，则向上回溯，将整个表达式标记为无效，并清空栈顶中间结果。",[45,441,442,445],{},[48,443,444],{},"最终输出","：成功解析且无错误时，栈顶即为最终计算结果；否则反馈错误信息。",[24,447,448,449],{"id":448,"class":13},"错误处理与用户反馈",[15,450,452,455],{"class":17,"href":451},"#错误处理与用户反馈",[31,453,35],{"className":454},[34],[31,456,40],{"ariaHidden":38,"tabIndex":39},[42,458,459,465,471],{},[45,460,461,464],{},[48,462,463],{},"实时检查","：输入时动态显示错误消息。",[45,466,467,470],{},[48,468,469],{},"计算错误提示","：语法错误如括号不匹配、Token解析错误，数字格式错误分别显示不同消息。",[45,472,473,478],{},[48,474,475],{},[81,476,477],{},"NaN","：针对常见除0，Infinity加减除等运算错误自动识别。",[24,480,127,481],{"id":127,"class":13},[15,482,483,486],{"class":17,"href":130},[31,484,35],{"className":485},[34],[31,487,40],{"ariaHidden":38,"tabIndex":39},[20,489,490],{},[139,491],{"alt":492,"src":493},"使用Scratch动画计算器计算嵌套表达式","\u002Fraw\u002Fanimated-calculator-screenshot.png",{"title":83,"searchDepth":144,"depth":145,"links":495},[496,498,500,502,504],{"id":248,"depth":144,"text":497},"运算能力章节 §",{"id":322,"depth":144,"text":499},"交互体验章节 §",{"id":403,"depth":144,"text":501},"核心算法实现章节 §",{"id":448,"depth":144,"text":503},"错误处理与用户反馈章节 §",{"id":127,"depth":144,"text":154},"2025\u002F04\u002F29",[507,508],"支持多种运算格式，负数，小数。用户操作有非线性的流畅动效。支持识别常见语法错误，计算错误。","纯Scratch实现，利用到栈，递归等技巧，实时显示运算结果。",[510],[511,162],"\u002Fraw\u002Fanimated-calculator.sb3",[513],[514,170],"\u002Fraw\u002Fanimated-calculator.html",{},"\u002Fpages\u002Fanimated-calculator",{"title":238,"description":518},[507,508],"pages\u002Fanimated-calculator",[521,523,525],[179,522],"scratch3",[182,524],"adaptation",[185,526],"tool","Vf-LhRBOJhRGajg7_lnDJgHeZS5oQOfaP9kmOaSD55k",1782556477768]
58,359],"这个小程序复制了以 MIT License 开源的 https:\u002F\u002Fgithub.com\u002Fitorr\u002Fhomo 代码。","可论证任何数字为 5277 和 7725。",[361,364],[362,363],"\u002Fraw\u002F5277-demonstrator.html","下载：5277论证器",[365,366],"\u002Fraw\u002F7725-demonstrator.html","下载：7725论证器",[368,371,374,376],[369,370],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002F5277-demonstrator.html","源代码（5277）",[372,373],"https:\u002F\u002Fgithub.com\u002FIsBenben\u002FFunny-Things\u002Fblob\u002Fmain\u002F7725-demonstrator.html","源代码（7725）",[362,375],"体验：5277论证器",[365,377],"体验：7725论证器",{},"\u002Fpages\u002Fdemonstrator",{"title":244,"description":381},[358,359],"pages\u002Fdemonstrator",[384,386,387],[233,385],"web",[236,237],[239,388],"tool","LxT2v6ruzZJ7gkbu6jCbp8C-I9RiRcYjMvHGTq9KmfA",{"id":391,"title":392,"body":393,"date":684,"description":685,"downloads":689,"extension":216,"hide":217,"links":692,"meta":695,"navigation":226,"path":696,"seo":697,"stem":699,"tags":700,"__hash__":705},"pages\u002Fpages\u002Fchicken-parkour.md","小鸡跑酷",{"type":8,"value":394,"toc":668},[395,400,409,412,424,453,464,478,489,509,520,523,528,558,563,600,605,620,631,634,651,662],[11,396,392,397],{"id":392,"class":14},[16,398],{"class":18,"href":399},"#小鸡跑酷",[21,401,23,402],{"id":23,"class":14},[16,403,404,407],{"class":18,"href":26},[28,405,32],{"className":406},[31],[28,408,37],{"ariaHidden":35,"tabIndex":36},[39,410,411],{},"小鸡跑酷是一款基于Scratch风格的横版跑酷游戏，玩家需要控制一只可爱的小鸡在不断滚动的背景中前进。",[413,414,415,416],"h3",{"id":415,"class":14},"核心机制",[16,417,419,422],{"class":18,"href":418},"#核心机制",[28,420,32],{"className":421},[31],[28,423,37],{"ariaHidden":35,"tabIndex":36},[425,426,427,435,441,447],"ul",{},[428,429,430,434],"li",{},[431,432,433],"strong",{},"背景滚动","：通过背景的连续滚动模拟小鸡的向前移动效果",[428,436,437,440],{},[431,438,439],{},"跳跃控制","：玩家按下空格键可以让小鸡跳跃，躲避地面障碍物",[428,442,443,446],{},[431,444,445],{},"重力系统","：游戏内置了重力模拟，小鸡跳跃后会自然下落，需要掌握好跳跃时机",[428,448,449,452],{},[431,450,451],{},"道具系统","：地图右侧会不断随机出现各种道具，碰到道具会获得或失去相应分数",[413,454,455,456],{"id":455,"class":14},"操作方式",[16,457,459,462],{"class":18,"href":458},"#操作方式",[28,460,32],{"className":461},[31],[28,463,37],{"ariaHidden":35,"tabIndex":36},[425,465,466,472],{},[428,467,468,471],{},[431,469,470],{},"空格键","：让小鸡跳跃",[428,473,474,477],{},[431,475,476],{},"点击按钮","：可以开始或结束游戏",[413,479,480,481],{"id":480,"class":14},"游戏特色",[16,482,484,487],{"class":18,"href":483},"#游戏特色",[28,485,32],{"className":486},[31],[28,488,37],{"ariaHidden":35,"tabIndex":36},[425,490,491,497,503],{},[428,492,493,496],{},[431,494,495],{},"Scratch风格","：采用经典的Scratch编程风格，画面简洁可爱",[428,498,499,502],{},[431,500,501],{},"简单易上手","：操作简单，点击即玩",[428,504,505,508],{},[431,506,507],{},"随机性","：道具的出现位置和类型具有随机性，每次游戏体验都不同",[21,510,511,512],{"id":511,"class":14},"道具",[16,513,515,518],{"class":18,"href":514},"#道具",[28,516,32],{"className":517},[31],[28,519,37],{"ariaHidden":35,"tabIndex":36},[39,521,522],{},"游戏中会出现各种道具，玩家需要根据道具类型决定是否收集：",[39,524,525],{},[431,526,527],{},"加分道具：",[425,529,530,540,549],{},[428,531,532,535,536,539],{},[431,533,534],{},"钻石","：",[46,537,538],{},"+20","分 - 珍贵的加分道具，需要跳跃收集",[428,541,542,535,545,548],{},[431,543,544],{},"金币",[46,546,547],{},"+15","分 - 常见的高分道具",[428,550,551,535,554,557],{},[431,552,553],{},"鸡蛋",[46,555,556],{},"+10","分 - 基础的加分道具",[39,559,560],{},[431,561,562],{},"减分道具（需要躲避）：",[425,564,565,574,583,592],{},[428,566,567,535,570,573],{},[431,568,569],{},"毒药",[46,571,572],{},"-20","分 - 危险道具，会大幅减分",[428,575,576,535,579,582],{},[431,577,578],{},"坑",[46,580,581],{},"-15","分 - 地面陷阱，需要跳跃躲避",[428,584,585,535,588,591],{},[431,586,587],{},"刺猬",[46,589,590],{},"-10","分 - 会扎到小鸡受伤减分",[428,593,594,535,597,599],{},[431,595,596],{},"云朵",[46,598,590],{},"分 - 乌云下雨导致减分",[39,601,602],{},[431,603,604],{},"特殊道具：",[425,606,607],{},[428,608,609,612,613,615,616,619],{},[431,610,611],{},"盲盒","：随机",[46,614,581],{},"~",[46,617,618],{},"15","分 - 运气道具，可能加分也可能减分，适合喜欢冒险的玩家",[21,621,622,623],{"id":622,"class":14},"游戏技巧",[16,624,626,629],{"class":18,"href":625},"#游戏技巧",[28,627,32],{"className":628},[31],[28,630,37],{"ariaHidden":35,"tabIndex":36},[39,632,633],{},"想要获得更高分数，玩家需要掌握以下技巧：",[425,635,636,639,642,645,648],{},[428,637,638],{},"根据道具出现的频率调整跳跃节奏，既不能频繁跳跃浪费体力，也不能错过收集道具的机会",[428,640,641],{},"预判能力，提前观察道具类型，判断是否需要跳跃收集或躲避",[428,643,644],{},"优先收集钻石和金币等高分道具",[428,646,647],{},"坚决躲避毒药和坑等高危障碍",[428,649,650],{},"对于盲盒，根据当前分数决定是否冒险",[21,652,653,654],{"id":653,"class":14},"截图",[16,655,657,660],{"class":18,"href":656},"#截图",[28,658,32],{"className":659},[31],[28,661,37],{"ariaHidden":35,"tabIndex":36},[39,663,664],{},[193,665],{"alt":666,"src":667},"小鸡跑酷游戏画面截图","\u002Fraw\u002Fchicken-pakour-screenshot.png",{"title":56,"searchDepth":79,"depth":92,"links":669},[670,678,680,682],{"id":23,"depth":79,"text":204,"children":671},[672,674,676],{"id":415,"depth":92,"text":673},"核心机制章节 §",{"id":455,"depth":92,"text":675},"操作方式章节 §",{"id":480,"depth":92,"text":677},"游戏特色章节 §",{"id":511,"depth":79,"text":679},"道具章节 §",{"id":622,"depth":79,"text":681},"游戏技巧章节 §",{"id":653,"depth":79,"text":683},"截图章节 §","2025\u002F02\u002F10",[686,687,688],"基于Scratch风格的横版跑酷游戏，控制小鸡在滚动背景中跳跃前进。","通过背景滚动、跳跃控制、重力系统、道具系统等机制，躲避障碍物收集道具。","简单易上手且具有随机性，每次游戏体验都不同，需要一定的技巧。",[690],[691,215],"\u002Fraw\u002Fchicken-parkour.sb3",[693],[694,221],"\u002Fraw\u002Fchicken-parkour.html",{},"\u002Fpages\u002Fchicken-parkour",{"title":392,"description":698},[686,687,688],"pages\u002Fchicken-parkour",[701,702,704],[233,234],[236,703],"original",[239,240],"EdYW76_2qu1lQrwSV-3CcYYYbIi80bPBsLSHHTo26yU",1782556477856]
s":61,"line":112},4,[28,114,95],{"class":65},[28,116,117],{"class":98},"2",[28,119,102],{"class":65},[28,121,48],{"class":69},[28,123,35],{"class":98},[28,125,126],{"class":75}," \u002F\u002F false\n",[28,128,130,132,134,136,138,141],{"class":61,"line":129},5,[28,131,95],{"class":65},[28,133,117],{"class":98},[28,135,102],{"class":65},[28,137,48],{"class":69},[28,139,140],{"class":98},"false",[28,142,126],{"class":75},[39,144,145,150],{},[16,146,6],{"href":147,"rel":148},"https:\u002F\u002Fwww.thomas-yang.me\u002Fprojects\u002Foh-my-dear-js\u002F",[149],"nofollow","具体介绍了这一特点。",[39,152,153,154,156,157,160,161,164],{},"游戏正是利用了这一特点。只要每个选择的相邻元素满足==判断为 ",[46,155,35],{},"，就可以消除。选择的越多得分越多。因为地方不够，这个游戏用 ",[46,158,159],{},"void 0"," 代替 ",[46,162,163],{},"undefined","。",[39,166,167,168,171],{},"你可以修改随机数种子，让游戏生成相同的随机数，固定初始局面。也可以输入 ",[46,169,170],{},"Today","，自动填充当天的日期作为随机数种子。",[39,173,174,178],{},[175,176,177],"del",{},"如果发现bug，欢迎提出。","（这里没有评论区）但是像前文所述的==特性可不是bug哦！",[21,180,181,182],{"id":181,"class":14},"游戏内截图",[16,183,185,188],{"class":18,"href":184},"#游戏内截图",[28,186,32],{"className":187},[31],[28,189,37],{"ariaHidden":35,"tabIndex":36},[39,191,192],{},[193,194],"img",{"alt":195,"src":196},"JS等于消消乐游戏使用种子0产生的初始局面","\u002Fraw\u002Foh-my-dear-js-screenshot.png",[198,199,200],"style",{},"html pre.shiki code .sAxZK, html code.shiki .sAxZK{--shiki-default:#ABB2BF;--shiki-dark:#ABB2BF;--shiki-light:#383A42}html pre.shiki code .ssHZq, html code.shiki .ssHZq{--shiki-default:#56B6C2;--shiki-dark:#56B6C2;--shiki-light:#0184BC}html pre.shiki code .sT61s, html code.shiki .sT61s{--shiki-default:#7F848E;--shiki-default-font-style:italic;--shiki-dark:#7F848E;--shiki-dark-font-style:italic;--shiki-light:#A0A1A7;--shiki-light-font-style:italic}html pre.shiki code .sMpXI, html code.shiki .sMpXI{--shiki-default:#D19A66;--shiki-dark:#D19A66;--shiki-light:#986801}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);f